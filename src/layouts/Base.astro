---
import '../styles/global.css';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import NavPrefooter from '../components/global/NavPrefooter.astro';
import WhatsAppButton from '../components/global/WhatsAppButton.astro';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
}

const {
  title,
  description,
  keywords,
  ogImage = '/images/monitores-contra-incendios-refineria-petroleo-gas.webp',
} = Astro.props;

const site = 'https://monitorescontraincendios.com';
const canonical = new URL(Astro.url.pathname, site).href;

// OG: Facebook/LinkedIn/WhatsApp no soportan webp/avif de forma confiable →
// servir espejo JPEG 1200×630 pre-generado en /images/og/ (basename.jpg).
let ogPath = ogImage;
if (/\.(avif|webp)$/i.test(ogPath)) {
  const base = (ogPath.split('/').pop() ?? '').replace(/\.(avif|webp)$/i, '');
  ogPath = `/images/og/${base}.jpg`;
}
const ogImageAbs = new URL(ogPath, site).href;
const ogImageType = ogPath.toLowerCase().endsWith('.png')
  ? 'image/png'
  : ogPath.toLowerCase().endsWith('.svg')
    ? 'image/svg+xml'
    : 'image/jpeg';

// BreadcrumbList automático por ruta (L3): mapa slug → { padre, nombre }
const l3Breadcrumbs: Record<string, { parentName: string; parentUrl: string; name: string }> = {
  'monitores-fijos': { parentName: 'Productos', parentUrl: '/productos', name: 'Monitores Fijos Industriales' },
  'monitores-portatiles': { parentName: 'Productos', parentUrl: '/productos', name: 'Monitores Portátiles' },
  'monitores-automaticos': { parentName: 'Productos', parentUrl: '/productos', name: 'Monitores Automáticos' },
  'boquillas': { parentName: 'Productos', parentUrl: '/productos', name: 'Boquillas y Accesorios' },
  'petroleo-gas': { parentName: 'Industrias', parentUrl: '/industrias', name: 'Petróleo y Gas' },
  'petroquimica': { parentName: 'Industrias', parentUrl: '/industrias', name: 'Petroquímica y Química' },
  'generacion-de-energia': { parentName: 'Industrias', parentUrl: '/industrias', name: 'Generación de Energía' },
  'manufactura': { parentName: 'Industrias', parentUrl: '/industrias', name: 'Manufactura e Industrial' },
  'mineria': { parentName: 'Industrias', parentUrl: '/industrias', name: 'Minería' },
  'aviacion': { parentName: 'Industrias', parentUrl: '/industrias', name: 'Aviación' },
  'bomberos': { parentName: 'Industrias', parentUrl: '/industrias', name: 'Bomberos y Gobierno' },
  'diseno-ingenieria': { parentName: 'Servicios', parentUrl: '/servicios', name: 'Diseño e Ingeniería' },
  'instalacion': { parentName: 'Servicios', parentUrl: '/servicios', name: 'Instalación Profesional' },
  'mantenimiento-preventivo': { parentName: 'Servicios', parentUrl: '/servicios', name: 'Mantenimiento Preventivo' },
  'mantenimiento-correctivo': { parentName: 'Servicios', parentUrl: '/servicios', name: 'Mantenimiento Correctivo' },
  'capacitacion': { parentName: 'Servicios', parentUrl: '/servicios', name: 'Capacitación Especializada' },
  'consultoria-normativa': { parentName: 'Servicios', parentUrl: '/servicios', name: 'Consultoría Normativa' },
};
const slug = Astro.url.pathname.replace(/^\/|\/$/g, '');
const bc = l3Breadcrumbs[slug];
const breadcrumbSchema = bc && {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: site + '/' },
    { '@type': 'ListItem', position: 2, name: bc.parentName, item: new URL(bc.parentUrl, site).href },
    { '@type': 'ListItem', position: 3, name: bc.name, item: canonical },
  ],
};

// NAP / redes OMITIDOS: el teléfono (+52-55-1234-5678, secuencial), la dirección
// (Reforma 505 / Torre Mayor, scaffold) y los perfiles sociales (enlazados como
// href="#" en Footer/TopBar, no verificados) son PLACEHOLDER/fabricados → fuera del
// schema (regla cero contenido fabricado). Reponer address/contactPoint/sameAs cuando
// el cliente entregue NAP y perfiles reales.
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'AQUEON',
  alternateName: 'AQUEON México',
  url: site,
  logo: {
    '@type': 'ImageObject',
    url: `${site}/apple-touch-icon.png`,
    width: 180,
    height: 180,
  },
  description:
    'Proveedor líder de monitores contra incendios industriales en México. Equipos certificados FM Approved y UL Listed.',
};

// telephone + address OMITIDOS por placeholder/scaffold (ver nota arriba). Se conservan
// datos reales/consistentes on-page: email (contacto@aqueon.com.mx, uniforme en el sitio),
// horario (Lun-Vie 8-18), áreaServida y priceRange. Reponer telephone/address con NAP real.
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'AQUEON México',
  url: site,
  image: ogImageAbs,
  priceRange: '$$$',
  email: 'contacto@aqueon.com.mx',
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '08:00',
    closes: '18:00',
  },
  areaServed: {
    '@type': 'Country',
    name: 'México',
  },
};
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags Primarios -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content="AQUEON México" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <!-- Geo Tags para México -->
    <meta name="geo.region" content="MX" />
    <meta name="geo.placename" content="Ciudad de México" />
    <meta name="geo.position" content="19.432608;-99.133209" />
    <meta name="ICBM" content="19.432608, -99.133209" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content="AQUEON México" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#e02424" />

    <!-- Preload de fuentes críticas -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/space-grotesk-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
</head>
<body>
    <!-- Skip Navigation para Accesibilidad -->
    <a href="#contenido-principal" class="skip-link">Saltar al contenido principal</a>

    <Header />

    <main id="contenido-principal">
        <slot />
    </main>

    <NavPrefooter />

    <Footer />

    <WhatsAppButton />

    <script>
        import '../scripts/menu.js';
    </script>
</body>
</html>
