---
const marcas = [
  'Elkhart Brass',
  'Akron Brass',
  'Task Force Tips',
  'Potter Roemer',
  'Angus Fire',
  'Williams Fire',
];

const certificaciones = [
  { nombre: 'FM Approved', detalle: 'Factory Mutual Research' },
  { nombre: 'UL Listed', detalle: 'Underwriters Laboratories' },
  { nombre: 'NFPA Compliant', detalle: 'National Fire Protection Association' },
  { nombre: 'ISO 9001', detalle: 'Sistema de Gestión de Calidad' },
];
---
<section class="brands-section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Nuestros Aliados</span>
            <h2>Distribuidores Autorizados de Marcas Líderes</h2>
            <p>
                Trabajamos exclusivamente con los fabricantes más reconocidos a nivel mundial en equipos contra incendio.
                Esta alianza nos permite ofrecer productos de primera línea con garantía de fábrica y soporte técnico directo.
            </p>
        </div>

        <div class="brands-grid">
            {marcas.map((marca) => (
                <div class="brand-item">
                    <div class="brand-placeholder">{marca}</div>
                </div>
            ))}
        </div>

        <div class="certifications">
            <h3>Certificaciones que Respaldan Nuestra Calidad</h3>
            <div class="certifications-grid">
                {certificaciones.map((cert) => (
                    <div class="cert-item">
                        <div class="cert-icon">
                            <i class="fas fa-certificate" aria-hidden="true"></i>
                        </div>
                        <span>{cert.nombre}</span>
                        <p>{cert.detalle}</p>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
