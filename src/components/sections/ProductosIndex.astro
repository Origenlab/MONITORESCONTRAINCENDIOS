---
import { categorias } from '../../data/productos';

// Páginas L3 dedicadas por categoría (las demás usan ancla en /productos)
const l3: Record<string, string> = {
  'monitores-fijos': '/monitores-fijos',
  'monitores-portatiles': '/monitores-portatiles',
  'monitores-automaticos': '/monitores-automaticos',
  'boquillas': '/boquillas',
};
const catUrl = (id: string) => l3[id] ?? `/productos#${id}`;
---
<section id="productos" class="products-section">
    <div class="container">
        <div class="section-header split">
            <div class="section-header__head">
                <span class="section-tag">Catálogo de Productos</span>
                <h2>Monitores Contra Incendios Certificados</h2>
            </div>
            <div class="section-header__body">
                <p>
                    Línea completa de monitores <strong>fijos, portátiles y automáticos</strong> diseñados
                    para la protección de instalaciones industriales de alto riesgo.
                </p>
                <p>
                    Cada equipo está certificado <strong>FM Approved y UL Listed</strong>: el cumplimiento que exigen
                    PEMEX, las aseguradoras y las auditorías de Protección Civil.
                </p>
            </div>
        </div>

        {categorias.map((categoria) => (
            <div class="product-category">
                <div class="section-header split">
                    <div class="section-header__head">
                        <h3 id={categoria.id}><a href={catUrl(categoria.id)}>{categoria.titulo}</a></h3>
                        <a href={catUrl(categoria.id)} class="category-link">Ver toda la categoría <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                    </div>
                    <div class="section-header__body">
                        {categoria.parrafos.map((parrafo) => (
                            <p set:html={parrafo} />
                        ))}
                    </div>
                </div>

                <div class="products-grid">
                    {categoria.productos.map((producto) => (
                        <article class="product-card">
                            {producto.badge && (
                                <div class={producto.badgePremium ? 'product-badge premium' : 'product-badge'}>{producto.badge}</div>
                            )}
                            <div class="product-image">
                                <div class="image-placeholder">
                                    <i class={producto.placeholderIcon} aria-hidden="true"></i>
                                    <span>{producto.placeholderLabel}</span>
                                </div>
                            </div>
                            <div class="product-info">
                                <h4>{producto.nombre}</h4>
                                <p>{producto.descripcion}</p>
                                <ul class="product-specs">
                                    {producto.specs.map((spec) => (
                                        <li><i class={spec.icon} aria-hidden="true"></i> {spec.text}</li>
                                    ))}
                                </ul>
                                <div class="product-actions">
                                    <a href="/#cotizar" class="btn btn-primary btn-sm">Solicitar Cotización</a>
                                    {producto.fichaTecnica && (
                                        <a href="#" class="btn btn-outline btn-sm">Ficha Técnica</a>
                                    )}
                                </div>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        ))}

        <div class="products-cta">
            <p>Explore el catálogo completo con todas las especificaciones técnicas, o contáctenos para una recomendación personalizada según su instalación.</p>
            <div class="products-cta-actions">
                <a href="/productos" class="btn btn-primary btn-lg">
                    <i class="fas fa-layer-group" aria-hidden="true"></i> Ver Catálogo Completo
                </a>
                <a href="/#contacto" class="btn btn-secondary btn-lg">
                    <i class="fas fa-phone" aria-hidden="true"></i> Contactar a un Especialista
                </a>
            </div>
        </div>
    </div>
</section>
