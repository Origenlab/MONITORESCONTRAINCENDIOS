---
import { industriaDestacada, industrias } from '../../data/industrias';

// Industrias con página L3 dedicada
const l3Industrias: Record<string, string> = {
  'petroleo-gas': '/petroleo-gas',
  'petroquimica': '/petroquimica',
  'energia': '/generacion-de-energia',
  'manufactura': '/manufactura',
  'mineria': '/mineria',
};
const industriaUrl = (id?: string) => (id && l3Industrias[id]) ? l3Industrias[id] : `/industrias#${id}`;
---
<section id="industrias" class="industries-section">
    <div class="container">
        <div class="section-header split">
            <div class="section-header__head">
                <span class="section-tag">Sectores que Atendemos</span>
                <h2>Soluciones Especializadas por Industria</h2>
            </div>
            <div class="section-header__body">
                <p>Cada sector enfrenta riesgos distintos: <strong>refinerías, petroquímica, manufactura, aviación, minería y energía</strong>.</p>
                <p>Diseñamos la solución óptima para cada operación, cumpliendo la normativa <strong>NFPA</strong> y los requisitos de <strong>PEMEX</strong> y aseguradoras.</p>
            </div>
        </div>

        <!-- Industria Destacada: Petróleo y Gas -->
        <article class="industry-featured" id={industriaDestacada.id}>
            <div class="industry-featured-image">
                <img src={industriaDestacada.imagen} alt={industriaDestacada.alt} loading="lazy" />
                <div class="industry-image-placeholder">
                    <i class={industriaDestacada.placeholderIcon} aria-hidden="true"></i>
                    <span>{industriaDestacada.placeholderLabel}</span>
                    <small>1200 x 600 px recomendado</small>
                </div>
            </div>
            <div class="industry-featured-content">
                <span class="industry-badge">{industriaDestacada.badge}</span>
                <h3>{industriaDestacada.titulo}</h3>
                <p>{industriaDestacada.descripcion}</p>
                <div class="industry-stats">
                    {industriaDestacada.stats.map((stat) => (
                        <div class="industry-stat">
                            <span class="stat-number">{stat.numero}</span>
                            <span class="stat-text">{stat.texto}</span>
                        </div>
                    ))}
                </div>
                <ul class="industry-features">
                    {industriaDestacada.features.map((feature) => (
                        <li><i class="fas fa-check-circle" aria-hidden="true"></i> {feature}</li>
                    ))}
                </ul>
                <div class="industry-featured-actions">
                    <a href="/#cotizar" class="btn btn-primary btn-lg">
                        <i class="fas fa-file-invoice" aria-hidden="true"></i> Solicitar Cotización
                    </a>
                    <a href="/petroleo-gas" class="btn btn-outline btn-lg">
                        Más Información
                    </a>
                </div>
            </div>
        </article>

        <!-- Grid de Industrias Secundarias -->
        <div class="industries-grid">
            {industrias.map((industria) => (
                <article class="industry-card" id={industria.id}>
                    <div class="industry-card-image">
                        <img src={industria.imagen} alt={industria.alt} loading="lazy" />
                        <div class="industry-image-placeholder">
                            <i class={industria.placeholderIcon} aria-hidden="true"></i>
                            <span>{industria.placeholderLabel}</span>
                        </div>
                        <div class="industry-card-overlay">
                            <span class="overlay-icon"><i class={industria.placeholderIcon} aria-hidden="true"></i></span>
                        </div>
                    </div>
                    <div class="industry-card-content">
                        <h3>{industria.titulo}</h3>
                        <p>{industria.descripcion}</p>
                        <ul class="industry-features">
                            {industria.features.map((feature) => (
                                <li><i class="fas fa-check" aria-hidden="true"></i> {feature}</li>
                            ))}
                        </ul>
                        <a href={industriaUrl(industria.id)} class="btn btn-primary">Más Información</a>
                    </div>
                </article>
            ))}
        </div>

        <div class="industries-cta">
            <a href="/industrias" class="btn btn-secondary btn-lg">
                <i class="fas fa-industry" aria-hidden="true"></i> Ver todas las industrias
            </a>
        </div>
    </div>
</section>
