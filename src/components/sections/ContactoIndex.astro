---
// Sección de contacto con formulario de cotización — paridad 1:1
---
<section id="contacto" class="contact-section">
    <!-- Header de Contacto -->
    <div class="contact-header">
        <div class="container">
            <div class="section-header split">
                <div class="section-header__head">
                    <span class="section-tag section-tag-light">Contacto</span>
                    <h2>Hablemos de su Proyecto</h2>
                </div>
                <div class="section-header__body">
                    <p>
                        Estamos listos para ayudarle a proteger su operación. Contáctenos para una <strong>consulta sin compromiso</strong>.
                    </p>
                    <p>
                        Nuestro equipo de especialistas le responderá en <strong>menos de 24 horas</strong>.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Sección Principal: Formulario + Mapa/Info -->
    <div class="container">
        <div class="contact-main" id="cotizar">
            <!-- Formulario de Cotización -->
            <div class="contact-form-section">
                <div class="form-header">
                    <div class="form-header-icon">
                        <i class="fas fa-file-invoice" aria-hidden="true"></i>
                    </div>
                    <div class="form-header-content">
                        <h3>Solicitar Cotización Gratuita</h3>
                        <p>Complete el formulario y reciba una propuesta personalizada en menos de 24 horas.</p>
                    </div>
                </div>

                <form id="contactForm" class="contact-form" action="#" method="POST">
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="nombre">
                                <i class="fas fa-user" aria-hidden="true"></i>
                                Nombre Completo <span class="required">*</span>
                            </label>
                            <input type="text" id="nombre" name="nombre" placeholder="Ej: Juan Pérez García" required autocomplete="name" />
                        </div>

                        <div class="form-group">
                            <label for="empresa">
                                <i class="fas fa-building" aria-hidden="true"></i>
                                Empresa <span class="required">*</span>
                            </label>
                            <input type="text" id="empresa" name="empresa" placeholder="Ej: Petrolera Nacional S.A." required autocomplete="organization" />
                        </div>

                        <div class="form-group">
                            <label for="email">
                                <i class="fas fa-envelope" aria-hidden="true"></i>
                                Correo Electrónico <span class="required">*</span>
                            </label>
                            <input type="email" id="email" name="email" placeholder="Ej: juan.perez@empresa.com" required autocomplete="email" />
                        </div>

                        <div class="form-group">
                            <label for="telefono">
                                <i class="fas fa-phone" aria-hidden="true"></i>
                                Teléfono <span class="required">*</span>
                            </label>
                            <input type="tel" id="telefono" name="telefono" placeholder="Ej: 55 1234 5678" required autocomplete="tel" />
                        </div>

                        <div class="form-group">
                            <label for="industria">
                                <i class="fas fa-industry" aria-hidden="true"></i>
                                Industria <span class="required">*</span>
                            </label>
                            <select id="industria" name="industria" required>
                                <option value="">Seleccione su industria</option>
                                <option value="petroleo-gas">Petróleo y Gas</option>
                                <option value="petroquimica">Petroquímica / Química</option>
                                <option value="manufactura">Manufactura</option>
                                <option value="parque-industrial">Parque Industrial</option>
                                <option value="bomberos">Bomberos / Gobierno</option>
                                <option value="aviacion">Aviación</option>
                                <option value="mineria">Minería</option>
                                <option value="energia">Generación de Energía</option>
                                <option value="otro">Otro</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="tipo-proyecto">
                                <i class="fas fa-project-diagram" aria-hidden="true"></i>
                                Tipo de Proyecto <span class="required">*</span>
                            </label>
                            <select id="tipo-proyecto" name="tipo-proyecto" required>
                                <option value="">Seleccione el tipo de proyecto</option>
                                <option value="nuevo">Instalación Nueva</option>
                                <option value="reemplazo">Reemplazo de Equipos</option>
                                <option value="expansion">Expansión de Sistema</option>
                                <option value="mantenimiento">Servicio / Mantenimiento</option>
                                <option value="asesoria">Asesoría Técnica</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group form-group-full">
                        <label for="mensaje">
                            <i class="fas fa-comment-alt" aria-hidden="true"></i>
                            Descripción del Proyecto
                        </label>
                        <textarea id="mensaje" name="mensaje" rows="4"
                            placeholder="Describa su proyecto: área a proteger, tipo de riesgo, requisitos específicos, presupuesto estimado, etc."></textarea>
                    </div>

                    <div class="form-group form-group-full">
                        <label class="checkbox-label">
                            <input type="checkbox" name="privacidad" required />
                            <span class="checkbox-custom"></span>
                            <span class="checkbox-text">
                                He leído y acepto el <a href="/aviso-de-privacidad" target="_blank">Aviso de Privacidad</a>
                                <span class="required">*</span>
                            </span>
                        </label>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-paper-plane" aria-hidden="true"></i>
                            Enviar Solicitud
                        </button>
                        <div class="form-guarantee">
                            <i class="fas fa-shield-alt" aria-hidden="true"></i>
                            <span>Información 100% segura. Respuesta garantizada en 24h.</span>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Panel Lateral de Información -->
            <div class="contact-info-panel">
                <!-- Ubicación con Mapa -->
                <div class="info-panel-map">
                    <div class="map-placeholder">
                        <img src="/images/ubicacion-aqueon-monitores-contra-incendios-cdmx-mexico.webp" alt="Ubicación AQUEON CDMX" loading="lazy" />
                        <div class="map-overlay">
                            <i class="fas fa-map-marked-alt" aria-hidden="true"></i>
                            <span>Ver en Google Maps</span>
                        </div>
                    </div>
                </div>

                <!-- Dirección Completa -->
                <div class="info-panel-address">
                    <h4>
                        <i class="fas fa-building" aria-hidden="true"></i>
                        Oficina Central
                    </h4>
                    <address>
                        <strong>AQUEON México</strong><br />
                        Av. Paseo de la Reforma 505<br />
                        Piso 15, Torre Mayor<br />
                        Col. Cuauhtémoc, C.P. 06500<br />
                        Ciudad de México, México
                    </address>
                </div>

                <!-- Horarios -->
                <div class="info-panel-hours">
                    <h4>
                        <i class="fas fa-clock" aria-hidden="true"></i>
                        Horarios de Atención
                    </h4>
                    <ul class="hours-list">
                        <li>
                            <span class="day">Lunes - Viernes</span>
                            <span class="time">8:00 - 18:00</span>
                        </li>
                        <li>
                            <span class="day">Sábado</span>
                            <span class="time">9:00 - 14:00</span>
                        </li>
                        <li>
                            <span class="day">Emergencias</span>
                            <span class="time emergency">24/7</span>
                        </li>
                    </ul>
                </div>

                <!-- Redes Sociales -->
                <div class="info-panel-social">
                    <h4>Síguenos</h4>
                    <div class="social-grid">
                        <a href="#" class="social-link" aria-label="LinkedIn">
                            <i class="fab fa-linkedin-in" aria-hidden="true"></i>
                            <span>LinkedIn</span>
                        </a>
                        <a href="#" class="social-link" aria-label="Facebook">
                            <i class="fab fa-facebook-f" aria-hidden="true"></i>
                            <span>Facebook</span>
                        </a>
                        <a href="#" class="social-link" aria-label="YouTube">
                            <i class="fab fa-youtube" aria-hidden="true"></i>
                            <span>YouTube</span>
                        </a>
                        <a href="#" class="social-link" aria-label="Instagram">
                            <i class="fab fa-instagram" aria-hidden="true"></i>
                            <span>Instagram</span>
                        </a>
                    </div>
                </div>

                <!-- Garantías -->
                <div class="info-panel-trust">
                    <div class="trust-item">
                        <i class="fas fa-check-circle" aria-hidden="true"></i>
                        <span>Cotización sin compromiso</span>
                    </div>
                    <div class="trust-item">
                        <i class="fas fa-check-circle" aria-hidden="true"></i>
                        <span>Respuesta en menos de 24h</span>
                    </div>
                    <div class="trust-item">
                        <i class="fas fa-check-circle" aria-hidden="true"></i>
                        <span>Asesoría técnica gratuita</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
