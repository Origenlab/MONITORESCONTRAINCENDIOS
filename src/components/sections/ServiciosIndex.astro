---
import { servicios, planes } from '../../data/servicios';

// Servicios con página L3 dedicada
const l3Servicios: Record<string, string> = {
  'diseno-ingenieria': '/diseno-ingenieria',
  'instalacion': '/instalacion',
  'mantenimiento-preventivo': '/mantenimiento-preventivo',
  'mantenimiento-correctivo': '/mantenimiento-correctivo',
  'capacitacion': '/capacitacion',
  'consultoria-normativa': '/consultoria-normativa',
};
const servicioUrl = (id: string) => l3Servicios[id] ?? `/servicios#${id}`;
---
<section id="servicios" class="services-section">
    <div class="container">
        <div class="section-header split">
            <div class="section-header__head">
                <span class="section-tag">Servicios Integrales</span>
                <h2>Servicios Contra Incendios de Principio a Fin</h2>
            </div>
            <div class="section-header__body">
                <p>Un monitor bien elegido es apenas el principio. Cubrimos el ciclo completo: <strong>cálculo y diseño, instalación con pruebas, capacitación de la brigada y mantenimiento conforme a NFPA 25</strong>.</p>
                <p>Todo con el mismo equipo de ingeniería, de la primera memoria de cálculo a la última refacción.</p>
            </div>
        </div>

        <div class="services-grid">
            {servicios.map((servicio) => (
                <article class="service-card">
                    <div class="service-card-image">
                        <img src={servicio.imagen} alt={servicio.alt} loading="lazy" />
                        <div class="service-image-placeholder">
                            <i class={servicio.placeholderIcon} aria-hidden="true"></i>
                        </div>
                        <div class="service-number">{servicio.numero}</div>
                    </div>
                    <div class="service-card-content">
                        <h3>{servicio.titulo}</h3>
                        <p>{servicio.descripcion}</p>
                        <ul class="service-features">
                            {servicio.features.map((feature) => (
                                <li><i class="fas fa-check" aria-hidden="true"></i> {feature}</li>
                            ))}
                        </ul>
                        <a href={servicioUrl(servicio.id)} class="btn btn-primary">Más Información</a>
                    </div>
                </article>
            ))}
        </div>

        <div class="industries-cta">
            <a href="/servicios" class="btn btn-secondary btn-lg">
                <i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Ver todos los servicios
            </a>
        </div>

        <!-- Planes de Servicio -->
        <div class="service-plans">
            <h3>Planes de Servicio AQUEON</h3>
            <p class="plans-intro">
                Elija el nivel de servicio que mejor se adapte a las necesidades de su operación.
                Todos nuestros planes incluyen acceso prioritario a nuestro equipo técnico.
            </p>

            <div class="plans-grid">
                {planes.map((plan) => (
                    <div class={`plan-card${plan.featured ? ' featured' : ''}${plan.premium ? ' premium' : ''}`}>
                        {plan.featured && <div class="plan-badge">Recomendado</div>}
                        <div class="plan-header">
                            <h3>{plan.nombre}</h3>
                            <p>{plan.subtitulo}</p>
                        </div>
                        <ul class="plan-features">
                            {plan.features.map((feature) => (
                                <li><i class="fas fa-check" aria-hidden="true"></i> {feature}</li>
                            ))}
                        </ul>
                        <div class="plan-price">
                            <span class="price">{plan.precio}</span>
                            <span class="period">{plan.periodo}</span>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
