---
// CTA final — módulo de llamada a la acción a dos columnas
---
<section class="cta-section">
    <div class="container">
        <div class="cta-grid">
            <!-- Columna 1: mensaje + beneficios -->
            <div class="cta-text">
                <span class="cta-kicker"><i class="fas fa-shield-halved" aria-hidden="true"></i> Protección de clase mundial</span>
                <h2>¿Listo para Proteger su Operación?</h2>
                <p>
                    Solicite una cotización sin compromiso o agende una consulta técnica gratuita con
                    nuestros especialistas. Diseñamos la solución perfecta para su industria.
                </p>
                <ul class="cta-features">
                    <li><i class="fas fa-check" aria-hidden="true"></i> Respuesta en menos de 24 horas</li>
                    <li><i class="fas fa-check" aria-hidden="true"></i> Sin costo ni compromiso</li>
                    <li><i class="fas fa-check" aria-hidden="true"></i> Asesoría técnica incluida</li>
                </ul>
            </div>

            <!-- Columna 2: tarjeta de acción -->
            <div class="cta-action-card">
                <div class="cta-card-head">
                    <div class="cta-card-icon"><i class="fas fa-file-invoice-dollar" aria-hidden="true"></i></div>
                    <div>
                        <h3>Comience hoy mismo</h3>
                        <p>Atención de ingenieros especialistas.</p>
                    </div>
                </div>
                <a href="/#cotizar" class="btn btn-primary btn-lg cta-card-btn">
                    <i class="fas fa-file-invoice" aria-hidden="true"></i> Solicitar Cotización Gratuita
                </a>
                <a href="tel:+525512345678" class="btn btn-outline-light btn-lg cta-card-btn">
                    <i class="fas fa-phone" aria-hidden="true"></i> +52 55 1234 5678
                </a>
                <span class="cta-card-note"><i class="fas fa-lock" aria-hidden="true"></i> Información 100% segura · Respuesta garantizada en 24 h</span>
            </div>
        </div>
    </div>
</section>
