---
const year = 2024;
---
<footer class="footer">
    <div class="footer-main">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <a href="/" class="footer-logo">
                        <div class="logo-icon">
                            <svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <circle cx="25" cy="25" r="23" stroke="currentColor" stroke-width="2"/>
                                <path d="M25 10 L25 40 M15 25 L35 25 M18 15 L32 35 M32 15 L18 35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                <circle cx="25" cy="25" r="8" fill="currentColor"/>
                            </svg>
                        </div>
                        <span>AQUEON</span>
                    </a>
                    <p>
                        Protección industrial de clase mundial. Monitores contra incendios y sistemas de extinción
                        para industrias de alto riesgo en México. Más de 15 años protegiendo lo que más importa.
                    </p>
                    <div class="footer-social">
                        <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                        <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                        <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>

                <div class="footer-links">
                    <h4>Productos</h4>
                    <ul>
                        <li><a href="/productos">Ver todo el catálogo</a></li>
                        <li><a href="/monitores-fijos">Monitores Fijos</a></li>
                        <li><a href="/monitores-portatiles">Monitores Portátiles</a></li>
                        <li><a href="/monitores-automaticos">Monitores Automáticos</a></li>
                        <li><a href="/boquillas">Boquillas y Accesorios</a></li>
                    </ul>
                </div>

                <div class="footer-links">
                    <h4>Industrias</h4>
                    <ul>
                        <li><a href="/petroleo-gas">Petróleo y Gas</a></li>
                        <li><a href="/petroquimica">Petroquímica</a></li>
                        <li><a href="/generacion-de-energia">Generación de Energía</a></li>
                        <li><a href="/manufactura">Manufactura</a></li>
                        <li><a href="/mineria">Minería</a></li>
                        <li><a href="/bomberos">Bomberos y Gobierno</a></li>
                        <li><a href="/aviacion">Aviación</a></li>
                    </ul>
                </div>

                <div class="footer-links">
                    <h4>Empresa</h4>
                    <ul>
                        <li><a href="/nosotros">Nosotros</a></li>
                        <li><a href="/servicios">Servicios</a></li>
                        <li><a href="/contacto">Contacto</a></li>
                        <li><a href="/blog">Blog</a></li>
                        <li><a href="/recursos">Recursos Técnicos</a></li>
                    </ul>
                </div>

                <div class="footer-contact">
                    <h4>Contacto</h4>
                    <ul>
                        <li>
                            <i class="fas fa-phone" aria-hidden="true"></i>
                            <a href="tel:+525512345678">+52 55 1234 5678</a>
                        </li>
                        <li>
                            <i class="fas fa-envelope" aria-hidden="true"></i>
                            <a href="mailto:contacto@aqueon.com.mx">contacto@aqueon.com.mx</a>
                        </li>
                        <li>
                            <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
                            <span>CDMX, México</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container">
            <div class="footer-bottom-content">
                <p>&copy; {year} AQUEON México. Todos los derechos reservados.</p>
                <div class="footer-legal">
                    <a href="/aviso-de-privacidad">Aviso de Privacidad</a>
                    <a href="/terminos-y-condiciones">Términos y Condiciones</a>
                </div>
            </div>
        </div>
    </div>
</footer>
