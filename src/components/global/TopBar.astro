---
// Barra superior de contacto (header-top del diseño original)
---
<div class="header-top">
    <div class="container">
        <div class="header-top-content">
            <div class="contact-info">
                <a href="tel:+525512345678" class="contact-item">
                    <i class="fas fa-phone" aria-hidden="true"></i>
                    <span>+52 55 1234 5678</span>
                </a>
                <a href="mailto:contacto@aqueon.com.mx" class="contact-item">
                    <i class="fas fa-envelope" aria-hidden="true"></i>
                    <span>contacto@aqueon.com.mx</span>
                </a>
                <span class="contact-item">
                    <i class="fas fa-clock" aria-hidden="true"></i>
                    <span>Lun - Vie: 8:00 - 18:00</span>
                </span>
            </div>
            <div class="social-links">
                <a href="#" aria-label="Síguenos en LinkedIn" title="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
                <a href="#" aria-label="Síguenos en Facebook" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                <a href="#" aria-label="Nuestro canal de YouTube" title="YouTube"><i class="fab fa-youtube"></i></a>
            </div>
        </div>
    </div>
</div>
