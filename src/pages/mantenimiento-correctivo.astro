---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: '24/7', label: 'Servicio de emergencia' },
  { numero: '< 24 h', label: 'Respuesta a la falla' },
  { numero: 'OEM', label: 'Refacciones 100% originales' },
  { numero: 'NFPA 25', label: 'Verificación posterior a la reparación' },
];

const beneficios = [
  'Atención de emergencias las 24 horas, los 365 días',
  'Diagnóstico especializado de la causa raíz de la falla',
  'Refacciones originales de fábrica, sin genéricos',
  'Verificación funcional tras la reparación (NFPA 25)',
  'Reporte de servicio y garantía de la reparación',
  'Recomendación para evitar que la falla se repita',
];

// DIFERENCIADOR 1 — Flujo de respuesta de emergencia (pg-chain)
const fases = [
  {
    id: 'reporte',
    eslabon: 'Paso 01',
    titulo: 'Recepción del Reporte',
    icon: 'fas fa-headset',
    descripcion: 'Recibimos el reporte de falla las 24 horas, clasificamos su criticidad y activamos al técnico según el nivel de servicio.',
    incluye: ['Atención 24/7', 'Clasificación de criticidad', 'Activación de técnico', 'Confirmación de tiempo'],
    entrega: 'Ticket de servicio',
  },
  {
    id: 'diagnostico',
    eslabon: 'Paso 02',
    titulo: 'Diagnóstico en Sitio',
    icon: 'fas fa-magnifying-glass',
    descripcion: 'Identificamos la causa raíz de la falla —no solo el síntoma— para reparar de fondo y evitar que se repita.',
    incluye: ['Inspección de la falla', 'Causa raíz', 'Alcance de reparación', 'Refacciones requeridas'],
    entrega: 'Diagnóstico de falla',
  },
  {
    id: 'reparacion',
    eslabon: 'Paso 03',
    titulo: 'Reparación con OEM',
    icon: 'fas fa-wrench',
    descripcion: 'Reparamos o sustituimos con refacciones originales de fábrica para mantener la certificación y el desempeño del equipo.',
    incluye: ['Refacciones OEM', 'Reparación o cambio', 'Ajuste y calibración', 'Minimizar el paro'],
    entrega: 'Equipo reparado',
  },
  {
    id: 'verificacion',
    eslabon: 'Paso 04',
    titulo: 'Verificación y Reanudación',
    icon: 'fas fa-circle-check',
    descripcion: 'Probamos el equipo conforme a NFPA 25, confirmamos su operación y entregamos el reporte con la garantía de la reparación.',
    incluye: ['Prueba funcional', 'Verificación de desempeño', 'Reporte de servicio', 'Garantía de reparación'],
    entrega: 'Sistema operativo',
  },
];

// DIFERENCIADOR 2 — Matriz de diagnóstico (pg-scen)
const diagnostico = [
  {
    icon: 'fas fa-droplet',
    nombre: 'Fuga en el monitor o juntas',
    descripcion: 'Goteo o pérdida de presión en conexiones, empaques o sellos.',
    causa: 'Empaque desgastado, par de apriete o corrosión.',
    accion: 'Cambio de sello / empaque OEM y reapriete',
  },
  {
    icon: 'fas fa-lock',
    nombre: 'Monitor agarrotado',
    descripcion: 'Resistencia o bloqueo en el giro o la elevación del monitor.',
    causa: 'Falta de lubricación, corrosión o suciedad interna.',
    accion: 'Limpieza, lubricación y ajuste de mecanismo',
  },
  {
    icon: 'fas fa-gauge-simple-high',
    nombre: 'Baja presión o caudal',
    descripcion: 'El sistema no entrega el desempeño esperado en la descarga.',
    causa: 'Obstrucción, válvula parcial o falla de bomba.',
    accion: 'Diagnóstico hidráulico y corrección del origen',
  },
  {
    icon: 'fas fa-pump-medical',
    nombre: 'La bomba no arranca',
    descripcion: 'La bomba contra incendio no responde en la prueba o demanda.',
    causa: 'Tablero, batería, controlador o falla mecánica.',
    accion: 'Diagnóstico del controlador y de la bomba',
  },
  {
    icon: 'fas fa-tower-broadcast',
    nombre: 'Control remoto sin respuesta',
    descripcion: 'El monitor remoto no obedece el joystick o el tablero.',
    causa: 'Cableado, actuador o tarjeta de control.',
    accion: 'Diagnóstico eléctrico y de control',
  },
  {
    icon: 'fas fa-faucet',
    nombre: 'Válvula con fuga o trabada',
    descripcion: 'Válvula de control que no sella o no opera correctamente.',
    causa: 'Asiento dañado, vástago o accionamiento.',
    accion: 'Reparación o reemplazo de la válvula',
  },
];

// DIFERENCIADOR 3 — Qué incluye (pg-sol)
const incluye = [
  {
    icon: 'fas fa-stethoscope',
    titulo: 'Diagnóstico de falla',
    texto: 'Identificación de la causa raíz, no solo del síntoma, para una reparación de fondo.',
    producto: 'Reportar una falla',
    url: '/contacto',
  },
  {
    icon: 'fas fa-file-lines',
    titulo: 'Reporte de servicio',
    texto: 'Documento con el diagnóstico, la reparación ejecutada y las refacciones utilizadas.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-box-open',
    titulo: 'Refacciones originales (OEM)',
    texto: 'Partes originales de fábrica para mantener la certificación y el desempeño del equipo.',
    producto: 'Ver catálogo de equipo',
    url: '/productos',
  },
  {
    icon: 'fas fa-shield-halved',
    titulo: 'Garantía de la reparación',
    texto: 'Respaldo por escrito de la reparación realizada y de las partes sustituidas.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-clipboard-check',
    titulo: 'Recomendación preventiva',
    texto: 'Acciones para evitar que la falla se repita, integrables a su programa NFPA 25.',
    producto: 'Ver mantenimiento preventivo',
    url: '/mantenimiento-preventivo',
  },
  {
    icon: 'fas fa-headset',
    titulo: 'Soporte 24/7',
    texto: 'Línea de emergencia disponible todo el año para fallas que no pueden esperar.',
    producto: 'Contactar a AQUEON',
    url: '/contacto',
  },
];

// pg-dens — Niveles de respuesta (SLA)
const sla = [
  ['AQUEON Basic', 'Soporte en horario de oficina', 'Atención según disponibilidad'],
  ['AQUEON Plus', 'Respuesta prioritaria en 24 horas', 'Cobertura ampliada'],
  ['AQUEON Premium', 'Emergencia 24/7 (4 h de respuesta)', 'Técnico dedicado y refacciones en consignación'],
];

const normativas = [
  { n: 'NFPA 25', d: 'Verificación funcional posterior a la reparación' },
  { n: 'NFPA 20', d: 'Bombas contra incendio' },
  { n: 'Refacciones OEM', d: 'Partes originales del fabricante' },
  { n: 'Soporte 24/7', d: 'Atención de emergencia todo el año' },
  { n: 'NOM-002-STPS', d: 'Condiciones de seguridad en el servicio' },
];

const errores = [
  'Reparar el síntoma sin atender la causa raíz de la falla',
  'Usar refacciones genéricas en equipo certificado',
  'No verificar el equipo conforme a NFPA 25 tras reparar',
  'Carecer de una línea de emergencia para fallas críticas',
  'No documentar la reparación ni las partes sustituidas',
  'Ignorar la recomendación para evitar la recurrencia',
];

const recomendaciones = [
  'Atienda la causa raíz, no solo el síntoma visible',
  'Exija refacciones originales de fábrica (OEM)',
  'Verifique el equipo conforme a NFPA 25 tras la reparación',
  'Defina un nivel de servicio con tiempo de respuesta claro',
  'Documente cada reparación y mantenga la trazabilidad',
  'Integre la recomendación preventiva a su programa NFPA 25',
];

const faqs = [
  { q: '¿Qué tan rápido responden a una emergencia?', a: 'Depende del nivel de servicio contratado. Atendemos reportes las 24 horas y, en el nivel Premium, ofrecemos respuesta de emergencia con técnico en sitio en 4 horas; en el nivel Plus, respuesta prioritaria en 24 horas. Para cualquier cliente, respondemos el reporte de inmediato, clasificamos la criticidad y activamos la atención correspondiente. Mantenemos cobertura en los 32 estados de la República.' },
  { q: '¿Por qué insisten en refacciones originales (OEM)?', a: 'En equipo certificado FM Approved / UL Listed, una refacción genérica puede comprometer el desempeño hidráulico y, peor aún, invalidar la certificación del equipo. Como distribuidores autorizados de Elkhart Brass, Akron Brass y Task Force Tips, usamos exclusivamente refacciones originales de fábrica, garantizando que el equipo reparado conserve su desempeño y su respaldo.' },
  { q: '¿Diagnostican la causa raíz o solo reparan el síntoma?', a: 'Diagnosticamos la causa raíz. Reparar solo el síntoma —cambiar un sello sin entender por qué falló, por ejemplo— casi garantiza que la falla regrese. Nuestro técnico identifica el origen real (corrosión, falta de lubricación, una válvula parcial, un problema de bomba) para reparar de fondo y dejar una recomendación que evite la recurrencia.' },
  { q: '¿Verifican el equipo después de repararlo?', a: 'Sí. Tras la reparación probamos el equipo conforme a NFPA 25 —operación en todo su rango, presión y caudal, y en remotos el control— para confirmar que quedó operativo, no solo "arreglado". Entregamos un reporte de servicio con el diagnóstico, la reparación, las refacciones y la verificación, además de la garantía de la reparación.' },
  { q: '¿El correctivo reemplaza al mantenimiento preventivo?', a: 'No: lo complementa. El mantenimiento preventivo (NFPA 25) busca evitar las fallas detectándolas a tiempo; el correctivo atiende la falla cuando ocurre. Lo ideal es tener un programa preventivo sólido y un correctivo de respaldo para lo imprevisto. De hecho, cada correctivo nos deja una recomendación que integramos a su programa preventivo para reducir futuras fallas.' },
  { q: '¿Atienden equipo de cualquier marca?', a: 'Sí. Aunque somos especialistas en las marcas que distribuimos, nuestro servicio correctivo atiende monitores, válvulas, bombas y red de otras marcas. Diagnosticamos y reparamos su sistema completo, con un solo responsable y refacciones originales cuando aplica.' },
];
---
<Base
  title="Mantenimiento Correctivo Incendios 24/7 | AQUEON"
  description="Mantenimiento correctivo contra incendios con emergencia 24/7: diagnóstico de causa raíz, refacciones OEM y verificación NFPA 25, con garantía. AQUEON."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/servicios">Servicios</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Mantenimiento Correctivo</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Servicios · Mantenimiento Correctivo</span>
          <h1>Mantenimiento Correctivo de Sistemas Contra Incendio</h1>
        </div>
        <div class="section-header__body">
          <p>Cuando algo falla, el reloj corre. <strong>Respuesta de emergencia 24/7</strong> con diagnóstico de causa raíz.</p>
          <p>Reparación con <strong>refacciones originales</strong> y verificación conforme a NFPA 25, documentada y con garantía.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El servicio</span>
          <h2>Una Falla no Avisa: la Respuesta sí Importa</h2>
          <p>
            Por bien diseñado y mantenido que esté un sistema, los imprevistos ocurren: una válvula que se traba, una bomba
            que no arranca, una fuga que aparece. En protección contra incendios, un equipo fuera de servicio es un riesgo
            que no se puede dejar esperar. Lo que marca la diferencia es la <strong>velocidad de respuesta</strong> y, sobre
            todo, que la reparación sea <strong>de fondo</strong> y no un parche que volverá a fallar.
          </p>
          <p>
            El mantenimiento correctivo de AQUEON combina <strong>atención 24/7</strong>, diagnóstico de
            <strong>causa raíz</strong> y reparación con <strong>refacciones originales de fábrica</strong>, seguida de una
            verificación conforme a NFPA 25 que confirma que el equipo quedó operativo. Entregamos reporte de servicio,
            garantía de la reparación y una recomendación para que la falla no se repita.
          </p>
          <p>
            En esta página verá el flujo de respuesta de emergencia, la matriz de diagnóstico de fallas comunes, lo que
            incluye el servicio y los niveles de respuesta disponibles.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Flujo de respuesta -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Metodología</span>
          <h2>Flujo de Respuesta de Emergencia</h2>
        </div>
        <div class="section-header__body">
          <p>Del <strong>reporte</strong> a la <strong>reanudación</strong>, un proceso claro contra el reloj.</p>
          <p>Cada paso con su entregable, para que la reparación sea trazable.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {fases.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-list-ul" aria-hidden="true"></i> Incluye</span>
            <div class="l3-chips">
              {c.incluye.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-box-open" aria-hidden="true"></i> Entregable</span>
            <div class="l3-chips">
              <span class="l3-chip l3-chip--norm">{c.entrega}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Matriz de diagnóstico -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Diagnóstico</span>
          <h2>Matriz de Fallas Comunes</h2>
        </div>
        <div class="section-header__body">
          <p>Del síntoma a la <strong>causa raíz</strong> y a la acción: así diagnosticamos.</p>
          <p>Una guía de las fallas más frecuentes y cómo las resolvemos.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Síntoma</th>
              <th scope="col">Qué se observa</th>
              <th scope="col">Causa probable</th>
              <th scope="col">Acción AQUEON</th>
            </tr>
          </thead>
          <tbody>
            {diagnostico.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td>{e.causa}</td>
                <td class="pg-scen-sol">{e.accion}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> El diagnóstico definitivo se realiza en sitio; esta matriz orienta las fallas más frecuentes en monitores y su red.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Qué incluye -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Alcance</span>
          <h2>Qué Incluye el Servicio</h2>
        </div>
        <div class="section-header__body">
          <p>Más que reparar: <strong>diagnosticar, documentar y prevenir</strong> la recurrencia.</p>
          <p>Cada elemento enlaza con el servicio o equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {incluye.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- pg-dens: Niveles de respuesta -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Niveles de servicio</span>
          <h2>Tiempos de Respuesta por Nivel</h2>
          <p>
            La rapidez con la que atendemos una emergencia depende del <strong>nivel de servicio</strong> contratado. Para
            instalaciones críticas, el nivel Premium ofrece atención 24/7 con técnico en sitio en 4 horas y refacciones en
            consignación. Defina el nivel según la criticidad de su operación.
          </p>
          <a href="/servicios#planes" class="btn btn-outline"><i class="fas fa-layer-group" aria-hidden="true"></i> Ver planes de servicio</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Nivel</th><th scope="col">Tiempo de respuesta</th><th scope="col">Cobertura</th></tr>
            </thead>
            <tbody>
              {sla.map(([n, t, c]) => (
                <tr><th scope="row">{n}</th><td class="pg-dens-ok">{t}</td><td>{c}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Cuando Falla, Estamos del Otro Lado del Teléfono</h2>
          <p>
            En <strong>AQUEON</strong> entendemos que una falla en un sistema contra incendio no admite esperas. Atendemos
            emergencias <strong>24/7</strong>, diagnosticamos la causa raíz y reparamos con <strong>refacciones originales</strong>,
            verificando el equipo conforme a NFPA 25 antes de reanudar. Y como somos un solo proveedor de diseño, equipo,
            instalación y mantenimiento, conocemos su sistema y respondemos sin zonas grises.
          </p>
          <p>
            Damos servicio correctivo a <strong>refinerías, plantas, parques industriales, aeropuertos, minería y gobierno</strong>,
            con reporte y garantía de cada reparación y cobertura en los 32 estados de la República desde la Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/mantenimiento-preventivo" class="btn btn-outline-light"><i class="fas fa-clipboard-check" aria-hidden="true"></i> Mantenimiento preventivo</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Todos los servicios</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Normas de referencia</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Mantenimiento Correctivo" contexto="el servicio de mantenimiento correctivo y emergencias 24/7" faqs={faqs} />

  <!-- Otros servicios -->
  <section class="l3-otras">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Ciclo Completo</span>
          <h2>Otros Servicios AQUEON</h2>
        </div>
        <div class="section-header__body">
          <p>Del diseño al mantenimiento, cubrimos <strong>todo el ciclo de vida</strong> de su sistema.</p>
          <p>Un solo proveedor con ingeniería, obra y soporte de por vida.</p>
        </div>
      </div>
      <div class="l3-otras-grid">
        <a href="/mantenimiento-preventivo" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-clipboard-check" aria-hidden="true"></i></span><span class="l3-otra-name">Mantenimiento Preventivo</span><span class="l3-otra-sub">NFPA 25 · disponibilidad</span></a>
        <a href="/instalacion" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i></span><span class="l3-otra-name">Instalación Profesional</span><span class="l3-otra-sub">Montaje certificado · pruebas</span></a>
        <a href="/consultoria-normativa" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-file-contract" aria-hidden="true"></i></span><span class="l3-otra-name">Consultoría Normativa</span><span class="l3-otra-sub">Auditorías · aseguradoras</span></a>
