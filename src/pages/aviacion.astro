---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: 'NFPA 403·409', label: 'ARFF y hangares de aeronaves' },
  { numero: 'ICAO · FAA', label: 'Estándares internacionales' },
  { numero: 'DGAC', label: 'Cumplimiento en México' },
  { numero: 'Jet A', label: 'Combustible de alto riesgo' },
];

const beneficios = [
  'Sistemas de espuma para hangares conforme a NFPA 409',
  'Cobertura de plataforma y áreas de operación (ARFF)',
  'Protección de granjas de combustible y reabastecimiento',
  'Espuma AFFF para incendios de combustible de aviación',
  'Cumplimiento de ICAO Anexo 14, FAA y DGAC',
  'Documentación técnica para auditoría aeroportuaria',
];

// DIFERENCIADOR 1 — Áreas aeroportuarias (pg-chain)
const areas = [
  {
    id: 'plataforma',
    eslabon: 'Operación',
    titulo: 'Plataforma y Pista (ARFF)',
    icon: 'fas fa-plane-departure',
    descripcion: 'Áreas de operación de aeronaves donde un incidente con combustible exige respuesta inmediata de alto caudal.',
    activos: ['Plataforma de operación', 'Calles de rodaje', 'Posiciones de contacto', 'Estación ARFF'],
    riesgos: ['Incendio de combustible Jet A', 'Tiempo de respuesta crítico'],
  },
  {
    id: 'hangares',
    eslabon: 'Mantenimiento',
    titulo: 'Hangares de Aeronaves',
    icon: 'fas fa-warehouse',
    descripcion: 'Grandes naves con aeronaves de altísimo valor y combustible a bordo, protegidas con sistemas de espuma conforme a NFPA 409.',
    activos: ['Hangares de servicio', 'Aeronaves estacionadas', 'Áreas de pintura', 'Talleres anexos'],
    riesgos: ['Derrame bajo aeronave', 'Propagación rápida'],
  },
  {
    id: 'combustible',
    eslabon: 'Suministro',
    titulo: 'Granja de Combustible',
    icon: 'fas fa-gas-pump',
    descripcion: 'Tanques de almacenamiento y sistemas de hidrantes de combustible de aviación con gran inventario de Jet A.',
    activos: ['Tanques de Jet A', 'Sistema de hidrantes', 'Islas de carga', 'Bombeo'],
    riesgos: ['Incendio de tanque', 'Incendio de derrame'],
  },
  {
    id: 'mro',
    eslabon: 'MRO',
    titulo: 'Talleres MRO',
    icon: 'fas fa-screwdriver-wrench',
    descripcion: 'Mantenimiento, reparación y overhaul con solventes, pintura y procesos que suman riesgo de líquidos inflamables.',
    activos: ['Talleres de motores', 'Cabinas de pintura', 'Almacén de solventes', 'Bancos de prueba'],
    riesgos: ['Líquidos inflamables', 'Vapores de solvente'],
  },
];

// DIFERENCIADOR 2 — Escenarios (pg-scen)
const escenarios = [
  {
    icon: 'fas fa-fire',
    nombre: 'Incendio en plataforma',
    descripcion: 'Derrame de combustible Jet A encendido bajo o junto a una aeronave en operación.',
    estrategia: 'Aplicación masiva de espuma de alto caudal y enfriamiento, con respuesta ARFF inmediata (NFPA 403).',
    solucion: 'Monitor de alto caudal + espuma AFFF',
  },
  {
    icon: 'fas fa-warehouse',
    nombre: 'Incendio en hangar',
    descripcion: 'Fuego bajo una aeronave estacionada con combustible a bordo en espacio cerrado.',
    estrategia: 'Sistemas fijos de espuma (baja o alta expansión) según el grupo de hangar (NFPA 409).',
    solucion: 'Sistema de espuma + monitores de apoyo',
  },
  {
    icon: 'fas fa-gas-pump',
    nombre: 'Reabastecimiento / rampa',
    descripcion: 'Operación de carga de combustible con riesgo de derrame en la rampa.',
    estrategia: 'Drenaje controlado, espuma y enfriamiento de exposiciones (NFPA 415 / 11).',
    solucion: 'Monitor + cámara de espuma',
  },
  {
    icon: 'fas fa-oil-well',
    nombre: 'Granja de combustible',
    descripcion: 'Incendio de tanque o de derrame en el almacenamiento de Jet A.',
    estrategia: 'Espuma sobre la superficie y enfriamiento de tanques expuestos (NFPA 11 / 30).',
    solucion: 'Monitor Magnum MG-4000 + espuma',
  },
  {
    icon: 'fas fa-spray-can-sparkles',
    nombre: 'Taller MRO / pintura',
    descripcion: 'Solventes y pintura en procesos de mantenimiento y acabado.',
    estrategia: 'Espuma y enfriamiento en cabinas y almacenes conforme a NFPA 30.',
    solucion: 'Boquillas + cámara de espuma',
  },
];

// DIFERENCIADOR 3 — Soluciones por área (pg-sol, interlink)
const soluciones = [
  {
    icon: 'fas fa-plane-departure',
    titulo: 'Plataforma y áreas de operación',
    texto: 'Monitores de alto caudal con espuma para respuesta inmediata a incendios de combustible de aviación.',
    producto: 'Monitor Magnum MG-4000',
    url: '/monitores-fijos#mg-4000',
  },
  {
    icon: 'fas fa-warehouse',
    titulo: 'Hangares de aeronaves',
    texto: 'Monitores de apoyo a los sistemas fijos de espuma conforme al grupo de hangar (NFPA 409).',
    producto: 'Monitores Fijos Industriales',
    url: '/monitores-fijos',
  },
  {
    icon: 'fas fa-spray-can-sparkles',
    titulo: 'Espuma y combustible',
    texto: 'Cámaras de espuma y boquillas para granjas de combustible, rampas y talleres con líquidos inflamables.',
    producto: 'Boquillas y Cámaras de Espuma',
    url: '/boquillas',
  },
  {
    icon: 'fas fa-robot',
    titulo: 'Detección y respuesta autónoma',
    texto: 'Monitores automáticos con detección para hangares y áreas críticas sin presencia permanente.',
    producto: 'Monitores Automáticos',
    url: '/monitores-automaticos',
  },
  {
    icon: 'fas fa-truck-droplet',
    titulo: 'Respuesta de brigada',
    texto: 'Equipos portátiles de despliegue rápido para complementar la respuesta ARFF y el mantenimiento.',
    producto: 'Monitores Portátiles',
    url: '/monitores-portatiles',
  },
  {
    icon: 'fas fa-compass-drafting',
    titulo: 'Diseño NFPA 403 / 409',
    texto: 'Ingeniería del sistema y documentación para cumplimiento ICAO, FAA y DGAC.',
    producto: 'Servicios de ingeniería',
    url: '/servicios#diseno-ingenieria',
  },
];

// EXTRA — Grupos de hangar NFPA 409 (pg-dens)
const hangares = [
  ['Grupo I', 'Hangares de gran altura de puerta y mayor superficie', 'Espuma de baja o alta expansión'],
  ['Grupo II', 'Hangares de superficie y altura intermedias', 'Espuma según área de fuego'],
  ['Grupo III', 'Hangares menores / mantenimiento ligero', 'Protección según evaluación de riesgo'],
  ['Grupo IV', 'Hangares con membrana tensada (estructura textil)', 'Criterio específico de estructura'],
];

const normativas = [
  { n: 'NFPA 403', d: 'Servicios ARFF en aeropuertos' },
  { n: 'NFPA 409', d: 'Hangares de aeronaves' },
  { n: 'NFPA 415', d: 'Drenaje y rampas de reabastecimiento' },
  { n: 'NFPA 11', d: 'Sistemas de espuma para combustible' },
  { n: 'NFPA 30', d: 'Líquidos inflamables y combustibles' },
  { n: 'ICAO Anexo 14', d: 'Diseño y operación de aeródromos' },
  { n: 'FAA', d: 'Estándares de aviación (EE. UU.)' },
  { n: 'DGAC', d: 'Autoridad aeronáutica de México' },
];

const errores = [
  'Proteger un hangar sin clasificar su grupo conforme a NFPA 409',
  'Subdimensionar el caudal y la reserva de espuma para Jet A',
  'Ignorar el drenaje controlado en rampas de reabastecimiento',
  'Tratar la granja de combustible como almacenamiento ordinario',
  'No contemplar el tiempo de respuesta ARFF en el diseño',
  'Usar concentrado de espuma inadecuado para combustible de aviación',
];

const recomendaciones = [
  'Clasifique el hangar (Grupo I–IV) antes de definir el sistema',
  'Dimensione espuma y reserva según el escenario de Jet A',
  'Integre drenaje y contención en rampas y reabastecimiento',
  'Combine sistemas fijos de espuma con monitores de apoyo',
  'Diseñe conforme a NFPA 403/409 e ICAO, FAA y DGAC',
  'Considere detección y respuesta autónoma en áreas sin personal',
];

const faqs = [
  { q: '¿Qué es ARFF y qué normativa lo rige?', a: 'ARFF (Aircraft Rescue and Fire Fighting) es el servicio de rescate y extinción de incendios de aeronaves en aeropuertos. Su diseño se rige por NFPA 403 y por el Anexo 14 de la ICAO, que define la categoría del aeródromo según la longitud de las aeronaves y, con ella, las cantidades mínimas de agente extintor y los tiempos de respuesta. En México se complementa con los requisitos de la DGAC. AQUEON especifica equipo de alto caudal y espuma para respaldar estas operaciones.' },
  { q: '¿Cómo se protege un hangar de aeronaves?', a: 'Los hangares se protegen con sistemas fijos de espuma diseñados conforme a NFPA 409, que clasifica los hangares en grupos (I a IV) según su tamaño, altura de puerta y tipo de estructura. Según el grupo se define el sistema: espuma de baja expansión a nivel de piso, espuma de alta expansión que inunda el volumen, o monitores fijos, según la evaluación de riesgo. Los monitores AQUEON complementan estos sistemas para cobertura dirigida.' },
  { q: '¿Por qué el combustible de aviación (Jet A) es un riesgo especial?', a: 'El Jet A es un combustible de hidrocarburo que, en un derrame encendido, propaga el fuego con gran rapidez y libera enorme energía, además de estar presente en grandes volúmenes tanto en las aeronaves como en la granja de combustible. Se combate con espuma —típicamente AFFF— que sella la superficie del combustible, junto con enfriamiento de las exposiciones. El dimensionamiento del caudal y la reserva de concentrado es crítico.' },
  { q: '¿Qué es la categoría de aeródromo de la ICAO?', a: 'Es una clasificación del 1 al 10 que la ICAO asigna al aeropuerto según la longitud y el ancho del fuselaje de las aeronaves que opera. La categoría determina las cantidades mínimas de agua para producción de espuma, el agente complementario y el número de vehículos ARFF requeridos. Es la base para dimensionar la capacidad de respuesta del aeropuerto.' },
  { q: '¿Atienden granjas de combustible y sistemas de hidrantes?', a: 'Sí. El almacenamiento de Jet A y los sistemas de hidrantes de combustible se protegen como un riesgo de hidrocarburo bajo NFPA 11 y NFPA 30: espuma sobre la superficie del combustible y enfriamiento de tanques y equipos expuestos. Integramos monitores de alto caudal, cámaras de espuma y proporcionadores como parte del sistema.' },
  { q: '¿Trabajan con aeropuertos, hangares privados y talleres MRO?', a: 'Sí. Atendemos aeropuertos comerciales y ejecutivos, hangares de aerolíneas y de aviación privada, y talleres MRO de mantenimiento, reparación y overhaul, con equipos FM Approved y UL Listed y documentación para auditorías de la autoridad aeronáutica y aseguradoras.' },
  { q: '¿AQUEON diseña, instala y certifica el sistema?', a: 'Sí. Partimos de la categoría del aeródromo o del grupo de hangar y del escenario de incendio, diseñamos conforme a NFPA 403/409/415 e ICAO, calculamos caudales y reservas de espuma, y entregamos planos y memoria de cálculo. Instalamos con técnicos certificados, probamos, ponemos en marcha, capacitamos y damos mantenimiento NFPA 25, con cobertura nacional.' },
];
---
<Base
  title="Protección Contra Incendios para Aviación | ARFF, Hangares NFPA 409 y Combustible | AQUEON México"
  description="Soluciones de monitores contra incendios para aviación en México: plataformas y ARFF, hangares de aeronaves (NFPA 409), granjas de combustible y talleres MRO. Espuma AFFF para Jet A conforme a NFPA 403, ICAO, FAA y DGAC. Ingeniería e instalación con AQUEON."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/industrias">Industrias</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Aviación</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Industrias · Aviación</span>
          <h1>Protección Contra Incendios para Aviación</h1>
        </div>
        <div class="section-header__body">
          <p>El sector donde la <strong>respuesta inmediata</strong> salva vidas: plataformas, hangares y granjas de combustible.</p>
          <p>Sistemas de espuma para <strong>Jet A</strong> conforme a <strong>NFPA 403/409</strong>, ICAO, FAA y DGAC.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El reto del sector</span>
          <h2>Donde Cada Segundo Cuenta</h2>
          <p>
            La <strong>aviación</strong> reúne enormes volúmenes de combustible <strong>Jet A</strong>, aeronaves de
            altísimo valor y, sobre todo, vidas humanas, en un entorno donde un incidente con combustible puede crecer en
            segundos. La protección contra incendios no es un complemento: es parte de la licencia para operar de cualquier
            aeropuerto u hangar.
          </p>
          <p>
            Cada área plantea su propio reto: la <strong>plataforma</strong> exige respuesta ARFF inmediata de alto caudal;
            los <strong>hangares</strong> se protegen con sistemas de espuma diseñados por grupo conforme a NFPA 409; la
            <strong>granja de combustible</strong> es un riesgo de hidrocarburo de gran inventario; y los talleres
            <strong>MRO</strong> suman solventes y pintura. Todo bajo el marco de NFPA, ICAO, FAA y DGAC.
          </p>
          <p>
            En esta página verá la protección por área aeroportuaria, los escenarios de incendio y su estrategia, las
            soluciones AQUEON y la clasificación de hangares que rige el diseño.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Áreas aeroportuarias -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Mapa de riesgo</span>
          <h2>Protección por Área Aeroportuaria</h2>
        </div>
        <div class="section-header__body">
          <p>De la plataforma al taller MRO, cada área del aeropuerto plantea un <strong>reto distinto</strong>.</p>
          <p>Identificarlo define la <strong>estrategia de protección</strong> correcta.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {areas.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-cubes" aria-hidden="true"></i> Activos típicos</span>
            <div class="l3-chips">
              {c.activos.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-fire" aria-hidden="true"></i> Riesgos principales</span>
            <div class="l3-chips">
              {c.riesgos.map((r) => <span class="l3-chip l3-chip--norm">{r}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Escenarios -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Estrategia de respuesta</span>
          <h2>Escenarios de Incendio y Cómo se Combaten</h2>
        </div>
        <div class="section-header__body">
          <p>De la plataforma a la granja de combustible, cada escenario exige una <strong>estrategia propia</strong>.</p>
          <p>Esta matriz resume el enfoque de ingeniería que aplicamos a cada uno.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Escenario</th>
              <th scope="col">Descripción</th>
              <th scope="col">Estrategia</th>
              <th scope="col">Solución AQUEON</th>
            </tr>
          </thead>
          <tbody>
            {escenarios.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td>{e.estrategia}</td>
                <td class="pg-scen-sol">{e.solucion}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> La estrategia definitiva se establece según la categoría del aeródromo y el grupo de hangar, conforme a NFPA e ICAO.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Soluciones por área -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Soluciones AQUEON</span>
          <h2>El Equipo Correcto para Cada Área</h2>
        </div>
        <div class="section-header__body">
          <p>Combinamos monitores de alto caudal, espuma y detección en un <strong>sistema integral</strong>.</p>
          <p>Cada recomendación enlaza con la <strong>ficha técnica</strong> del equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {soluciones.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- EXTRA: Grupos de hangar NFPA 409 -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Criterio de diseño</span>
          <h2>Clasificación de Hangares (NFPA 409)</h2>
          <p>
            El sistema de protección de un hangar depende de su <strong>grupo</strong> conforme a NFPA 409, definido por la
            superficie, la altura de puerta y el tipo de estructura. El grupo determina si se requiere espuma de baja
            expansión a nivel de piso, espuma de alta expansión que inunda el volumen, o una combinación con monitores.
            Esta es la referencia general; la clasificación final la confirma la ingeniería del proyecto.
          </p>
          <a href="/servicios#consultoria-normativa" class="btn btn-outline"><i class="fas fa-clipboard-check" aria-hidden="true"></i> Ver consultoría normativa</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Grupo</th><th scope="col">Características</th><th scope="col">Sistema típico</th></tr>
            </thead>
            <tbody>
              {hangares.map(([g, c, s]) => (
                <tr><th scope="row">{g}</th><td>{c}</td><td>{s}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes en el sector</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones de ingeniería</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Protección Aeroportuaria de Nivel Internacional</h2>
          <p>
            En <strong>AQUEON</strong> diseñamos la protección de instalaciones de aviación partiendo de la categoría del
            aeródromo y del grupo de hangar. Somos distribuidores autorizados de Elkhart Brass, Akron Brass y Task Force
            Tips, y especificamos <strong>monitores de alto caudal y sistemas de espuma</strong> conforme a NFPA 403, 409 y
            415 y a los estándares ICAO y FAA. Entregamos ingeniería, instalación certificada y mantenimiento NFPA 25.
          </p>
          <p>
            Atendemos <strong>aeropuertos comerciales y ejecutivos, hangares de aerolíneas y de aviación privada y talleres
            MRO</strong>, con documentación para la DGAC, auditorías y aseguradoras, y cobertura en los 32 estados de la
            República desde la Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/nosotros" class="btn btn-outline-light"><i class="fas fa-building-shield" aria-hidden="true"></i> Conozca AQUEON</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Servicios de ingeniería</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Marco normativo aplicable</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Protección para Aviación" contexto="protección contra incendios para aviación, hangares y aeropuertos" faqs={faqs} />

  <!-- Otras industrias -->
