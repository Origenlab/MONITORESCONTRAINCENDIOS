---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: 'NFPA 1901', label: 'Aparatos de bomberos' },
  { numero: 'NFPA 1964', label: 'Boquillas y lanzas' },
  { numero: 'Licitación', label: 'Acompañamiento en compra pública' },
  { numero: '32', label: 'Estados con cobertura y soporte' },
];

const beneficios = [
  'Monitores vehiculares (deck guns) conforme a NFPA 1901',
  'Equipos portátiles de despliegue rápido para brigadas',
  'Boquillas y accesorios bajo NFPA 1964 / 1965',
  'Asesoría técnica y documentación para licitaciones públicas',
  'Fichas técnicas y certificaciones para el expediente',
  'Capacitación a brigadas y soporte de por vida',
];

// DIFERENCIADOR 1 — Entidades que atendemos (pg-chain)
const entidades = [
  {
    id: 'bomberos',
    eslabon: 'Emergencia',
    titulo: 'Cuerpos de Bomberos',
    icon: 'fas fa-fire-extinguisher',
    descripcion: 'Estaciones municipales y estatales que requieren equipo confiable, vehicular y portátil, con respaldo y refacciones a largo plazo.',
    activos: ['Unidades de ataque', 'Deck guns vehiculares', 'Monitores portátiles', 'Boquillas y lanzas'],
    riesgos: ['Confiabilidad en emergencia', 'Refacciones y soporte'],
  },
  {
    id: 'proteccion-civil',
    eslabon: 'Prevención',
    titulo: 'Protección Civil',
    icon: 'fas fa-shield-halved',
    descripcion: 'Dependencias de prevención y respuesta que necesitan equipo normalizado y documentación para auditoría y operación.',
    activos: ['Equipo de respuesta', 'Reservas estratégicas', 'Capacitación', 'Documentación'],
    riesgos: ['Cumplimiento normativo', 'Trazabilidad documental'],
  },
  {
    id: 'brigadas',
    eslabon: 'Industria',
    titulo: 'Brigadas Industriales',
    icon: 'fas fa-people-group',
    descripcion: 'Brigadas de planta que complementan la red fija con equipo portátil robusto para primera respuesta en sitio.',
    activos: ['Monitores portátiles', 'Boquillas', 'Equipo de espuma', 'Mangueras'],
    riesgos: ['Primera respuesta', 'Operación bajo presión'],
  },
  {
    id: 'gobierno',
    eslabon: 'Gobierno',
    titulo: 'Dependencias y Gobierno',
    icon: 'fas fa-landmark',
    descripcion: 'Entidades federales, estatales y municipales que adquieren por licitación pública y exigen expediente técnico completo.',
    activos: ['Partidas licitadas', 'Fichas técnicas', 'Certificaciones', 'Garantías'],
    riesgos: ['Proceso de licitación', 'Cumplimiento de bases'],
  },
];

// DIFERENCIADOR 2 — Equipo por aplicación (pg-scen)
const equipos = [
  {
    icon: 'fas fa-truck-front',
    nombre: 'Monitor vehicular (deck gun)',
    descripcion: 'Cañón montado en la unidad de bomberos para ataque de alto caudal desde el vehículo.',
    estrategia: 'Caudal y materiales conforme a NFPA 1901, con control manual o remoto.',
    solucion: 'Monitor fijo / deck gun',
  },
  {
    icon: 'fas fa-truck-droplet',
    nombre: 'Monitor portátil de brigada',
    descripcion: 'Equipo desplegable por una o dos personas para primera respuesta sin línea fija.',
    estrategia: 'Despliegue rápido, estabilidad y caudal según el escenario de brigada.',
    solucion: 'Monitores Portátiles',
  },
  {
    icon: 'fas fa-shower',
    nombre: 'Boquillas y lanzas',
    descripcion: 'Boquillas de chorro/niebla y accesorios para ataque y enfriamiento.',
    estrategia: 'Selección conforme a NFPA 1964 / 1965 según caudal y patrón requerido.',
    solucion: 'Boquillas y Accesorios',
  },
  {
    icon: 'fas fa-plane-departure',
    nombre: 'Aplicación ARFF / aeropuerto',
    descripcion: 'Respuesta a incendios de combustible en operaciones aeroportuarias.',
    estrategia: 'Alto caudal con espuma para combustible de aviación (NFPA 403).',
    solucion: 'Monitor de alto caudal + espuma',
  },
  {
    icon: 'fas fa-fill-drip',
    nombre: 'Sistemas de espuma',
    descripcion: 'Ataque a incendios de hidrocarburo en respuesta municipal e industrial.',
    estrategia: 'Cámaras y proporcionadores de espuma conforme a NFPA 11.',
    solucion: 'Boquillas + cámara de espuma',
  },
];

// DIFERENCIADOR 3 — Soluciones por necesidad (pg-sol, interlink)
const soluciones = [
  {
    icon: 'fas fa-truck-droplet',
    titulo: 'Equipo portátil para brigadas',
    texto: 'Monitores portátiles robustos de despliegue rápido para cuerpos de bomberos y brigadas industriales.',
    producto: 'Monitores Portátiles',
    url: '/monitores-portatiles',
  },
  {
    icon: 'fas fa-truck-front',
    titulo: 'Monitores vehiculares y fijos',
    texto: 'Deck guns y monitores de alto caudal para unidades de ataque y estaciones, conforme a NFPA 1901.',
    producto: 'Monitores Fijos Industriales',
    url: '/monitores-fijos',
  },
  {
    icon: 'fas fa-shower',
    titulo: 'Boquillas, lanzas y espuma',
    texto: 'Boquillas, cámaras de espuma y accesorios bajo NFPA 1964 para ataque y enfriamiento.',
    producto: 'Boquillas y Accesorios',
    url: '/boquillas',
  },
  {
    icon: 'fas fa-graduation-cap',
    titulo: 'Capacitación y consultoría',
    texto: 'Capacitación a brigadas, asesoría normativa y acompañamiento técnico en licitaciones.',
    producto: 'Servicios de consultoría',
    url: '/servicios#consultoria-normativa',
  },
  {
    icon: 'fas fa-robot',
    titulo: 'Monitores automáticos',
    texto: 'Detección y respuesta autónoma para instalaciones gubernamentales e infraestructura crítica.',
    producto: 'Monitores Automáticos',
    url: '/monitores-automaticos',
  },
  {
    icon: 'fas fa-screwdriver-wrench',
    titulo: 'Servicio y refacciones',
    texto: 'Instalación, mantenimiento NFPA 25 y disponibilidad de refacciones a largo plazo.',
    producto: 'Servicios de ingeniería',
    url: '/servicios',
  },
];

// EXTRA — Acompañamiento en licitaciones (pg-dens)
const licitacion = [
  ['Fichas técnicas', 'Documento del equipo para integrar a las bases y la propuesta'],
  ['Certificaciones', 'FM Approved / UL Listed y cumplimiento NFPA para el expediente'],
  ['Cuadro de partidas', 'Desglose técnico por partida para cotización y evaluación'],
  ['Cumplimiento normativo', 'Mapeo del equipo contra las bases y la normativa aplicable'],
  ['Capacitación y garantías', 'Plan de capacitación, garantía y soporte post-venta'],
];

const normativas = [
  { n: 'NFPA 1901', d: 'Aparatos automotores de bomberos' },
  { n: 'NFPA 1964', d: 'Boquillas de chorro/niebla' },
  { n: 'NFPA 1965', d: 'Accesorios para mangueras' },
  { n: 'NFPA 1962', d: 'Cuidado y uso de mangueras' },
  { n: 'NFPA 11', d: 'Sistemas de espuma' },
  { n: 'Licitación pública', d: 'Ley de Adquisiciones y bases técnicas' },
  { n: 'Protección Civil', d: 'Normatividad federal y estatal aplicable' },
];

const errores = [
  'Redactar bases de licitación sin especificación técnica clara',
  'Adquirir equipo sin certificación verificable (FM/UL)',
  'No considerar la disponibilidad de refacciones a largo plazo',
  'Omitir la capacitación de la brigada en la compra',
  'Elegir por precio sin evaluar confiabilidad en emergencia',
  'Dejar fuera el soporte y la garantía del expediente',
];

const recomendaciones = [
  'Defina la especificación técnica con respaldo normativo',
  'Exija certificación FM Approved o UL Listed verificable',
  'Asegure refacciones y soporte de largo plazo en las bases',
  'Incluya capacitación y garantía en la partida',
  'Evalúe confiabilidad y respaldo, no solo el precio',
  'Apóyese en asesoría técnica para el expediente de licitación',
];

const faqs = [
  { q: '¿AQUEON apoya en procesos de licitación pública?', a: 'Sí. Acompañamos a dependencias y a participantes con la documentación técnica que requiere el proceso: fichas técnicas del equipo, certificaciones FM Approved / UL Listed, cuadro de partidas, mapeo de cumplimiento contra las bases y la normativa, y planes de capacitación y garantía. El objetivo es que el expediente sea técnicamente sólido y que el equipo adquirido sea el correcto para la operación.' },
  { q: '¿Qué normativa aplica al equipo para cuerpos de bomberos?', a: 'Los aparatos automotores de bomberos se rigen por NFPA 1901, las boquillas de chorro y niebla por NFPA 1964, los accesorios de manguera por NFPA 1965 y el cuidado de mangueras por NFPA 1962; los sistemas de espuma por NFPA 11. A esto se suman los requisitos de Protección Civil y, en compra pública, la Ley de Adquisiciones y las bases técnicas de cada licitación.' },
  { q: '¿Qué es un monitor vehicular o deck gun?', a: 'Es un monitor montado sobre la unidad de bomberos que permite atacar el incendio con un caudal muy superior al de una línea de manguera, operado desde el vehículo de forma manual o remota. Se especifica conforme a NFPA 1901 según el caudal, el material y el tipo de control, y es una pieza clave de la capacidad de ataque de una unidad.' },
  { q: '¿Qué equipo recomiendan para una brigada industrial?', a: 'Una brigada de planta se beneficia de monitores portátiles robustos de despliegue rápido, boquillas y lanzas bajo NFPA 1964, y, donde haya riesgo de hidrocarburo, equipo de espuma. El objetivo es una primera respuesta efectiva que complemente la red fija de la instalación, con equipo confiable y capacitación adecuada.' },
  { q: '¿Incluyen capacitación para la brigada o el cuerpo de bomberos?', a: 'Sí. La capacitación es parte de nuestra propuesta: enseñamos el uso correcto, seguro y eficiente del equipo, su mantenimiento básico y los protocolos de operación. Para dependencias y licitaciones, integramos el plan de capacitación y la garantía como parte del expediente.' },
  { q: '¿Garantizan refacciones y soporte a largo plazo?', a: 'Sí. Como distribuidores autorizados de marcas líderes mundiales, aseguramos disponibilidad de refacciones y soporte técnico de largo plazo, un punto crítico para el sector público donde el equipo debe operar de forma confiable durante muchos años. Lo documentamos en la propuesta para que quede en el expediente.' },
  { q: '¿Atienden a gobiernos municipales, estatales y federales?', a: 'Sí. Atendemos a cuerpos de bomberos y Protección Civil de los tres órdenes de gobierno, así como a brigadas industriales, con equipo FM Approved y UL Listed, documentación para licitación y auditoría, capacitación y soporte, con cobertura en los 32 estados de la República desde la Ciudad de México.' },
];
---
<Base
  title="Protección Contra Incendios para Bomberos y Gobierno | NFPA 1901 y Licitaciones | AQUEON México"
  description="Monitores contra incendios para cuerpos de bomberos, Protección Civil, brigadas industriales y gobierno en México: deck guns vehiculares, equipo portátil y boquillas conforme a NFPA 1901/1964. Asesoría y documentación para licitaciones públicas. Ingeniería, capacitación y soporte con AQUEON."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/industrias">Industrias</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Bomberos y Gobierno</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Industrias · Bomberos y Gobierno</span>
          <h1>Protección Contra Incendios para Bomberos y Gobierno</h1>
        </div>
        <div class="section-header__body">
          <p>El sector donde la <strong>confiabilidad</strong> y el <strong>expediente</strong> pesan tanto como el equipo.</p>
          <p>Equipo conforme a <strong>NFPA 1901/1964</strong> y acompañamiento en <strong>licitaciones públicas</strong>, con soporte de largo plazo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El reto del sector</span>
          <h2>Equipo Confiable y Expediente Impecable</h2>
          <p>
            El sector de <strong>bomberos y gobierno</strong> tiene dos exigencias que van de la mano: el equipo debe
            <strong>responder sin falla</strong> en el momento de la emergencia, y su adquisición debe cumplir un
            <strong>proceso de compra pública</strong> con documentación técnica impecable. Un buen monitor no sirve de
            nada si el expediente de licitación no lo respalda, ni un buen expediente si el equipo falla en campo.
          </p>
          <p>
            Por eso acompañamos a cuerpos de bomberos, Protección Civil, brigadas industriales y dependencias con equipo
            certificado conforme a <strong>NFPA 1901, 1964 y 11</strong>, y con la <strong>asesoría técnica</strong> que el
            proceso de licitación requiere: fichas técnicas, certificaciones, cuadro de partidas y cumplimiento normativo.
            Y, sobre todo, con refacciones y soporte que duran tanto como el equipo.
          </p>
          <p>
            En esta página verá las entidades que atendemos, el equipo por aplicación, las soluciones por necesidad y cómo
            acompañamos el proceso de licitación pública de principio a fin.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Entidades -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">A quién servimos</span>
          <h2>Entidades que Atendemos</h2>
        </div>
        <div class="section-header__body">
          <p>De los cuerpos de bomberos a las dependencias de gobierno, cada entidad tiene <strong>necesidades propias</strong>.</p>
          <p>Adaptamos el equipo, la documentación y el soporte a cada una.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {entidades.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-cubes" aria-hidden="true"></i> Equipo y necesidades</span>
            <div class="l3-chips">
              {c.activos.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-flag" aria-hidden="true"></i> Prioridades</span>
            <div class="l3-chips">
              {c.riesgos.map((r) => <span class="l3-chip l3-chip--norm">{r}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Equipo por aplicación -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Equipo y normativa</span>
          <h2>Equipo por Aplicación</h2>
        </div>
        <div class="section-header__body">
          <p>Del deck gun vehicular a la espuma, cada aplicación tiene su <strong>norma y su equipo</strong>.</p>
          <p>Esta matriz resume cómo seleccionamos según la necesidad operativa.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Aplicación</th>
              <th scope="col">Descripción</th>
              <th scope="col">Criterio / norma</th>
              <th scope="col">Solución AQUEON</th>
            </tr>
          </thead>
          <tbody>
            {equipos.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td>{e.estrategia}</td>
                <td class="pg-scen-sol">{e.solucion}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> La selección final se ajusta a las bases de la licitación y al escenario operativo de cada cuerpo o brigada.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Soluciones por necesidad -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Soluciones AQUEON</span>
          <h2>El Equipo Correcto para Cada Necesidad</h2>
        </div>
        <div class="section-header__body">
          <p>Equipo, capacitación y soporte como un <strong>paquete integral</strong> para el sector público.</p>
          <p>Cada recomendación enlaza con la <strong>ficha técnica</strong> del equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {soluciones.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- EXTRA: Acompañamiento en licitaciones -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Compra pública</span>
          <h2>Acompañamiento en Licitaciones Públicas</h2>
          <p>
            La compra de equipo contra incendios en el sector público vive o muere en el <strong>expediente técnico</strong>.
            Acompañamos cada etapa con la documentación que el proceso exige, para que el equipo adquirido sea el correcto y
            la licitación se sostenga ante cualquier revisión. Esto es lo que entregamos.
          </p>
          <a href="/contacto" class="btn btn-outline"><i class="fas fa-file-signature" aria-hidden="true"></i> Solicitar asesoría de licitación</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Entregable</th><th scope="col">Propósito</th></tr>
            </thead>
            <tbody>
              {licitacion.map(([d, p]) => (
                <tr><th scope="row">{d}</th><td>{p}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes en la compra</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Socio Técnico del Sector Público y las Brigadas</h2>
          <p>
            En <strong>AQUEON</strong> entendemos que el sector público necesita más que un proveedor: necesita un socio
            técnico. Somos distribuidores autorizados de Elkhart Brass, Akron Brass y Task Force Tips, y ofrecemos
            <strong>equipo certificado, asesoría de licitación, capacitación y soporte de largo plazo</strong> conforme a
            NFPA 1901, 1964 y 11. Entregamos la documentación que el expediente exige y respondemos con refacciones cuando
            más importa.
          </p>
          <p>
            Atendemos <strong>cuerpos de bomberos, Protección Civil, brigadas industriales y dependencias</strong> de los
            tres órdenes de gobierno, con cobertura en los 32 estados de la República desde la Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/nosotros" class="btn btn-outline-light"><i class="fas fa-building-shield" aria-hidden="true"></i> Conozca AQUEON</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Servicios y capacitación</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Marco normativo aplicable</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Equipo para Bomberos y Gobierno" contexto="equipo contra incendios para bomberos, brigadas y dependencias de gobierno" faqs={faqs} />

  <!-- Otras industrias -->
  <section class="l3-otras">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Más Sectores</span>
          <h2>Otras Industrias que Protegemos</h2>
        </div>
        <div class="section-header__body">
          <p>Diseñamos la solución óptima para cada <strong>operación de alto riesgo</strong>.</p>
          <p>Conozca nuestra cobertura por sector en todo México.</p>
        </div>
      </div>
      <div class="l3-otras-grid">
        <a href="/petroleo-gas" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-oil-well" aria-hidden="true"></i></span><span class="l3-otra-name">Petróleo y Gas</span><span class="l3-otra-sub">Refinerías · terminales · offshore</span></a>
