---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const modelos = [
  {
    id: 'mi-1500',
    modelo: 'MI-1500',
    nombre: 'Monitor Industrial MI-1500',
    badge: 'FM Approved',
    badgePremium: false,
    icon: 'fas fa-fire-extinguisher',
    imagen: '/images/monitores-contra-incendios-industria-manufactura.webp',
    resumen: 'Monitor fijo manual de bronce marino, la opción de referencia para protección permanente de áreas de proceso, almacenamiento y manufactura de riesgo moderado.',
    descripcion: 'El MI-1500 es un monitor fijo de operación manual construido en bronce marino, diseñado para décadas de servicio en intemperie. Su rango de 500 a 1,500 GPM cubre la mayoría de los escenarios de enfriamiento y ataque directo en planta, con un mecanismo de volantes suave y preciso que permite a un solo operador reorientar el chorro bajo presión.',
    specs: [
      ['Caudal nominal', '500 – 1,500 GPM'],
      ['Presión máxima de operación', '150 PSI'],
      ['Material de construcción', 'Bronce marino'],
      ['Tipo de control', 'Manual (volantes de elevación y giro)'],
      ['Rotación', '360° horizontal · +90° / −45° vertical'],
      ['Conexión de entrada', 'Brida 2.5" a 4"'],
      ['Certificación', 'FM Approved · UL Listed'],
    ],
    aplicaciones: ['Manufactura', 'Parques industriales', 'Áreas de almacenamiento', 'Muelles de carga'],
  },
  {
    id: 'mg-4000',
    modelo: 'MG-4000',
    nombre: 'Monitor Magnum MG-4000',
    badge: 'Alto Caudal',
    badgePremium: true,
    icon: 'fas fa-gauge-high',
    imagen: '/images/monitores-contra-incendios-refineria-petroleo-gas.webp',
    resumen: 'Monitor de ultra-alto caudal en acero inoxidable 316L para refinerías y terminales de almacenamiento que exigen cumplimiento PEMEX y alcance superior.',
    descripcion: 'Cuando el escenario de diseño contempla tanques de gran diámetro o patios de almacenamiento de hidrocarburos, el MG-4000 entrega de 2,000 a 4,000 GPM con un alcance que permite enfriar exposiciones desde una posición segura. Su construcción en acero inoxidable 316L resiste ambientes salinos y corrosivos, y cumple con los requisitos técnicos de PEMEX y de las aseguradoras internacionales.',
    specs: [
      ['Caudal nominal', '2,000 – 4,000 GPM'],
      ['Presión máxima de operación', '175 PSI'],
      ['Material de construcción', 'Acero inoxidable 316L'],
      ['Tipo de control', 'Manual con opción de actuación remota'],
      ['Compatibilidad', 'Agua y espuma (cámara / tubo aspirante)'],
      ['Conexión de entrada', 'Brida 4" a 6"'],
      ['Certificación', 'FM Approved · UL Listed · Cumplimiento PEMEX'],
    ],
    aplicaciones: ['Refinerías', 'Terminales de almacenamiento', 'Patios de tanques', 'Petroquímica'],
  },
  {
    id: 'mr-3000',
    modelo: 'MR-3000',
    nombre: 'Monitor Remoto ATEX MR-3000',
    badge: 'ATEX',
    badgePremium: false,
    icon: 'fas fa-bolt',
    imagen: '/images/monitores-contra-incendios-planta-petroquimica.webp',
    resumen: 'Monitor fijo con control remoto eléctrico certificado para atmósferas explosivas, ideal para áreas clasificadas Clase I División 1 y 2.',
    descripcion: 'El MR-3000 lleva la protección a las zonas donde ningún operador debería estar durante una emergencia. Con control remoto eléctrico por joystick o tablero, y certificación ATEX/IECEx para áreas clasificadas, permite atacar y enfriar el incendio sin exponer al personal. Es la solución para refinerías, plantas químicas y terminales con presencia de vapores inflamables.',
    specs: [
      ['Caudal nominal', '1,500 – 3,000 GPM'],
      ['Tipo de control', 'Remoto eléctrico (joystick / tablero)'],
      ['Clasificación de área', 'Clase I, División 1 y 2'],
      ['Certificación', 'ATEX / IECEx · FM Approved'],
      ['Posicionamiento', 'Posiciones programables y oscilación opcional'],
      ['Material de construcción', 'Acero inoxidable / recubrimiento epóxico'],
      ['Integración', 'Compatible con DCS / SCADA'],
    ],
    aplicaciones: ['Áreas clasificadas', 'Plantas químicas', 'Refinerías', 'Terminales con vapores'],
  },
];

const stats = [
  { numero: '500–4,000', label: 'GPM de caudal disponible' },
  { numero: 'FM · UL', label: 'Certificaciones internacionales' },
  { numero: '316L', label: 'Acero inoxidable marino' },
  { numero: '360°', label: 'Cobertura de rotación' },
];

const beneficios = [
  'Protección permanente 24/7 sin dependencia de personal en sitio',
  'Cobertura constante de áreas críticas y exposiciones',
  'Alcance y caudal muy superiores a una línea de manguera',
  'Materiales resistentes a la corrosión para décadas de servicio',
  'Compatibilidad con sistemas de espuma para hidrocarburos',
  'Integración con la red hidráulica y sistemas de control existentes',
];

const aplicaciones = [
  { icon: 'fas fa-oil-well', titulo: 'Refinerías y terminales', texto: 'Enfriamiento de tanques, patios de almacenamiento y áreas de proceso de hidrocarburos.' },
  { icon: 'fas fa-flask', titulo: 'Petroquímica', texto: 'Protección de reactores, racks de tubería y zonas con vapores inflamables.' },
  { icon: 'fas fa-industry', titulo: 'Manufactura', texto: 'Naves industriales, almacenes y líneas de producción de gran superficie.' },
  { icon: 'fas fa-bolt', titulo: 'Generación de energía', texto: 'Enfriamiento de transformadores, turbinas y áreas de combustible.' },
  { icon: 'fas fa-warehouse', titulo: 'Almacenamiento y logística', texto: 'Centros de distribución, muelles de carga y bodegas de alto riesgo.' },
  { icon: 'fas fa-anchor', titulo: 'Puertos y muelles', texto: 'Protección de terminales marítimas y zonas de trasiego de combustible.' },
];

const errores = [
  'Seleccionar el caudal por costo y no por el escenario de incendio de diseño',
  'Ignorar la distancia de seguridad y la radiación térmica al ubicar el monitor',
  'Elegir materiales no aptos para ambientes salinos o corrosivos',
  'Omitir la verificación de certificación FM/UL independiente',
  'No considerar la compatibilidad con espuma en riesgos de hidrocarburos',
  'Subdimensionar la red hidráulica que alimenta el monitor',
];

const recomendaciones = [
  'Parta siempre de un cálculo hidráulico conforme a NFPA 15',
  'Exija documentación de certificación FM Approved o UL Listed',
  'Defina material según el ambiente: bronce marino o acero 316L',
  'Evalúe control remoto ATEX en áreas clasificadas',
  'Considere el mantenimiento NFPA 25 desde el diseño',
  'Solicite asesoría de ingeniería antes de especificar el equipo',
];

const faqs = [
  { q: '¿Qué es un monitor fijo industrial contra incendios?', a: 'Es un cañón de agua o espuma montado de forma permanente sobre una base, brida o pedestal, conectado a la red privada de protección contra incendios. A diferencia de un equipo portátil, el monitor fijo ofrece cobertura constante de un área crítica sin necesidad de despliegue, lo que lo convierte en la columna vertebral de la protección de tanques, áreas de proceso y muelles de carga.' },
  { q: '¿Qué caudal (GPM) necesito en un monitor fijo?', a: 'Depende del escenario de incendio de diseño: superficie a proteger, tipo de riesgo y densidad de aplicación que exige la norma (NFPA 15 para agua, NFPA 11 para espuma). Nuestros modelos cubren de 500 a 4,000 GPM. El dimensionamiento correcto requiere un cálculo hidráulico; en AQUEON lo realizamos sin costo a partir de los datos de su instalación.' },
  { q: '¿Cuál es la diferencia entre el MI-1500, el MG-4000 y el MR-3000?', a: 'El MI-1500 es manual de bronce para riesgo moderado (500–1,500 GPM); el MG-4000 es de ultra-alto caudal en acero 316L con cumplimiento PEMEX para refinerías (2,000–4,000 GPM); y el MR-3000 es de control remoto eléctrico certificado ATEX para áreas clasificadas. La selección depende del riesgo, el caudal y la clasificación del área.' },
  { q: '¿Los monitores fijos AQUEON son compatibles con espuma?', a: 'Sí. El MG-4000 y el MR-3000 admiten descarga de solución espumante mediante tubo aspirante o cámara de espuma, indispensable para incendios de hidrocarburos bajo NFPA 11. La selección del concentrado (AFFF, AR-AFFF o F3) y del proporcionador forma parte del diseño integral del sistema.' },
  { q: '¿Por qué es importante la certificación FM Approved o UL Listed?', a: 'Porque garantiza, mediante pruebas de laboratorio independiente y auditoría de fábrica, que el monitor cumple con el desempeño hidráulico, la resistencia a la corrosión y los requisitos de seguridad declarados. Es condición en especificaciones de PEMEX y referencia obligada de las aseguradoras internacionales.' },
  { q: '¿Se pueden controlar a distancia los monitores fijos?', a: 'Sí. El MR-3000 ofrece control remoto eléctrico por joystick o tablero, con posiciones programables y compatibilidad con sistemas DCS/SCADA. Esto permite operar el monitor desde una sala de control, sin exponer al personal en áreas de alto riesgo.' },
  { q: '¿Qué material conviene: bronce o acero inoxidable?', a: 'El bronce marino ofrece excelente durabilidad y resistencia a la corrosión a un costo competitivo, ideal para manufactura e industria general. El acero inoxidable 316L es preferible en ambientes salinos, costeros o con químicos agresivos, como refinerías y terminales marítimas.' },
  { q: '¿Qué normativa aplica al diseño e instalación?', a: 'Principalmente NFPA 15 (sistemas fijos de agua pulverizada), NFPA 11 (espuma), NFPA 24 (redes privadas de servicio contra incendios) y NFPA 25 (inspección, prueba y mantenimiento), además de la NOM-002-STPS en materia de seguridad laboral y los requisitos específicos de PEMEX y aseguradoras.' },
  { q: '¿AQUEON instala y da mantenimiento a los monitores fijos?', a: 'Sí. Ofrecemos el ciclo completo: diseño e ingeniería conforme a NFPA, instalación con técnicos certificados, pruebas hidrostáticas, puesta en marcha, capacitación y mantenimiento preventivo NFPA 25, con cobertura en toda la República Mexicana desde la Ciudad de México.' },
  { q: '¿En cuánto tiempo entregan una cotización?', a: 'Respondemos cotizaciones técnicas en menos de 24 horas hábiles. Para proyectos que lo requieran agendamos una visita técnica sin costo para levantar el escenario de incendio y proponer el modelo y la configuración óptimos.' },
];
---
<Base
  title="Monitores Fijos Industriales Contra Incendios | AQUEON"
  description="Monitores fijos industriales contra incendios FM Approved y UL Listed: MI-1500, MG-4000 y MR-3000 ATEX, de 500 a 4,000 GPM. Ingeniería e instalación AQUEON."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/productos">Productos</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Monitores Fijos Industriales</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Catálogo · Monitores Fijos</span>
          <h1>Monitores Fijos Industriales Contra Incendios</h1>
        </div>
        <div class="section-header__body">
          <p>La <strong>columna vertebral</strong> de la protección industrial: cobertura permanente de tanques, áreas de proceso y muelles de carga.</p>
          <p>Equipos certificados <strong>FM Approved y UL Listed</strong>, de 500 a 4,000 GPM, con ingeniería e instalación de AQUEON.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">¿Qué es un monitor fijo?</span>
          <h2>Protección Permanente que No Depende de Nadie</h2>
          <p>
            Un <strong>monitor fijo industrial contra incendios</strong> —también llamado cañón de agua o
            <em>deck gun</em>— es un dispositivo de descarga de gran caudal montado de forma permanente y conectado a la
            red privada de protección contra incendios. Mientras una línea de manguera operada por dos personas entrega
            entre 250 y 300 GPM, un monitor fijo descarga desde 500 hasta más de 4,000 galones por minuto, con un alcance
            que permite enfriar exposiciones y atacar el fuego desde una posición segura.
          </p>
          <p>
            En la industria petrolera, petroquímica y manufacturera, el monitor fijo es la primera línea de defensa: está
            siempre listo, cubre el área crítica de manera constante y no depende de que una brigada llegue a tiempo. Por
            eso las normas <strong>NFPA 15, NFPA 11 y NFPA 24</strong>, así como los requisitos de PEMEX y de las
            aseguradoras, exigen monitores en prácticamente todas las instalaciones de alto riesgo.
          </p>
          <p>
            Seleccionar el monitor correcto no es una decisión de catálogo. Implica calcular el caudal en GPM y la presión
            en PSI, definir el material según el ambiente, verificar la certificación independiente y, en áreas
            clasificadas, evaluar el control remoto. En esta página encontrará los tres modelos fijos de AQUEON, sus
            especificaciones técnicas y la guía para elegir con criterio de ingeniería.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Modelos -->
  <section class="l3-modelos">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Nuestros Modelos</span>
          <h2>Tres Soluciones para Cada Nivel de Riesgo</h2>
        </div>
        <div class="section-header__body">
          <p>Del riesgo moderado al sector petrolero y las áreas clasificadas, cada modelo responde a un <strong>escenario de diseño</strong> distinto.</p>
          <p>Todos con <strong>certificación internacional</strong>, garantía de fábrica y respaldo de ingeniería.</p>
        </div>
      </div>

      {modelos.map((m) => (
        <article id={m.id} class="l3-model">
          <div class="l3-model-media">
            <img src={m.imagen} alt={`${m.nombre} — monitor fijo contra incendios AQUEON`} loading="lazy" />
            <span class:list={['l3-model-badge', m.badgePremium && 'is-premium']}><i class={m.icon} aria-hidden="true"></i> {m.badge}</span>
          </div>
          <div class="l3-model-content">
            <span class="l3-model-kicker">{m.modelo}</span>
            <h3>{m.nombre}</h3>
            <p class="l3-model-resumen">{m.resumen}</p>
            <p>{m.descripcion}</p>

            <table class="l3-spec-table">
              <tbody>
                {m.specs.map(([k, v]) => (
                  <tr><th scope="row">{k}</th><td>{v}</td></tr>
                ))}
              </tbody>
            </table>

            <div class="l3-model-apps">
              <span class="l3-apps-label"><i class="fas fa-location-dot" aria-hidden="true"></i> Aplicaciones</span>
              <div class="l3-chips">
                {m.aplicaciones.map((a) => <span class="l3-chip">{a}</span>)}
              </div>
            </div>

            <div class="l3-model-actions">
              <a href="/contacto" class="btn btn-primary"><i class="fas fa-file-invoice" aria-hidden="true"></i> Cotizar el {m.modelo}</a>
              <a href={`https://wa.me/5215512345678?text=Hola%20AQUEON%2C%20me%20interesa%20el%20monitor%20fijo%20${m.modelo}`} class="btn btn-outline" target="_blank" rel="noopener"><i class="fab fa-whatsapp" aria-hidden="true"></i> WhatsApp</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Tabla comparativa -->
  <section class="l3-compare">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Comparativa</span>
          <h2>MI-1500 vs MG-4000 vs MR-3000</h2>
        </div>
        <div class="section-header__body">
          <p>Una vista rápida para <strong>decidir con criterio técnico</strong> según su escenario de riesgo.</p>
          <p>¿Dudas sobre cuál especificar? Nuestros ingenieros lo orientan <strong>sin costo</strong>.</p>
        </div>
      </div>
      <div class="l3-compare-wrap">
        <table class="l3-compare-table">
          <thead>
            <tr>
              <th scope="col">Característica</th>
              <th scope="col">MI-1500</th>
              <th scope="col">MG-4000</th>
              <th scope="col">MR-3000</th>
            </tr>
          </thead>
          <tbody>
            <tr><th scope="row">Caudal (GPM)</th><td>500 – 1,500</td><td>2,000 – 4,000</td><td>1,500 – 3,000</td></tr>
            <tr><th scope="row">Presión máx. (PSI)</th><td>150</td><td>175</td><td>160</td></tr>
            <tr><th scope="row">Material</th><td>Bronce marino</td><td>Acero inox. 316L</td><td>Inox. / epóxico</td></tr>
            <tr><th scope="row">Control</th><td>Manual</td><td>Manual / remoto</td><td>Remoto eléctrico</td></tr>
            <tr><th scope="row">Áreas clasificadas</th><td>—</td><td>Opcional</td><td>ATEX / IECEx</td></tr>
            <tr><th scope="row">Espuma</th><td>Opcional</td><td>Sí</td><td>Sí</td></tr>
            <tr><th scope="row">Certificación</th><td>FM · UL</td><td>FM · UL · PEMEX</td><td>ATEX · FM</td></tr>
            <tr><th scope="row">Ideal para</th><td>Manufactura</td><td>Refinerías</td><td>Áreas de riesgo</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Aplicaciones -->
  <section class="l3-apps-section">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Aplicaciones</span>
          <h2>Dónde Protegen los Monitores Fijos</h2>
        </div>
        <div class="section-header__body">
          <p>Equipos especificados para los <strong>entornos industriales más exigentes</strong> de México.</p>
          <p>Cada sector con su normativa y su material idóneo, definidos por ingeniería.</p>
        </div>
      </div>
      <div class="l3-apps-grid">
        {aplicaciones.map((a) => (
          <article class="l3-app-card">
            <span class="l3-app-icon" aria-hidden="true"><i class={a.icon}></i></span>
            <h3>{a.titulo}</h3>
            <p>{a.texto}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes al seleccionar</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones para empresas</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Distribuidor Especialista en Monitores Fijos en México</h2>
          <p>
            En <strong>AQUEON</strong> somos distribuidores autorizados de Elkhart Brass, Akron Brass y Task Force Tips, las
            marcas líderes mundiales en monitores contra incendios. No solo vendemos equipo: entregamos ingeniería de diseño
            conforme a NFPA, instalación con técnicos certificados, mantenimiento preventivo NFPA 25, capacitación a su
            brigada y soporte técnico de por vida, con cobertura en los 32 estados de la República desde la Ciudad de México.
          </p>
          <p>
            Atendemos proyectos de <strong>PEMEX, CFE, refinerías, terminales de almacenamiento, parques industriales y
            grandes corporativos</strong>, con documentación completa para auditorías de Protección Civil y aseguradoras.
            Somos uno de los principales especialistas en monitores contra incendios industriales en México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/nosotros" class="btn btn-outline-light"><i class="fas fa-building-shield" aria-hidden="true"></i> Conozca AQUEON</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Servicios de ingeniería</a>
          </div>
        </div>
        <div class="l3-normativas">
          <h3>Normativas aplicables</h3>
          <div class="l3-chips">
            <span class="l3-chip l3-chip--norm">NFPA 15</span>
            <span class="l3-chip l3-chip--norm">NFPA 11</span>
            <span class="l3-chip l3-chip--norm">NFPA 24</span>
            <span class="l3-chip l3-chip--norm">NFPA 25</span>
            <span class="l3-chip l3-chip--norm">NOM-002-STPS</span>
            <span class="l3-chip l3-chip--norm">FM Approved</span>
            <span class="l3-chip l3-chip--norm">UL Listed</span>
            <span class="l3-chip l3-chip--norm">ATEX / IECEx</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Monitores Fijos Industriales" contexto="monitores fijos industriales" faqs={faqs} />

  <!-- Otras categorías -->
  <section class="l3-otras">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Catálogo Completo</span>
          <h2>Otras Categorías de Producto</h2>
        </div>
        <div class="section-header__body">
          <p>Complemente su sistema con la <strong>línea completa</strong> de monitores y accesorios AQUEON.</p>
          <p>Una sola fuente para todo su sistema de protección contra incendios.</p>
        </div>
      </div>
