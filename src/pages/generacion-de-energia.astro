---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: 'NFPA 850·851', label: 'Centrales térmicas e hidroeléctricas' },
  { numero: 'CFE', label: 'Cumplimiento de requisitos' },
  { numero: '0.25 gpm/ft²', label: 'Enfriamiento de transformadores (ref.)' },
  { numero: '24/7', label: 'Disponibilidad crítica de planta' },
];

const beneficios = [
  'Diseño conforme a NFPA 850 y NFPA 851 para generación eléctrica',
  'Sistemas de agua pulverizada para transformadores y turbinas',
  'Monitores remotos para subestaciones y áreas energizadas',
  'Protección de galerías de cables y bandas de manejo de combustible',
  'Cumplimiento de requisitos CFE y documentación para auditoría',
  'Materiales y configuración para operación continua 24/7',
];

// DIFERENCIADOR 1 — Tipos de central (pg-chain)
const tipos = [
  {
    id: 'termoelectrica',
    eslabon: 'Térmica',
    titulo: 'Termoeléctrica y Ciclo Combinado',
    icon: 'fas fa-fire-flame-curved',
    descripcion: 'Turbinas de gas y vapor, calderas y manejo de combustible. El aceite lubricante a presión y el combustible concentran el riesgo de incendio.',
    activos: ['Turbinas de gas y vapor', 'Calderas', 'Patios de combustible', 'Generadores'],
    riesgos: ['Aceite lubricante', 'Incendio de combustible', 'Hidrógeno de enfriamiento'],
  },
  {
    id: 'hidroelectrica',
    eslabon: 'Hidro',
    titulo: 'Hidroeléctrica',
    icon: 'fas fa-water',
    descripcion: 'Generadores, transformadores y extensas galerías de cables en casa de máquinas, regidos por NFPA 851. El aceite y los cables son el foco.',
    activos: ['Generadores', 'Transformadores', 'Galerías de cables', 'Casa de máquinas'],
    riesgos: ['Aceite de transformador', 'Propagación por cables'],
  },
  {
    id: 'subestaciones',
    eslabon: 'Transmisión',
    titulo: 'Subestaciones y Transformadores',
    icon: 'fas fa-tower-cell',
    descripcion: 'Transformadores de potencia con gran inventario de aceite aislante. Una falla puede derivar en incendio de aceite y afectar equipos vecinos.',
    activos: ['Transformadores de potencia', 'Reactores', 'Bancos de capacitores', 'Patios de maniobra'],
    riesgos: ['Incendio de aceite aislante', 'Exposición a equipos vecinos'],
  },
  {
    id: 'cogeneracion',
    eslabon: 'Distribuida',
    titulo: 'Cogeneración y Distribuida',
    icon: 'fas fa-plug-circle-bolt',
    descripcion: 'Motores y microturbinas con recuperación de calor en instalaciones industriales. Combustible y aceite en espacios compactos.',
    activos: ['Motores de combustión', 'Microturbinas', 'Recuperadores de calor', 'Tanques de día'],
    riesgos: ['Aceite y combustible', 'Espacios confinados'],
  },
];

// DIFERENCIADOR 2 — Matriz de activos críticos (pg-scen)
const activos = [
  {
    icon: 'fas fa-bolt',
    nombre: 'Transformador de potencia',
    descripcion: 'Gran inventario de aceite aislante; la falla interna puede romper el tanque e incendiar.',
    estrategia: 'Sistema de diluvio de agua pulverizada sobre la superficie + dique y drenaje de aceite (NFPA 850).',
    solucion: 'Monitor remoto + boquillas de aspersión',
  },
  {
    icon: 'fas fa-gears',
    nombre: 'Turbina (aceite lubricante)',
    descripcion: 'Fuga de aceite a presión sobre superficies calientes de la turbina.',
    estrategia: 'Agua pulverizada o niebla de agua (water mist) sobre el conjunto y enfriamiento de exposiciones.',
    solucion: 'Sistema fijo de aspersión + monitor',
  },
  {
    icon: 'fas fa-atom',
    nombre: 'Generador enfriado por hidrógeno',
    descripcion: 'Riesgo de explosión por fuga de hidrógeno del sistema de enfriamiento.',
    estrategia: 'Purga e inertización del hidrógeno y enfriamiento de exposiciones desde posición segura.',
    solucion: 'Monitor remoto + detección',
  },
  {
    icon: 'fas fa-grip-lines',
    nombre: 'Galería de cables',
    descripcion: 'Propagación rápida del fuego a través de charolas y bandejas de cables.',
    estrategia: 'Detección temprana + agua pulverizada y sellos cortafuego entre tramos (NFPA 850).',
    solucion: 'Monitores automáticos + aspersión',
  },
  {
    icon: 'fas fa-oil-can',
    nombre: 'Patio de combustible',
    descripcion: 'Tanques de diésel o gas y áreas de bombeo con riesgo de derrame e incendio.',
    estrategia: 'Espuma sobre la superficie del combustible y enfriamiento de exposiciones (NFPA 11).',
    solucion: 'Monitor Magnum MG-4000 + espuma',
  },
  {
    icon: 'fas fa-conveyor-belt-boxes',
    nombre: 'Manejo de carbón',
    descripcion: 'Polvo combustible y bandas transportadoras con riesgo de ignición y deflagración.',
    estrategia: 'Supresión en puntos de transferencia y enfriamiento de bandas; gestión de polvo combustible.',
    solucion: 'Monitores automáticos dirigidos',
  },
];

// DIFERENCIADOR 3 — Soluciones por activo (pg-sol, interlink)
const soluciones = [
  {
    icon: 'fas fa-tower-cell',
    titulo: 'Subestaciones y transformadores',
    texto: 'Enfriamiento y ataque de incendios de aceite sin exponer personal en patios energizados, operado a distancia.',
    producto: 'Monitor Remoto ATEX MR-3000',
    url: '/monitores-fijos#mr-3000',
  },
  {
    icon: 'fas fa-oil-can',
    titulo: 'Patios de combustible',
    texto: 'Enfriamiento de exposiciones y aplicación de espuma sobre tanques de diésel y combustibles líquidos.',
    producto: 'Monitor Magnum MG-4000',
    url: '/monitores-fijos#mg-4000',
  },
  {
    icon: 'fas fa-grip-lines',
    titulo: 'Galerías de cables y bandas',
    texto: 'Cobertura dirigida con detección y descarga automática en charolas de cables y manejo de carbón.',
    producto: 'Monitores Automáticos',
    url: '/monitores-automaticos',
  },
  {
    icon: 'fas fa-shower',
    titulo: 'Enfriamiento de turbinas y áreas',
    texto: 'Boquillas de aspersión y cámaras para sistemas fijos de agua pulverizada en equipos críticos.',
    producto: 'Boquillas y Accesorios',
    url: '/boquillas',
  },
  {
    icon: 'fas fa-truck-droplet',
    titulo: 'Respuesta de brigada',
    texto: 'Equipos de despliegue rápido para complementar la red fija en maniobras y mantenimiento.',
    producto: 'Monitores Portátiles',
    url: '/monitores-portatiles',
  },
  {
    icon: 'fas fa-compass-drafting',
    titulo: 'Diseño NFPA 850 / 851',
    texto: 'Ingeniería del sistema completo conforme a la normativa de generación eléctrica y requisitos CFE.',
    producto: 'Servicios de ingeniería',
    url: '/servicios#diseno-ingenieria',
  },
];

// Criterios de aplicación de referencia (pg-dens)
const densidades = [
  ['Enfriamiento de transformador (agua pulverizada)', 'NFPA 850', '0.25 gpm/ft²'],
  ['Protección de turbina / aceite lubricante', 'NFPA 850', '0.25 gpm/ft²'],
  ['Galerías y charolas de cables', 'NFPA 850', '0.30 gpm/ft²'],
  ['Patio de combustible líquido (espuma)', 'NFPA 11', '0.10 gpm/ft²'],
];

const normativas = [
  { n: 'NFPA 850', d: 'Protección contra incendios en plantas de generación' },
  { n: 'NFPA 851', d: 'Plantas hidroeléctricas' },
  { n: 'NFPA 15', d: 'Sistemas fijos de agua pulverizada' },
  { n: 'NFPA 11', d: 'Sistemas de espuma para combustible líquido' },
  { n: 'NFPA 72', d: 'Detección y alarma de incendios' },
  { n: 'CFE', d: 'Requisitos técnicos de la Comisión Federal de Electricidad' },
  { n: 'NOM-001-SEDE', d: 'Instalaciones eléctricas (utilización)' },
  { n: 'NOM-002-STPS', d: 'Condiciones de seguridad — prevención de incendios' },
];

const errores = [
  'Tratar un incendio de aceite de transformador con chorro directo en vez de agua pulverizada',
  'Omitir el dique y el drenaje de aceite en el diseño del transformador',
  'No proteger las galerías de cables, ruta principal de propagación',
  'Ignorar el riesgo de hidrógeno en generadores enfriados por H₂',
  'Operar monitores manuales en patios energizados sin protocolo',
  'Subdimensionar el respaldo de agua para la disponibilidad 24/7',
];

const recomendaciones = [
  'Aplique agua pulverizada (no chorro) sobre transformadores y turbinas',
  'Integre dique, drenaje y separación de aceite desde el diseño',
  'Proteja galerías de cables con detección y sellos cortafuego',
  'Use monitores remotos en patios y áreas energizadas',
  'Diseñe conforme a NFPA 850 / 851 y a los requisitos CFE',
  'Considere la operación continua y el mantenimiento NFPA 25',
];

const faqs = [
  { q: '¿Por qué un incendio de transformador se combate con agua pulverizada y no con chorro?', a: 'El agua en forma de chorro sólido sobre aceite ardiendo puede dispersar el combustible y propagar el fuego, además del riesgo eléctrico. La estrategia conforme a NFPA 850 es un sistema de diluvio de agua pulverizada (water spray) que enfría la superficie del transformador y controla el incendio sin salpicar el aceite, complementado con dique y drenaje para contener y separar el aceite derramado. Se aplica con boquillas de aspersión fijas y monitores de apoyo.' },
  { q: '¿Qué normativa aplica a la protección contra incendios en centrales eléctricas?', a: 'La referencia principal es NFPA 850 (plantas de generación térmica) y NFPA 851 (plantas hidroeléctricas), complementadas con NFPA 15 (agua pulverizada), NFPA 11 (espuma para combustibles), NFPA 72 (detección) y los requisitos técnicos de la CFE, además de las normas oficiales mexicanas aplicables. AQUEON diseña conforme a este marco y entrega la documentación de cumplimiento.' },
  { q: '¿Cómo se protege un generador enfriado por hidrógeno?', a: 'El hidrógeno usado para enfriar grandes generadores es altamente inflamable y puede formar mezclas explosivas. La defensa combina detección de fugas, sistemas de purga e inertización para evacuar el hidrógeno de forma segura, y enfriamiento de las exposiciones desde posiciones protegidas con monitores remotos. El diseño se hace caso por caso según el equipo y las recomendaciones del fabricante.' },
  { q: '¿Por qué son críticas las galerías de cables?', a: 'Las charolas y bandejas de cables son una ruta de propagación rápida del fuego que puede dejar fuera de servicio sistemas de control y potencia de toda la planta. NFPA 850 exige protegerlas con detección temprana, sistemas de agua pulverizada y sellos cortafuego entre tramos y penetraciones. Integramos monitores automáticos y aspersión dirigida en estos puntos.' },
  { q: '¿Atienden tanto plantas de CFE como de productores independientes?', a: 'Sí. Atendemos centrales termoeléctricas, de ciclo combinado, hidroeléctricas, cogeneración y subestaciones, tanto de la CFE como de productores independientes y plantas industriales de autoabastecimiento, con equipos FM Approved y UL Listed y documentación para auditorías y aseguradoras.' },
  { q: '¿Qué equipos recomiendan para una subestación?', a: 'Una subestación con transformadores de potencia combina sistemas fijos de agua pulverizada sobre cada transformador, monitores remotos para enfriamiento de exposiciones y ataque sin exponer personal en el patio energizado, y detección conforme a NFPA 72. La configuración depende de la capacidad, el inventario de aceite y la separación entre equipos.' },
  { q: '¿AQUEON diseña e instala el sistema completo en una central?', a: 'Sí. Partimos del análisis de riesgo y de la normativa NFPA 850/851, definimos la protección por activo (transformadores, turbinas, cables, combustible), calculamos densidades de aplicación y caudales, y entregamos planos y memoria de cálculo. Después instalamos con técnicos certificados, probamos, ponemos en marcha y damos mantenimiento NFPA 25, con cobertura nacional y respeto a la disponibilidad 24/7 de la planta.' },
];
---
<Base
  title="Protección Contra Incendios para Generación de Energía | NFPA 850/851 y CFE | AQUEON México"
  description="Soluciones de monitores contra incendios para centrales eléctricas en México: termoeléctricas, ciclo combinado, hidroeléctricas y subestaciones. Protección de transformadores, turbinas y galerías de cables conforme a NFPA 850, NFPA 851 y requisitos CFE. Ingeniería e instalación con AQUEON."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/industrias">Industrias</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Generación de Energía</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Industrias · Generación de Energía</span>
          <h1>Protección Contra Incendios para Generación de Energía</h1>
        </div>
        <div class="section-header__body">
          <p>La <strong>infraestructura crítica</strong> que no puede detenerse: transformadores, turbinas y galerías de cables.</p>
          <p>Diseño conforme a <strong>NFPA 850, NFPA 851</strong> y requisitos <strong>CFE</strong>, con equipos certificados FM/UL.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El reto del sector</span>
          <h2>Cuando Apagar la Planta no es una Opción</h2>
          <p>
            La <strong>generación de energía</strong> es infraestructura crítica: un incendio no solo pone en riesgo equipos
            de altísimo valor y largo tiempo de reposición —un transformador de potencia puede tardar meses en
            reemplazarse— sino la continuidad del suministro eléctrico de regiones enteras. La protección debe contener el
            evento <strong>sin detener la operación ni comprometer la seguridad del personal</strong> en áreas energizadas.
          </p>
          <p>
            Cada activo plantea un reto distinto: el <strong>aceite</strong> de transformadores y turbinas exige agua
            pulverizada y contención, no chorro; el <strong>hidrógeno</strong> de enfriamiento de generadores impone control
            de explosión; las <strong>galerías de cables</strong> son la ruta de propagación más peligrosa; y el manejo de
            combustible o carbón suma los riesgos de derrame y polvo combustible.
          </p>
          <p>
            Por eso diseñamos conforme a <strong>NFPA 850 y NFPA 851</strong> y a los requisitos de la CFE. En esta página
            verá la protección por tipo de central, la estrategia para cada activo crítico, las soluciones AQUEON y los
            criterios de aplicación de referencia.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Tipos de central -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Mapa de riesgo</span>
          <h2>Protección por Tipo de Central</h2>
        </div>
        <div class="section-header__body">
          <p>Cada tecnología de generación —<strong>térmica, hidro, transmisión y distribuida</strong>— concentra riesgos distintos.</p>
          <p>Identificarlos define la <strong>estrategia de protección</strong> correcta.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {tipos.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-cubes" aria-hidden="true"></i> Activos típicos</span>
            <div class="l3-chips">
              {c.activos.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-fire" aria-hidden="true"></i> Riesgos principales</span>
            <div class="l3-chips">
              {c.riesgos.map((r) => <span class="l3-chip l3-chip--norm">{r}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Matriz de activos críticos -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Estrategia de respuesta</span>
          <h2>Activos Críticos y Cómo se Protegen</h2>
        </div>
        <div class="section-header__body">
          <p>Del transformador a la galería de cables, cada activo exige una <strong>estrategia de fuego propia</strong>.</p>
          <p>Esta matriz resume el enfoque de ingeniería que aplicamos a cada uno.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Activo</th>
              <th scope="col">Riesgo</th>
              <th scope="col">Estrategia</th>
              <th scope="col">Solución AQUEON</th>
            </tr>
          </thead>
          <tbody>
            {activos.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td>{e.estrategia}</td>
                <td class="pg-scen-sol">{e.solucion}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> La estrategia definitiva se establece en el análisis de riesgo y la memoria de cálculo conforme a NFPA 850 / 851.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Soluciones por activo -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Soluciones AQUEON</span>
          <h2>El Equipo Correcto para Cada Activo</h2>
        </div>
        <div class="section-header__body">
          <p>Combinamos monitores fijos, remotos, automáticos y aspersión en un <strong>sistema integral</strong>.</p>
          <p>Cada recomendación enlaza con la <strong>ficha técnica</strong> del equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {soluciones.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Criterios de aplicación -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Criterios de diseño</span>
          <h2>Criterios de Aplicación de Referencia</h2>
          <p>
            El dimensionamiento de la protección de una central parte de la <strong>densidad de aplicación</strong> que
            exige la norma para cada activo. Estos son valores orientativos conforme a NFPA 850 y NFPA 11; el diseño final
            se determina por cálculo hidráulico según el equipo, su inventario de aceite o combustible y la disposición de la
            planta.
          </p>
          <a href="/servicios#diseno-ingenieria" class="btn btn-outline"><i class="fas fa-compass-drafting" aria-hidden="true"></i> Ver servicio de ingeniería</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Aplicación</th><th scope="col">Norma</th><th scope="col">Densidad de referencia</th></tr>
            </thead>
            <tbody>
              {densidades.map(([a, n, d]) => (
                <tr><th scope="row">{a}</th><td>{n}</td><td>{d}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes en el sector</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones de ingeniería</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Especialistas en Protección para el Sector Eléctrico</h2>
          <p>
            En <strong>AQUEON</strong> diseñamos la protección de centrales partiendo del activo y de la normativa que lo
            rige. Somos distribuidores autorizados de Elkhart Brass, Akron Brass y Task Force Tips, y especificamos
            <strong>sistemas de agua pulverizada, monitores remotos y aspersión</strong> conforme a NFPA 850 y NFPA 851.
            Entregamos ingeniería, instalación certificada, pruebas, puesta en marcha y mantenimiento NFPA 25 respetando la
            disponibilidad 24/7 de la planta.
          </p>
          <p>
            Atendemos <strong>centrales de la CFE, productores independientes y plantas industriales de autoabastecimiento</strong>,
            con documentación completa para auditorías y aseguradoras, y cobertura en los 32 estados de la República desde la
            Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/nosotros" class="btn btn-outline-light"><i class="fas fa-building-shield" aria-hidden="true"></i> Conozca AQUEON</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Servicios de ingeniería</a>
