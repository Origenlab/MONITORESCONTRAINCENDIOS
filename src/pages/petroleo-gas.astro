---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: '50+', label: 'Instalaciones del sector petrolero' },
  { numero: '100%', label: 'Cumplimiento de especificación PEMEX' },
  { numero: 'ATEX', label: 'Equipos para zonas clasificadas' },
  { numero: '4,000', label: 'GPM de caudal disponible' },
];

const beneficios = [
  'Cumplimiento verificable de especificaciones PEMEX y aseguradoras',
  'Monitores remotos ATEX/IECEx para áreas clasificadas Clase I',
  'Sistemas de espuma NFPA 11 para incendios de hidrocarburos',
  'Cálculo hidráulico y densidades de aplicación por ingeniería',
  'Materiales 316L y bronce marino para ambientes corrosivos',
  'Documentación completa para auditorías de Protección Civil',
];

// DIFERENCIADOR 1 — Cadena de valor del sector
const cadena = [
  {
    id: 'upstream',
    eslabon: 'Upstream',
    titulo: 'Exploración y Producción',
    icon: 'fas fa-oil-well',
    descripcion: 'Cabezales de pozo, baterías de separación y plataformas costa afuera, donde la fuga presurizada de gas y crudo genera dardos de fuego e incendios de derrame.',
    activos: ['Cabezales de pozo', 'Baterías de separación', 'Plataformas offshore', 'Quemadores y desfogues'],
    riesgos: ['Dardo de fuego (jet fire)', 'Incendio de derrame'],
  },
  {
    id: 'midstream',
    eslabon: 'Midstream',
    titulo: 'Transporte y Almacenamiento',
    icon: 'fas fa-warehouse',
    descripcion: 'Terminales, patios de tanques, estaciones de bombeo y compresión. El gran inventario de producto concentra el riesgo de incendio de tanque y de sello en techos flotantes.',
    activos: ['Patios de tanques', 'Estaciones de bombeo', 'Estaciones de compresión', 'Ductos y racks'],
    riesgos: ['Incendio de tanque', 'Incendio de sello (rim-seal)', 'Incendio de derrame'],
  },
  {
    id: 'downstream',
    eslabon: 'Downstream',
    titulo: 'Refinación y Proceso',
    icon: 'fas fa-industry',
    descripcion: 'Refinerías, plantas de proceso de gas y unidades de fraccionamiento, con recipientes a presión cuya falla bajo fuego puede derivar en una BLEVE.',
    activos: ['Unidades de proceso', 'Plantas de gas / LNG', 'Esferas y recipientes a presión', 'Racks de tubería'],
    riesgos: ['BLEVE', 'Dardo de fuego', 'Nube de vapor inflamable'],
  },
];

// DIFERENCIADOR 2 — Matriz de escenarios de incendio
const escenarios = [
  {
    icon: 'fas fa-fire',
    nombre: 'Incendio de derrame (pool fire)',
    descripcion: 'Charco de hidrocarburo encendido en dique de contención o área de proceso.',
    estrategia: 'Extinción con espuma sobre la superficie y enfriamiento simultáneo de las exposiciones cercanas.',
    solucion: 'Monitor de alto caudal + cámara de espuma (NFPA 11)',
  },
  {
    icon: 'fas fa-ring',
    nombre: 'Incendio de sello (rim-seal)',
    descripcion: 'Fuego en el sello perimetral de un tanque de techo flotante.',
    estrategia: 'Aplicación de espuma de barrido perimetral o inyección subsuperficial, según diseño del tanque.',
    solucion: 'Sistema fijo de espuma asistido por monitor',
  },
  {
    icon: 'fas fa-bolt',
    nombre: 'Dardo de fuego (jet fire)',
    descripcion: 'Llama presurizada por fuga de gas o líquido en equipo a presión.',
    estrategia: 'Enfriamiento intensivo de la estructura expuesta; no se extingue hasta cortar el suministro de combustible.',
    solucion: 'Monitor remoto de agua de alto caudal (NFPA 15)',
  },
  {
    icon: 'fas fa-triangle-exclamation',
    nombre: 'Riesgo de BLEVE',
    descripcion: 'Recipiente a presión expuesto a fuego con riesgo de explosión por expansión de vapor.',
    estrategia: 'Enfriamiento masivo y preventivo del recipiente desde una posición segura y operado a distancia.',
    solucion: 'Monitor remoto ATEX MR-3000 / oscilante',
  },
];

// DIFERENCIADOR 3 — Soluciones AQUEON por activo (interlinking a L3 de producto)
const soluciones = [
  {
    icon: 'fas fa-database',
    titulo: 'Tanques y patios de almacenamiento',
    texto: 'Enfriamiento de exposiciones y aplicación de espuma sobre incendios de hidrocarburo con monitores de ultra-alto caudal.',
    producto: 'Monitor Magnum MG-4000',
    url: '/monitores-fijos#mg-4000',
  },
  {
    icon: 'fas fa-tower-broadcast',
    titulo: 'Áreas clasificadas y racks de proceso',
    texto: 'Ataque y enfriamiento sin exponer personal en zonas con vapores inflamables, operado desde sala de control.',
    producto: 'Monitor Remoto ATEX MR-3000',
    url: '/monitores-fijos#mr-3000',
  },
  {
    icon: 'fas fa-truck-droplet',
    titulo: 'Respuesta de brigada y puntos sin cobertura fija',
    texto: 'Despliegue rápido para complementar la red fija en mantenimientos, paros y maniobras de emergencia.',
    producto: 'Monitores Portátiles',
    url: '/monitores-portatiles',
  },
  {
    icon: 'fas fa-robot',
    titulo: 'Detección y respuesta autónoma',
    texto: 'Cuartos de bombas y casas de compresores con detección IR/IA y descarga automática dirigida al foco.',
    producto: 'Monitores Automáticos',
    url: '/monitores-automaticos',
  },
];

// Densidades de aplicación de referencia
const densidades = [
  ['Enfriamiento de tanque expuesto (agua)', 'NFPA 15', '0.10 – 0.25 gpm/ft²'],
  ['Espuma sobre derrame de hidrocarburo', 'NFPA 11', '0.10 gpm/ft² (mín.)'],
  ['Espuma en tanque de techo flotante (sello)', 'NFPA 11', 'Según método de aplicación'],
  ['Tiempo de descarga de espuma', 'NFPA 11', '30 – 65 min según riesgo'],
];

const normativas = [
  { n: 'PEMEX', d: 'Especificaciones técnicas de equipo y materiales' },
  { n: 'NFPA 11', d: 'Sistemas de espuma de baja, media y alta expansión' },
  { n: 'NFPA 15', d: 'Sistemas fijos de agua pulverizada' },
  { n: 'NFPA 30', d: 'Almacenamiento de líquidos inflamables y combustibles' },
  { n: 'NFPA 24', d: 'Redes privadas de servicio contra incendios' },
  { n: 'NFPA 25', d: 'Inspección, prueba y mantenimiento (ITM)' },
  { n: 'API 2021', d: 'Atención de incendios en tanques de almacenamiento' },
  { n: 'API 2030', d: 'Sistemas fijos de aspersión de agua' },
  { n: 'ATEX / IECEx', d: 'Equipo para atmósferas explosivas' },
  { n: 'NOM-002-STPS', d: 'Condiciones de seguridad — prevención de incendios' },
];

const errores = [
  'Diseñar el caudal sin un escenario de incendio definido por ingeniería',
  'Confundir estrategia: extinguir un dardo de gas en vez de enfriar y cortar suministro',
  'Omitir el sistema de espuma en riesgos de hidrocarburo (NFPA 11)',
  'Ubicar monitores manuales en zonas de radiación térmica intolerable',
  'Usar materiales no aptos para ambiente salino u offshore',
  'No prever el respaldo de agua/espuma para el tiempo de descarga normativo',
];

const recomendaciones = [
  'Parta del escenario de incendio de diseño y del cálculo hidráulico',
  'Combine enfriamiento (agua) y extinción (espuma) según el activo',
  'Especifique control remoto ATEX en áreas clasificadas y riesgo de BLEVE',
  'Verifique certificación FM/UL y cumplimiento de especificación PEMEX',
  'Defina materiales 316L o bronce marino según corrosión del sitio',
  'Integre el mantenimiento NFPA 25 desde la ingeniería de detalle',
];

const faqs = [
  { q: '¿Qué normativa rige la protección contra incendios en petróleo y gas en México?', a: 'El diseño se rige principalmente por las especificaciones técnicas de PEMEX y por el cuerpo normativo NFPA: NFPA 11 (espuma), NFPA 15 (agua pulverizada), NFPA 30 (almacenamiento de líquidos inflamables), NFPA 24 (redes) y NFPA 25 (mantenimiento), complementadas con las prácticas recomendadas API 2021 y API 2030, la NOM-002-STPS y los requisitos de las aseguradoras. En AQUEON entregamos la documentación de cumplimiento para auditorías de Protección Civil.' },
  { q: '¿Por qué se enfría un dardo de fuego (jet fire) en lugar de extinguirlo?', a: 'Un dardo de fuego es alimentado por una fuga presurizada de gas o líquido. Si se apaga la llama sin cortar el suministro, el gas sigue escapando y puede reacumularse y reignitar de forma explosiva. La estrategia correcta es enfriar intensamente la estructura y los recipientes expuestos para evitar una falla por radiación —y un posible BLEVE— mientras se aísla la fuente de combustible. Por eso priorizamos monitores de agua de alto caudal, idealmente remotos.' },
  { q: '¿Qué es una BLEVE y cómo se previene con monitores?', a: 'Una BLEVE (explosión por expansión de vapor de líquido en ebullición) ocurre cuando un recipiente a presión expuesto al fuego se debilita y falla catastróficamente. La defensa es el enfriamiento masivo y preventivo de la superficie del recipiente desde el inicio del evento, mantenido de forma continua. Los monitores remotos ATEX, como el MR-3000, permiten aplicar ese enfriamiento sin exponer al personal en la zona de riesgo.' },
  { q: '¿Necesito sistema de espuma además de los monitores de agua?', a: 'Sí, en la mayoría de los riesgos de hidrocarburo. El agua enfría exposiciones, pero un incendio de derrame o de tanque se extingue con una capa de espuma que sella la superficie del combustible bajo NFPA 11. El diseño define el concentrado (AFFF, AR-AFFF o espuma libre de flúor F3), la densidad de aplicación y el tiempo de descarga. AQUEON integra monitores, cámaras de espuma y proporcionadores como un solo sistema.' },
  { q: '¿Sus equipos cumplen con la especificación de PEMEX?', a: 'Sí. Suministramos monitores y accesorios con certificación FM Approved y/o UL Listed que cumplen con los requisitos técnicos de PEMEX, e integramos la documentación oficial para el expediente del proyecto. Atendemos refinerías, terminales de almacenamiento, plantas de proceso de gas e instalaciones offshore.' },
  { q: '¿Qué equipos recomiendan para una terminal de almacenamiento de hidrocarburos?', a: 'Un patio de tanques típicamente combina monitores de ultra-alto caudal (MG-4000) para enfriamiento de exposiciones y aplicación de espuma, monitores remotos ATEX (MR-3000) en áreas clasificadas, sistemas de espuma NFPA 11 por tanque y equipos portátiles para respuesta de brigada. La configuración final depende del diámetro de los tanques, el tipo de techo y el inventario de producto.' },
  { q: '¿Trabajan en plataformas e instalaciones costa afuera (offshore)?', a: 'Sí. Para ambiente marino especificamos materiales de acero inoxidable 316L y bronce marino con recubrimientos resistentes a la corrosión salina, y monitores remotos para operar desde posiciones seguras. El diseño contempla la severidad del entorno offshore y la disponibilidad limitada de agua y personal.' },
  { q: '¿AQUEON realiza el diseño e ingeniería del sistema?', a: 'Sí. Partimos del escenario de incendio de diseño, calculamos el caudal y la presión, definimos densidades de aplicación conforme a NFPA, seleccionamos los equipos y materiales, y entregamos planos y memoria de cálculo. Después instalamos con técnicos certificados, hacemos pruebas hidrostáticas, puesta en marcha y mantenimiento NFPA 25.' },
  { q: '¿En cuánto tiempo entregan una cotización para el sector petrolero?', a: 'Respondemos cotizaciones técnicas en menos de 24 horas hábiles. Para proyectos de mayor alcance agendamos una visita técnica sin costo para levantar el escenario de incendio, los activos a proteger y las condiciones del sitio, y proponer la configuración óptima.' },
];
---
<Base
  title="Protección Contra Incendios para Petróleo y Gas | Monitores PEMEX, ATEX y Espuma | AQUEON México"
  description="Soluciones de monitores contra incendios para la industria de petróleo y gas en México: refinerías, terminales de almacenamiento, plantas de gas y offshore. Equipos FM/UL con cumplimiento PEMEX, sistemas ATEX y espuma NFPA 11. Ingeniería, instalación y mantenimiento con AQUEON."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/industrias">Industrias</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Petróleo y Gas</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Industrias · Petróleo y Gas</span>
          <h1>Protección Contra Incendios para Petróleo y Gas</h1>
        </div>
        <div class="section-header__body">
          <p>El sector de <strong>mayor riesgo y mayor exigencia normativa</strong>: refinerías, terminales, plantas de gas e instalaciones costa afuera.</p>
          <p>Equipos <strong>FM Approved y UL Listed</strong> con cumplimiento PEMEX, sistemas ATEX y espuma NFPA 11, diseñados por ingeniería.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El reto del sector</span>
          <h2>Donde un Error de Diseño no es una Opción</h2>
          <p>
            La industria de <strong>petróleo y gas</strong> concentra los riesgos de incendio más severos de toda la
            actividad industrial: grandes inventarios de hidrocarburo, recipientes a presión, atmósferas con vapores
            inflamables y procesos que operan en los límites de temperatura y presión. Un evento mal contenido no se mide
            en daño material, sino en vidas, en impacto ambiental y en la continuidad de una operación crítica para el país.
          </p>
          <p>
            Por eso la protección contra incendios en este sector no se resuelve con catálogo, sino con
            <strong>ingeniería</strong>: definir el escenario de incendio de diseño, calcular el caudal y las densidades de
            aplicación, decidir entre enfriar o extinguir según el activo, y especificar equipos certificados que cumplan la
            especificación PEMEX y las prácticas API y NFPA. AQUEON acompaña ese proceso de principio a fin.
          </p>
          <p>
            En esta página encontrará cómo abordamos el riesgo a lo largo de la <strong>cadena de valor</strong>, la
            estrategia para cada escenario de incendio, las soluciones AQUEON por tipo de activo y el marco normativo
            aplicable en México.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Cadena de valor -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Mapa de riesgo</span>
          <h2>Protección a lo Largo de la Cadena de Valor</h2>
        </div>
        <div class="section-header__body">
          <p>Cada eslabón —<strong>upstream, midstream y downstream</strong>— enfrenta riesgos de incendio distintos.</p>
          <p>Identificarlos es el primer paso para una <strong>estrategia de protección correcta</strong>.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {cadena.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-cubes" aria-hidden="true"></i> Activos típicos</span>
            <div class="l3-chips">
              {c.activos.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-fire" aria-hidden="true"></i> Riesgos principales</span>
            <div class="l3-chips">
              {c.riesgos.map((r) => <span class="l3-chip l3-chip--norm">{r}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Matriz de escenarios -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Estrategia de respuesta</span>
          <h2>Escenarios de Incendio y Cómo se Combaten</h2>
        </div>
        <div class="section-header__body">
          <p>No todo fuego se apaga igual: la estrategia cambia según se trate de <strong>derrame, sello, dardo o BLEVE</strong>.</p>
          <p>Esta matriz resume el enfoque de ingeniería que aplicamos a cada caso.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Escenario</th>
              <th scope="col">Descripción</th>
              <th scope="col">Estrategia</th>
              <th scope="col">Solución AQUEON</th>
            </tr>
          </thead>
          <tbody>
            {escenarios.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td>{e.estrategia}</td>
                <td class="pg-scen-sol">{e.solucion}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> La estrategia definitiva siempre se establece en el análisis de riesgo y la memoria de cálculo del proyecto.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Soluciones por activo -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Soluciones AQUEON</span>
          <h2>El Equipo Correcto para Cada Activo</h2>
        </div>
        <div class="section-header__body">
          <p>Combinamos monitores fijos, remotos, portátiles y automáticos en un <strong>sistema integral</strong>.</p>
          <p>Cada recomendación enlaza con la <strong>ficha técnica</strong> del equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {soluciones.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Densidades de aplicación -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Criterios de diseño</span>
          <h2>Densidades de Aplicación de Referencia</h2>
          <p>
            El dimensionamiento de un sistema de protección para hidrocarburos parte de la
            <strong>densidad de aplicación</strong>: cuántos galones por minuto por pie cuadrado exige la norma para
            enfriar o extinguir un riesgo dado. Estos son valores orientativos; el diseño final se determina por cálculo
            hidráulico según el activo, el producto almacenado y las condiciones del sitio.
          </p>
          <a href="/servicios#diseno-ingenieria" class="btn btn-outline"><i class="fas fa-compass-drafting" aria-hidden="true"></i> Ver servicio de ingeniería</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Aplicación</th><th scope="col">Norma</th><th scope="col">Densidad de referencia</th></tr>
            </thead>
            <tbody>
              {densidades.map(([a, n, d]) => (
                <tr><th scope="row">{a}</th><td>{n}</td><td>{d}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes en el sector</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones de ingeniería</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Especialistas en Protección para la Industria Petrolera</h2>
          <p>
            En <strong>AQUEON</strong> somos distribuidores autorizados de Elkhart Brass, Akron Brass y Task Force Tips, y
            llevamos más de una década protegiendo <strong>refinerías, terminales de almacenamiento, plantas de proceso de
            gas e instalaciones offshore</strong> en México. Entregamos ingeniería de diseño conforme a NFPA y API,
            instalación con técnicos certificados, pruebas, puesta en marcha, capacitación y mantenimiento NFPA 25.
          </p>
          <p>
            Atendemos proyectos de <strong>PEMEX y de la iniciativa privada</strong> con documentación completa para
            auditorías de Protección Civil y aseguradoras internacionales, con cobertura en los 32 estados de la República
            desde la Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/nosotros" class="btn btn-outline-light"><i class="fas fa-building-shield" aria-hidden="true"></i> Conozca AQUEON</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Servicios de ingeniería</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Marco normativo aplicable</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
