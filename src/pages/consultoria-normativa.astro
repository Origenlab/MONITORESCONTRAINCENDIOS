---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: 'NOM-002', label: 'STPS — prevención de incendios' },
  { numero: 'NFPA', label: 'Marco técnico internacional' },
  { numero: 'FM Global', label: 'Requisitos de aseguradora' },
  { numero: 'Gap', label: 'Análisis de brechas y dictamen' },
];

const beneficios = [
  'Diagnóstico de cumplimiento (gap analysis) por norma',
  'Dictamen de cumplimiento con hallazgos y criticidad',
  'Plan de acción priorizado para cerrar brechas',
  'Expediente técnico listo para auditoría e inspección',
  'Gestión y respaldo ante aseguradoras y Protección Civil',
  'Actualización ante cambios normativos',
];

// DIFERENCIADOR 1 — Fases de la consultoría (pg-chain)
const fases = [
  {
    id: 'diagnostico',
    eslabon: 'Fase 01',
    titulo: 'Diagnóstico (Gap Analysis)',
    icon: 'fas fa-magnifying-glass-chart',
    descripcion: 'Comparamos su instalación y documentación contra la normativa aplicable para identificar todas las brechas de cumplimiento.',
    incluye: ['Levantamiento documental', 'Inspección en sitio', 'Brechas por norma', 'Nivel de criticidad'],
    entrega: 'Análisis de brechas',
  },
  {
    id: 'dictamen',
    eslabon: 'Fase 02',
    titulo: 'Dictamen de Cumplimiento',
    icon: 'fas fa-file-contract',
    descripcion: 'Emitimos un dictamen con el estado de cumplimiento, los hallazgos y su sustento normativo, claro y verificable.',
    incluye: ['Estado de cumplimiento', 'Hallazgos sustentados', 'Referencia normativa', 'Evidencia'],
    entrega: 'Dictamen técnico',
  },
  {
    id: 'plan',
    eslabon: 'Fase 03',
    titulo: 'Plan de Acción',
    icon: 'fas fa-list-check',
    descripcion: 'Definimos las acciones para cerrar cada brecha, priorizadas por riesgo y con responsables y tiempos.',
    incluye: ['Acciones por brecha', 'Priorización por riesgo', 'Responsables', 'Cronograma'],
    entrega: 'Plan priorizado',
  },
  {
    id: 'auditoria',
    eslabon: 'Fase 04',
    titulo: 'Acompañamiento en Auditoría',
    icon: 'fas fa-people-arrows',
    descripcion: 'Lo acompañamos ante la autoridad o la aseguradora con el expediente integrado y la defensa técnica del cumplimiento.',
    incluye: ['Expediente integrado', 'Defensa técnica', 'Atención a observaciones', 'Seguimiento'],
    entrega: 'Expediente de auditoría',
  },
];

// DIFERENCIADOR 2 — Marco normativo y obligaciones (pg-scen)
const marco = [
  {
    icon: 'fas fa-helmet-safety',
    nombre: 'NOM-002-STPS',
    descripcion: 'Condiciones de seguridad para prevención y protección contra incendios.',
    exige: 'Brigadas, equipo, simulacros y programa de seguridad.',
    aplica: 'Todo centro de trabajo',
  },
  {
    icon: 'fas fa-clipboard-check',
    nombre: 'NFPA 25',
    descripcion: 'Inspección, prueba y mantenimiento de sistemas a base de agua.',
    exige: 'Programa de ITM documentado por frecuencia.',
    aplica: 'Instalaciones con red contra incendio',
  },
  {
    icon: 'fas fa-compass-drafting',
    nombre: 'NFPA 11 / 15 / 24',
    descripcion: 'Diseño e instalación de espuma, agua pulverizada y redes.',
    exige: 'Sistemas calculados y conformes a norma.',
    aplica: 'Proyectos nuevos y modificaciones',
  },
  {
    icon: 'fas fa-building-shield',
    nombre: 'FM Global',
    descripcion: 'Hojas de datos y criterios de la aseguradora.',
    exige: 'Equipo aprobado y diseño conforme a Data Sheets.',
    aplica: 'Industria y almacenamiento asegurados',
  },
  {
    icon: 'fas fa-landmark',
    nombre: 'Programa Interno de PC',
    descripcion: 'Programa Interno de Protección Civil ante la autoridad.',
    exige: 'Documentación, análisis de riesgo y simulacros.',
    aplica: 'Inmuebles obligados por la ley',
  },
  {
    icon: 'fas fa-file-shield',
    nombre: 'Requisitos de aseguradora',
    descripcion: 'Condiciones de la póliza en materia de protección.',
    exige: 'Evidencia de mantenimiento y cumplimiento.',
    aplica: 'Instalaciones aseguradas',
  },
];

// DIFERENCIADOR 3 — Entregables (pg-sol)
const entregables = [
  {
    icon: 'fas fa-file-contract',
    titulo: 'Dictamen de cumplimiento',
    texto: 'Documento técnico con el estado de cumplimiento y los hallazgos sustentados por norma.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-table-list',
    titulo: 'Gap analysis',
    texto: 'Matriz de brechas entre su situación actual y la normativa aplicable, con criticidad.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-list-check',
    titulo: 'Plan de acción',
    texto: 'Acciones priorizadas por riesgo con responsables y tiempos para cerrar las brechas.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-folder-open',
    titulo: 'Expediente para auditoría',
    texto: 'Documentación integrada y ordenada para enfrentar una inspección o auditoría.',
    producto: 'Ver mantenimiento preventivo',
    url: '/mantenimiento-preventivo',
  },
  {
    icon: 'fas fa-building-shield',
    titulo: 'Gestión con aseguradora',
    texto: 'Respaldo técnico para satisfacer los requisitos de su póliza y mejorar condiciones.',
    producto: 'Ver industrias',
    url: '/industrias',
  },
  {
    icon: 'fas fa-rotate',
    titulo: 'Actualización normativa',
    texto: 'Seguimiento de cambios en normas y su impacto en su instalación.',
    producto: 'Ver diseño e ingeniería',
    url: '/diseno-ingenieria',
  },
];

// pg-dens — Hallazgos comunes en auditoría
const hallazgos = [
  ['Sin programa NFPA 25 documentado', 'Sistema sin verificación; riesgo en auditoría', 'Implementar programa ITM'],
  ['Equipo sin certificación verificable', 'Rechazo de aseguradora y autoridad', 'Sustituir por equipo FM/UL'],
  ['Falta de memoria de cálculo', 'Diseño no sustentado técnicamente', 'Elaborar ingeniería de respaldo'],
  ['Brigada sin capacitación / DC-3', 'Incumplimiento de NOM-002-STPS', 'Capacitar y certificar'],
  ['Expediente incompleto', 'Observaciones y sanciones en inspección', 'Integrar expediente técnico'],
];

const normativas = [
  { n: 'NOM-002-STPS', d: 'Prevención y protección contra incendios' },
  { n: 'NFPA 25', d: 'Inspección, prueba y mantenimiento' },
  { n: 'NFPA 11 / 15 / 24', d: 'Espuma, agua pulverizada y redes' },
  { n: 'FM Global', d: 'Criterios de aseguradora' },
  { n: 'Protección Civil', d: 'Programa Interno y normatividad local' },
  { n: 'NOM-100/101/102/103/104', d: 'Extintores y equipo (según aplique)' },
];

const errores = [
  'Esperar a la auditoría para revisar el cumplimiento',
  'Tratar la norma como trámite y no como gestión de riesgo',
  'Desconocer qué normas aplican a su instalación',
  'No documentar mantenimiento, diseño ni capacitación',
  'Ignorar los requisitos específicos de la aseguradora',
  'No actualizar el cumplimiento ante cambios normativos',
];

const recomendaciones = [
  'Realice un gap analysis antes de cualquier auditoría',
  'Trate el cumplimiento como gestión continua del riesgo',
  'Identifique con claridad las normas aplicables a su giro',
  'Documente diseño, mantenimiento y capacitación',
  'Atienda los requisitos de su aseguradora desde el inicio',
  'Actualice el expediente ante cada cambio normativo',
];

const faqs = [
  { q: '¿Qué normas aplican a la protección contra incendios en mi instalación?', a: 'Depende de su giro y su riesgo, pero el marco típico combina la NOM-002-STPS (prevención de incendios y brigadas, obligatoria para todo centro de trabajo), el cuerpo normativo NFPA (NFPA 25 para mantenimiento, NFPA 11/15/24 para diseño e instalación), los criterios de FM Global cuando hay aseguradora, y el Programa Interno de Protección Civil ante la autoridad. Parte de nuestra consultoría es precisamente identificar con claridad qué le aplica y por qué.' },
  { q: '¿Qué es un gap analysis de cumplimiento?', a: 'Es un análisis de brechas: comparamos el estado real de su instalación y su documentación contra lo que exige cada norma aplicable, e identificamos todo lo que falta o no cumple, clasificado por criticidad. El resultado es un mapa claro de dónde está usted y qué le separa del cumplimiento total, que se traduce en un plan de acción priorizado. Es la base de cualquier proceso serio de cumplimiento.' },
  { q: '¿Me ayudan a prepararme para una auditoría o inspección?', a: 'Sí. Integramos el expediente técnico —diseño, memorias de cálculo, mantenimiento NFPA 25, capacitación, certificaciones del equipo— y lo acompañamos ante la autoridad o la aseguradora con la defensa técnica del cumplimiento. La diferencia entre aprobar y reprobar una auditoría suele estar en la documentación y en saber sustentarla; en eso lo respaldamos.' },
  { q: '¿La consultoría me sirve para mejorar las condiciones de mi póliza?', a: 'Frecuentemente sí. Las aseguradoras evalúan el riesgo a partir del cumplimiento y la documentación. Un expediente sólido —equipo aprobado, diseño sustentado, mantenimiento al día— no solo reduce el riesgo real: respalda su póliza y puede mejorar las condiciones de cobertura. Gestionamos ese respaldo técnico con su aseguradora.' },
  { q: '¿Qué entregables recibo de la consultoría?', a: 'Recibe un dictamen de cumplimiento, la matriz de gap analysis con la criticidad de cada brecha, un plan de acción priorizado con responsables y tiempos, y el expediente técnico integrado para auditoría. Si lo requiere, damos seguimiento al cierre de las brechas con los demás servicios —diseño, instalación, mantenimiento y capacitación— como un solo proveedor.' },
  { q: '¿Cada cuánto debo revisar mi cumplimiento?', a: 'El cumplimiento no es un estado fijo: las normas se actualizan, la instalación cambia y los requisitos de la aseguradora evolucionan. Recomendamos una revisión anual y, especialmente, ante cualquier modificación del sistema, cambio de actividad o renovación de póliza. Podemos integrar la actualización normativa a su programa anual.' },
  { q: '¿Solo dictaminan o también cierran las brechas?', a: 'Ambas cosas. A diferencia de un consultor que solo entrega un dictamen y se retira, en AQUEON podemos cerrar las brechas que identificamos: rediseñar, suministrar equipo certificado, instalar, dar mantenimiento y capacitar. Un solo responsable del diagnóstico a la solución, lo que hace el cumplimiento mucho más ágil y verificable.' },
];
---
<Base
  title="Consultoría Normativa Contra Incendios | NOM-002-STPS, NFPA y FM Global | AQUEON México"
  description="Consultoría normativa en protección contra incendios: diagnóstico de cumplimiento (gap analysis), dictamen, plan de acción y acompañamiento en auditorías conforme a NOM-002-STPS, NFPA y FM Global. Expediente listo para autoridad y aseguradoras con AQUEON México."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/servicios">Servicios</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Consultoría Normativa</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Servicios · Consultoría Normativa</span>
          <h1>Consultoría Normativa Contra Incendios</h1>
        </div>
        <div class="section-header__body">
          <p>El cumplimiento no se improvisa en la auditoría: se <strong>construye y se documenta</strong> antes.</p>
          <p>Diagnóstico de brechas, dictamen y plan de acción conforme a <strong>NOM-002-STPS, NFPA y FM Global</strong>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El servicio</span>
          <h2>Cumplir no es un Trámite: es Gestionar el Riesgo</h2>
          <p>
            En protección contra incendios, el cumplimiento normativo no es papeleo: es la evidencia de que el riesgo está
            realmente bajo control. Una <strong>auditoría reprobada</strong>, una <strong>póliza en disputa</strong> o una
            <strong>sanción de la autoridad</strong> casi nunca se deben a falta de equipo, sino a un cumplimiento que nadie
            verificó ni documentó a tiempo. Lo que no se sustenta, no existe ante la autoridad ni ante la aseguradora.
          </p>
          <p>
            La consultoría normativa de AQUEON parte de un <strong>diagnóstico de brechas (gap analysis)</strong> contra las
            normas que realmente le aplican —NOM-002-STPS, NFPA, FM Global, Protección Civil—, emite un
            <strong>dictamen de cumplimiento</strong> y un <strong>plan de acción priorizado</strong>, y lo acompaña en la
            auditoría. Y, a diferencia de un consultor que solo dictamina, podemos cerrar las brechas: somos un solo
            proveedor del diagnóstico a la solución.
          </p>
          <p>
            En esta página verá las fases de la consultoría, el marco normativo y sus obligaciones, los entregables y los
            hallazgos más comunes en una auditoría.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Fases -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Metodología</span>
          <h2>Las Fases de la Consultoría</h2>
        </div>
        <div class="section-header__body">
          <p>Del <strong>gap analysis</strong> al <strong>acompañamiento en auditoría</strong>, un proceso ordenado.</p>
          <p>Cada fase con su entregable, para que el cumplimiento sea demostrable.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {fases.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-list-ul" aria-hidden="true"></i> Incluye</span>
            <div class="l3-chips">
              {c.incluye.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-box-open" aria-hidden="true"></i> Entregable</span>
            <div class="l3-chips">
              <span class="l3-chip l3-chip--norm">{c.entrega}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Marco normativo -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">El mapa de cumplimiento</span>
          <h2>Marco Normativo y Obligaciones</h2>
        </div>
        <div class="section-header__body">
          <p>Saber <strong>qué exige cada norma</strong> y a quién aplica es el primer paso para cumplir.</p>
          <p>Este es el marco con el que evaluamos su instalación.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Norma / referencia</th>
              <th scope="col">De qué trata</th>
              <th scope="col">Qué exige</th>
              <th scope="col">A quién aplica</th>
            </tr>
          </thead>
          <tbody>
            {marco.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td class="pg-scen-sol">{e.exige}</td>
                <td>{e.aplica}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> El marco aplicable se confirma en el diagnóstico según el giro, el riesgo y la jurisdicción de su instalación.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Entregables -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Entregables</span>
          <h2>Qué Recibe de la Consultoría</h2>
        </div>
        <div class="section-header__body">
          <p>Documentos que <strong>sustentan su cumplimiento</strong> ante la autoridad y la aseguradora.</p>
          <p>Cada entregable enlaza con el servicio que cierra la brecha.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {entregables.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- pg-dens: Hallazgos comunes -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Lo que encontramos</span>
          <h2>Hallazgos Comunes en Auditoría</h2>
          <p>
            La mayoría de los incumplimientos se repiten de una instalación a otra. Conocerlos por adelantado permite
            cerrarlos antes de que la autoridad o la aseguradora los señalen. Estos son los <strong>hallazgos más
            frecuentes</strong>, su riesgo y la acción que recomendamos.
          </p>
          <a href="/contacto" class="btn btn-outline"><i class="fas fa-file-contract" aria-hidden="true"></i> Solicitar diagnóstico</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Brecha frecuente</th><th scope="col">Riesgo</th><th scope="col">Acción</th></tr>
            </thead>
            <tbody>
              {hallazgos.map(([b, r, a]) => (
                <tr><th scope="row">{b}</th><td>{r}</td><td class="pg-dens-ok">{a}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>El Único que Dictamina y También Resuelve</h2>
          <p>
            En <strong>AQUEON</strong> la consultoría normativa no termina en un dictamen: es la puerta de entrada a la
            solución. Identificamos las brechas con un <strong>gap analysis</strong> riguroso, las priorizamos por riesgo y,
            como somos un solo proveedor de <strong>diseño, equipo, instalación, mantenimiento y capacitación</strong>,
            podemos cerrarlas nosotros mismos. Un solo responsable del diagnóstico al cumplimiento verificado.
          </p>
          <p>
            Asesoramos a <strong>refinerías, plantas, parques industriales, aeropuertos, minería y gobierno</strong> ante la
            autoridad y las aseguradoras, con expediente completo y cobertura en los 32 estados de la República desde la
            Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/diseno-ingenieria" class="btn btn-outline-light"><i class="fas fa-compass-drafting" aria-hidden="true"></i> Diseño e ingeniería</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Todos los servicios</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Normas de referencia</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Consultoría Normativa" contexto="el servicio de consultoría normativa y cumplimiento" faqs={faqs} />

  <!-- Otros servicios -->
  <section class="l3-otras">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Ciclo Completo</span>
          <h2>Otros Servicios AQUEON</h2>
        </div>
        <div class="section-header__body">
          <p>Del diseño al mantenimiento, cubrimos <strong>todo el ciclo de vida</strong> de su sistema.</p>
          <p>Un solo proveedor con ingeniería, obra y soporte de por vida.</p>
        </div>
      </div>
      <div class="l3-otras-grid">
        <a href="/diseno-ingenieria" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-compass-drafting" aria-hidden="true"></i></span><span class="l3-otra-name">Diseño e Ingeniería</span><span class="l3-otra-sub">Cálculo hidráulico · planos</span></a>
