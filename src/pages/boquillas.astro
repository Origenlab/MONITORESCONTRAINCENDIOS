---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const productos = [
  {
    id: 'bm-200',
    modelo: 'BM-200',
    nombre: 'Boquilla Multipatrón BM-200',
    badge: 'Más Versátil',
    badgePremium: true,
    icon: 'fas fa-shower',
    imagen: '/images/diseno-ingenieria-sistemas-monitores-contra-incendios.webp',
    resumen: 'Boquilla ajustable de bronce con patrón desde chorro sólido hasta niebla, compatible con monitores de 2.5" a 4".',
    descripcion: 'La boquilla es el componente que convierte el caudal en una herramienta de combate. La BM-200 permite al operador pasar de un chorro sólido de largo alcance —para atacar el foco a distancia— a un patrón de niebla que absorbe calor y protege al personal, todo girando un anillo. Construida en bronce para máxima durabilidad, es la opción universal para la mayoría de los monitores industriales.',
    specs: [
      ['Caudal de operación', '200 – 1,000 GPM'],
      ['Ajuste de patrón', '0° (chorro) a 120° (niebla)'],
      ['Compatibilidad', 'Monitores de 2.5" a 4"'],
      ['Material de construcción', 'Bronce marino'],
      ['Tipo', 'Multipatrón ajustable'],
      ['Certificación', 'UL Listed'],
    ],
    aplicaciones: ['Ataque directo', 'Cortina de protección', 'Enfriamiento', 'Uso general industrial'],
  },
  {
    id: 'ce-500',
    modelo: 'CE-500',
    nombre: 'Cámara de Espuma CE-500',
    badge: 'Hidrocarburos',
    badgePremium: false,
    icon: 'fas fa-flask',
    imagen: '/images/monitores-contra-incendios-refineria-petroleo-gas.webp',
    resumen: 'Cámara de inyección de espuma para monitores y tanques, con dosificación exacta al 3% o 6% según el riesgo de hidrocarburos.',
    descripcion: 'Sin espuma, el agua no extingue un incendio de hidrocarburos. La CE-500 es el componente que introduce y mezcla el concentrado espumante en la corriente de agua a la proporción exacta —3% o 6%— para generar la manta que sella los vapores. Fabricada en acero inoxidable y conforme a NFPA 11, es esencial en la protección de tanques de almacenamiento, racks de carga y áreas de proceso.',
    specs: [
      ['Concentración', '3% o 6% (seleccionable)'],
      ['Función', 'Inyección y mezcla de espumante'],
      ['Compatibilidad', 'Monitores y cámaras de tanque'],
      ['Material de construcción', 'Acero inoxidable'],
      ['Agentes', 'AFFF · AR-AFFF · F3'],
      ['Certificación', 'NFPA 11'],
    ],
    aplicaciones: ['Tanques de combustible', 'Racks de carga', 'Hidrocarburos', 'Áreas de proceso'],
  },
  {
    id: 'kc-pro',
    modelo: 'KC-PRO',
    nombre: 'Kit de Conexiones KC-PRO',
    badge: 'Instalación',
    badgePremium: false,
    icon: 'fas fa-link',
    imagen: '/images/instalacion-monitores-contra-incendios-industriales.webp',
    resumen: 'Kit completo de bridas, codos, reducciones y juntas de expansión de alta presión para integrar el monitor a la red hidráulica.',
    descripcion: 'Un monitor solo es tan confiable como su conexión a la red. El KC-PRO reúne en un solo paquete las bridas, codos, reducciones y juntas de expansión de alta presión necesarias para integrar el equipo a la tubería existente, absorber dilataciones y garantizar estanqueidad. Disponible en acero y bronce, simplifica la instalación y asegura el cumplimiento de NFPA 24.',
    specs: [
      ['Diámetros', '2.5" a 6"'],
      ['Presión de trabajo', 'Hasta 300 PSI'],
      ['Incluye', 'Bridas · codos · reducciones · juntas'],
      ['Material de construcción', 'Acero / bronce'],
      ['Función', 'Integración a red hidráulica'],
      ['Referencia normativa', 'NFPA 24'],
    ],
    aplicaciones: ['Instalación de monitores', 'Adecuación de red', 'Juntas de expansión', 'Mantenimiento'],
  },
];

const stats = [
  { numero: '200–1,000', label: 'GPM en boquillas' },
  { numero: '3% / 6%', label: 'Dosificación de espuma' },
  { numero: '300 PSI', label: 'Conexiones de alta presión' },
  { numero: 'UL · NFPA', label: 'Componentes certificados' },
];

const anatomia = [
  { icon: 'fas fa-arrow-right-to-bracket', titulo: 'Entrada y conexión', texto: 'Bridas, codos y juntas (KC-PRO) integran el monitor a la red privada y absorben dilataciones.' },
  { icon: 'fas fa-flask', titulo: 'Proporcionamiento', texto: 'La cámara de espuma (CE-500) inyecta y mezcla el concentrado a la proporción exacta para hidrocarburos.' },
  { icon: 'fas fa-shower', titulo: 'Boquilla de descarga', texto: 'La boquilla (BM-200) define el patrón —chorro o niebla— y el alcance del agua o la espuma.' },
  { icon: 'fas fa-fire', titulo: 'Aplicación sobre el riesgo', texto: 'El conjunto entrega el agente en la densidad y forma que exige la norma y el escenario.' },
];

const beneficios = [
  'Optimizan la eficiencia del monitor y el aprovechamiento del agua',
  'Habilitan la protección de hidrocarburos mediante espuma',
  'Aseguran una integración hermética y normada a la red',
  'Permiten adaptar un mismo monitor a distintos escenarios',
  'Reducen tiempos de instalación y mantenimiento',
  'Componentes certificados para auditorías y aseguradoras',
];

const errores = [
  'Comprar el monitor y descuidar la boquilla, que define el patrón real',
  'Omitir el sistema de espuma en riesgos de hidrocarburos',
  'Usar conexiones sin junta de expansión y provocar fugas por dilatación',
  'Seleccionar materiales incompatibles con el ambiente o el agente',
  'No verificar la proporción de espuma (3% vs 6%) según el combustible',
  'Improvisar adaptadores en lugar de un kit normado de conexiones',
];

const recomendaciones = [
  'Especifique la boquilla junto con el monitor, no como accesorio aparte',
  'Defina el agente espumante y la proporción según el tipo de hidrocarburo',
  'Use kits de conexión normados con juntas de expansión',
  'Verifique compatibilidad de diámetros y presiones con su red',
  'Incluya los accesorios en el plan de mantenimiento NFPA 25',
  'Solicite un diseño integral monitor + accesorios a ingeniería',
];

const seleccion = [
  ['Ataque y enfriamiento general', 'BM-200', 'Patrón ajustable chorro/niebla'],
  ['Tanques e hidrocarburos', 'CE-500', 'Inyección de espuma 3%/6%'],
  ['Integración a la red', 'KC-PRO', 'Bridas, codos y juntas normadas'],
  ['Adaptar un monitor existente', 'BM-200 + KC-PRO', 'Nueva boquilla y conexión'],
  ['Cumplimiento de aseguradora', 'Todos certificados', 'UL / NFPA documentado'],
];

const faqs = [
  { q: '¿Por qué la boquilla es tan importante en un monitor?', a: 'Porque es el componente que convierte el caudal en una herramienta útil. La misma cantidad de agua puede aplicarse como chorro sólido de largo alcance o como niebla que absorbe calor; la boquilla determina ese patrón, el alcance y la eficiencia. Un monitor excelente con una boquilla inadecuada desperdicia agua y reduce su capacidad de combate.' },
  { q: '¿Qué es una boquilla multipatrón?', a: 'Es una boquilla que permite ajustar la forma del chorro —de sólido a niebla— girando un anillo, sin cambiar de equipo. La BM-200 ofrece de 0° a 120°, lo que da al operador flexibilidad para atacar el foco a distancia o crear una cortina de protección, según evolucione el incendio.' },
  { q: '¿Para qué sirve una cámara de espuma?', a: 'La cámara de espuma inyecta y mezcla el concentrado espumante en la corriente de agua a la proporción correcta (3% o 6%). El resultado es una solución que, al descargarse, forma una manta que sella los vapores del combustible. Es indispensable en incendios de hidrocarburos, donde el agua sola no extingue. Conozca también nuestros sistemas de espuma con monitores.' },
  { q: '¿Cuál es la diferencia entre espuma al 3% y al 6%?', a: 'Indica cuántas partes de concentrado se mezclan por cada 100 partes de solución. Un concentrado al 3% requiere la mitad de producto que uno al 6% para el mismo volumen de solución, lo que reduce el almacenamiento. La elección depende del combustible, el tipo de concentrado y el diseño del sistema bajo NFPA 11.' },
  { q: '¿Qué incluye un kit de conexiones para monitores?', a: 'El KC-PRO reúne bridas, codos, reducciones y juntas de expansión de alta presión necesarias para integrar el monitor a la red hidráulica. Las juntas de expansión son clave: absorben la dilatación térmica de la tubería y evitan fugas o esfuerzos sobre el equipo, garantizando una instalación hermética conforme a NFPA 24.' },
  { q: '¿Los accesorios son compatibles con cualquier monitor?', a: 'La mayoría de boquillas y conexiones se fabrican en diámetros estándar (2.5" a 6") compatibles con monitores fijos y portátiles. Aun así, conviene validar la compatibilidad de rosca/brida, presión y agente con el equipo específico. Nuestros ingenieros verifican la compatibilidad como parte del diseño.' },
  { q: '¿Qué material conviene para las boquillas y conexiones?', a: 'El bronce ofrece excelente durabilidad y resistencia a la corrosión a costo competitivo; el acero inoxidable es preferible en ambientes salinos o con químicos agresivos. La cámara de espuma suele ser de acero inoxidable por el contacto con concentrados. La selección depende del ambiente y del agente.' },
  { q: '¿Los accesorios requieren mantenimiento?', a: 'Sí. Boquillas, cámaras de espuma y conexiones forman parte del sistema y se inspeccionan bajo NFPA 25: se verifica el libre movimiento de las boquillas, la integridad de las juntas y la calidad de la espuma. Nuestro servicio de mantenimiento preventivo los incluye con reportes documentados.' },
  { q: '¿AQUEON diseña el conjunto completo monitor + accesorios?', a: 'Sí. No vendemos accesorios sueltos: diseñamos el sistema integral —monitor, boquilla, proporcionamiento de espuma y conexiones— conforme a NFPA y a los requisitos de PEMEX y aseguradoras, con la documentación técnica completa.' },
  { q: '¿En cuánto tiempo entregan una cotización?', a: 'Respondemos cotizaciones técnicas en menos de 24 horas hábiles. Mantenemos stock de accesorios en México para entrega ágil y, si lo requiere, levantamos en sitio la adecuación necesaria sin costo.' },
];
---
<Base
  title="Boquillas y Accesorios para Monitores Contra Incendios | Espuma y Conexiones | AQUEON México"
  description="Boquillas multipatrón, cámaras de espuma y kits de conexión para monitores contra incendios: BM-200, CE-500 y KC-PRO. Certificados UL y NFPA 11. Diseño integral de sistemas de protección en México con AQUEON."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/productos">Productos</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Boquillas y Accesorios</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Catálogo · Boquillas y Accesorios</span>
          <h1>Boquillas y Accesorios para Monitores</h1>
        </div>
        <div class="section-header__body">
          <p>Los componentes que <strong>completan el sistema</strong>: definen el patrón, habilitan la espuma e integran el monitor a su red.</p>
          <p>Boquillas, cámaras de espuma y conexiones <strong>certificadas UL y NFPA 11</strong>, con diseño integral de AQUEON.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">¿Por qué importan los accesorios?</span>
          <h2>El Detalle que Decide el Desempeño</h2>
          <p>
            Un monitor contra incendios no trabaja solo. Entre el caudal que llega de la red y el agua o la espuma que cae
            sobre el fuego hay una cadena de componentes —<strong>conexiones, proporcionamiento y boquilla</strong>— que
            determinan si el sistema cumple o falla. Es frecuente ver instalaciones con un monitor excelente y una boquilla
            inadecuada que desperdicia caudal o un sistema sin espuma en un riesgo de hidrocarburos.
          </p>
          <p>
            Los accesorios son, en realidad, parte del corazón del sistema. La <strong>boquilla</strong> define el patrón y
            el alcance; la <strong>cámara de espuma</strong> habilita la protección de
            <a href="/industrias#petroleo-gas">hidrocarburos</a>; y el <strong>kit de conexiones</strong> garantiza una
            integración hermética y normada a la red. Especificarlos bien es tan importante como elegir el monitor.
          </p>
          <p>
            En AQUEON no vendemos accesorios sueltos: diseñamos el conjunto completo, del <a href="/monitores-fijos">monitor</a>
            a la boquilla, conforme a NFPA y a los requisitos de las aseguradoras. En esta página encontrará los tres
            componentes principales, sus especificaciones y la guía para seleccionarlos con criterio de ingeniería.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Anatomía del sistema (diferenciador de esta L3) -->
  <section class="l3-proceso">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Anatomía del Sistema</span>
          <h2>Del Caudal al Fuego: Cómo Encaja Cada Componente</h2>
        </div>
        <div class="section-header__body">
          <p>Cada accesorio cumple una función en la <strong>cadena de descarga</strong>. Juntos definen el desempeño real.</p>
          <p>Diseñarlos como conjunto —no por separado— es lo que <strong>garantiza el cumplimiento</strong>.</p>
        </div>
      </div>
      <div class="l3-proceso-grid">
        {anatomia.map((t, idx) => (
          <div class="l3-step">
            <span class="l3-step-num">{String(idx + 1).padStart(2, '0')}</span>
            <span class="l3-step-icon" aria-hidden="true"><i class={t.icon}></i></span>
            <h3>{t.titulo}</h3>
            <p>{t.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Productos -->
  <section class="l3-modelos">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Nuestros Componentes</span>
          <h2>Tres Piezas Clave del Sistema</h2>
        </div>
        <div class="section-header__body">
          <p>De la boquilla multipatrón a la cámara de espuma y el kit de conexiones, cada uno <strong>resuelve una función</strong>.</p>
          <p>Todos <strong>certificados</strong> y diseñados para integrarse a su monitor.</p>
        </div>
      </div>

      {productos.map((m, i) => (
        <article id={m.id} class:list={['l3-model', i % 2 === 1 && 'l3-model--rev']}>
          <div class="l3-model-media">
            <img src={m.imagen} alt={`${m.nombre} — accesorio para monitores contra incendios AQUEON`} loading="lazy" />
            <span class:list={['l3-model-badge', m.badgePremium && 'is-premium']}><i class={m.icon} aria-hidden="true"></i> {m.badge}</span>
          </div>
          <div class="l3-model-content">
            <span class="l3-model-kicker">{m.modelo}</span>
            <h3>{m.nombre}</h3>
            <p class="l3-model-resumen">{m.resumen}</p>
            <p>{m.descripcion}</p>

            <table class="l3-spec-table">
              <tbody>
                {m.specs.map(([k, v]) => (
                  <tr><th scope="row">{k}</th><td>{v}</td></tr>
                ))}
              </tbody>
            </table>

            <div class="l3-model-apps">
              <span class="l3-apps-label"><i class="fas fa-location-dot" aria-hidden="true"></i> Aplicaciones</span>
              <div class="l3-chips">
                {m.aplicaciones.map((a) => <span class="l3-chip">{a}</span>)}
              </div>
            </div>

            <div class="l3-model-actions">
              <a href="/contacto" class="btn btn-primary"><i class="fas fa-file-invoice" aria-hidden="true"></i> Cotizar el {m.modelo}</a>
              <a href={`https://wa.me/5215512345678?text=Hola%20AQUEON%2C%20me%20interesa%20el%20accesorio%20${m.modelo}`} class="btn btn-outline" target="_blank" rel="noopener"><i class="fab fa-whatsapp" aria-hidden="true"></i> WhatsApp</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Tabla de selección -->
  <section class="l3-compare">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Guía de Selección</span>
          <h2>¿Qué Accesorio Necesita su Sistema?</h2>
        </div>
        <div class="section-header__body">
          <p>Una referencia rápida según la <strong>función a resolver</strong> en su instalación.</p>
          <p>Lo ideal es un <strong>diseño integral</strong>: monitor y accesorios como un solo conjunto.</p>
        </div>
      </div>
      <div class="l3-compare-wrap">
        <table class="l3-compare-table">
          <thead>
            <tr><th scope="col">Necesidad</th><th scope="col">Componente</th><th scope="col">Por qué</th></tr>
          </thead>
          <tbody>
            {seleccion.map(([esc, mod, por]) => (
              <tr><th scope="row">{esc}</th><td>{mod}</td><td>{por}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes al especificar</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones para empresas</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Diseño Integral, No Accesorios Sueltos</h2>
          <p>
            En <strong>AQUEON</strong> entendemos los accesorios como lo que son: parte del corazón del sistema. Por eso
            diseñamos el conjunto completo —monitor, boquilla, proporcionamiento de espuma y conexiones— como una unidad
            coherente, distribuyendo componentes certificados de Elkhart Brass, Akron Brass, Task Force Tips, Williams Fire
            y Angus Fire. Entregamos ingeniería, instalación, mantenimiento NFPA 25 y documentación completa, con cobertura
            nacional desde la Ciudad de México.
          </p>
          <p>
            Atendemos proyectos de <strong>PEMEX, CFE, refinerías, petroquímica, parques industriales y corporativos</strong>,
            asegurando la compatibilidad y el cumplimiento de cada componente. Somos uno de los principales especialistas en
            monitores contra incendios industriales en México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Servicios de ingeniería</a>
            <a href="/contacto" class="btn btn-outline-light"><i class="fas fa-file-invoice" aria-hidden="true"></i> Solicitar asesoría</a>
          </div>
        </div>
        <div class="l3-normativas">
          <h3>Normativas aplicables</h3>
          <div class="l3-chips">
            <span class="l3-chip l3-chip--norm">UL Listed</span>
            <span class="l3-chip l3-chip--norm">NFPA 11</span>
            <span class="l3-chip l3-chip--norm">NFPA 15</span>
            <span class="l3-chip l3-chip--norm">NFPA 24</span>
            <span class="l3-chip l3-chip--norm">NFPA 25</span>
            <span class="l3-chip l3-chip--norm">FM Approved</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Boquillas y Accesorios" contexto="boquillas y accesorios para monitores" faqs={faqs} />

  <!-- Otras categorías -->
  <section class="l3-otras">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Catálogo Completo</span>
          <h2>Otras Categorías de Producto</h2>
        </div>
        <div class="section-header__body">
          <p>Los accesorios completan cualquier <strong>monitor fijo, portátil o automático</strong> de la línea AQUEON.</p>
          <p>Una sola fuente para todo su sistema de protección contra incendios.</p>
        </div>
      </div>
      <div class="l3-otras-grid">
        <a href="/monitores-fijos" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-fire-extinguisher" aria-hidden="true"></i></span><span class="l3-otra-name">Monitores Fijos</span><span class="l3-otra-sub">Protección permanente 24/7</span></a>
        <a href="/monitores-portatiles" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-truck-loading" aria-hidden="true"></i></span><span class="l3-otra-name">Monitores Portátiles</span><span class="l3-otra-sub">Despliegue rápido para brigadas</span></a>
        <a href="/monitores-automaticos" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-robot" aria-hidden="true"></i></span><span class="l3-otra-name">Monitores Automáticos</span><span class="l3-otra-sub">Detección IA · IR · oscilantes</span></a>
        <a href="/productos" class="l3-otra l3-otra--all"><span class="l3-otra-icon"><i class="fas fa-layer-group" aria-hidden="true"></i></span><span class="l3-otra-name">Ver todo el catálogo</span><span class="l3-otra-sub">12 equipos certificados</span></a>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="l3-cta">
    <div class="container">
      <div class="l3-cta-inner">
        <div>
          <h2>¿Listo para completar su sistema?</h2>
