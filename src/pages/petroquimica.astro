---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: '316L', label: 'Materiales anticorrosivos de serie' },
  { numero: 'Zona 0·1·2', label: 'Áreas clasificadas ATEX / IECEx' },
  { numero: 'AR-AFFF', label: 'Espuma para solventes polares' },
  { numero: 'NFPA 30·652', label: 'Líquidos inflamables y polvo combustible' },
];

const beneficios = [
  'Materiales 316L y recubrimientos para ambientes corrosivos',
  'Equipos ATEX/IECEx para Zonas 0, 1 y 2 con vapores inflamables',
  'Selección de agente espumante según la química del producto',
  'Protección de reactores, columnas, racks y áreas de carga',
  'Atención a polvo combustible (NFPA 652) en plásticos y polímeros',
  'Documentación de cumplimiento para auditorías y aseguradoras',
];

// DIFERENCIADOR 1 — Clasificación de áreas peligrosas
const zonasGas = [
  { zona: 'Zona 0', presencia: 'Atmósfera explosiva presente de forma continua o por largos periodos', equipo: 'Instrumentación intrínsecamente segura; sin equipo eléctrico no certificado' },
  { zona: 'Zona 1', presencia: 'Atmósfera explosiva probable en operación normal', equipo: 'Monitores remotos eléctricos ATEX/IECEx (Ex d / Ex e)' },
  { zona: 'Zona 2', presencia: 'Atmósfera explosiva poco probable y de corta duración', equipo: 'Equipo ATEX o monitores manuales con protocolo de operación' },
];
const zonasPolvo = [
  { zona: 'Zona 20', presencia: 'Nube de polvo combustible presente de forma continua', equipo: 'Equipo Ex tD certificado para polvo; control de ignición' },
  { zona: 'Zona 21', presencia: 'Nube de polvo probable en operación normal', equipo: 'Monitores Ex tD + gestión de NFPA 652 / 654' },
  { zona: 'Zona 22', presencia: 'Nube de polvo poco probable y de corta duración', equipo: 'Equipo Ex tD o protección con barreras de aislamiento' },
];

// DIFERENCIADOR 2 — Matriz de agente + material por química del producto
const matriz = [
  {
    clase: 'Hidrocarburos no polares',
    ejemplos: 'Gasolina, diésel, nafta, crudo',
    agente: 'AFFF / espuma sintética',
    material: 'Bronce marino o 316L',
    riesgo: 'Incendio de derrame y de tanque',
  },
  {
    clase: 'Solventes polares / alcoholes',
    ejemplos: 'Etanol, metanol, acetona, MEK',
    agente: 'AR-AFFF resistente al alcohol',
    material: 'Acero inoxidable 316L',
    riesgo: 'La espuma estándar se destruye: exige AR',
  },
  {
    clase: 'Químicos corrosivos',
    ejemplos: 'Ácidos, cáusticos, cloruros',
    agente: 'Agua pulverizada / espuma según caso',
    material: '316L + recubrimientos especiales',
    riesgo: 'Corrosión acelerada del equipo',
  },
  {
    clase: 'Reactivos al agua',
    ejemplos: 'Metales alcalinos, ciertos organometálicos',
    agente: 'NO agua — agente especial / aislamiento',
    material: 'Diseño específico por ingeniería',
    riesgo: 'El agua agrava el evento',
  },
];

// DIFERENCIADOR 3 — Protección por unidad de proceso
const unidades = [
  {
    icon: 'fas fa-flask-vial',
    titulo: 'Reactores y columnas de destilación',
    texto: 'Enfriamiento de recipientes a presión y estructuras altas expuestas a radiación térmica, operado a distancia.',
    producto: 'Monitor Remoto ATEX MR-3000',
    url: '/monitores-fijos#mr-3000',
  },
  {
    icon: 'fas fa-grip-lines',
    titulo: 'Racks de tubería (pipe racks)',
    texto: 'Cobertura lineal de corredores de proceso con monitores oscilantes para proteger tuberías y soportería.',
    producto: 'Monitores Automáticos',
    url: '/monitores-automaticos',
  },
  {
    icon: 'fas fa-truck-ramp-box',
    titulo: 'Áreas de carga y descarga',
    texto: 'Protección de islas de llenado de auto-tanques y carro-tanques, con espuma y enfriamiento de exposiciones.',
    producto: 'Monitor Magnum MG-4000',
    url: '/monitores-fijos#mg-4000',
  },
  {
    icon: 'fas fa-drum-steelpan',
    titulo: 'Almacenamiento de químicos',
    texto: 'Tanques y almacenes de producto con el agente correcto según su química y materiales anticorrosivos.',
    producto: 'Boquillas y Cámaras de Espuma',
    url: '/boquillas',
  },
  {
    icon: 'fas fa-truck-droplet',
    titulo: 'Respuesta de brigada',
    texto: 'Equipos de despliegue rápido para puntos sin cobertura fija, paros de planta y mantenimiento.',
    producto: 'Monitores Portátiles',
    url: '/monitores-portatiles',
  },
  {
    icon: 'fas fa-wind',
    titulo: 'Procesos con polvo combustible',
    texto: 'Plásticos, polímeros y aditivos en polvo donde el riesgo de deflagración exige gestión NFPA 652.',
    producto: 'Asesoría de ingeniería',
    url: '/consultoria-normativa',
  },
];

// EXTRA — Densidades de aplicación de espuma (pg-dens)
const densidades = [
  ['Derrame de hidrocarburo no polar (AFFF)', 'NFPA 11', '0.10 gpm/ft²'],
  ['Solvente polar / alcohol (AR-AFFF)', 'NFPA 11', 'Según fabricante (mayor)'],
  ['Enfriamiento de tanque de proceso', 'NFPA 15', '0.10 – 0.25 gpm/ft²'],
  ['Tiempo de descarga de espuma', 'NFPA 11', '30 – 65 min según riesgo'],
];

const normativas = [
  { n: 'NFPA 30', d: 'Almacenamiento de líquidos inflamables y combustibles' },
  { n: 'NFPA 11', d: 'Espuma — incluye criterios para solventes polares (AR)' },
  { n: 'NFPA 15', d: 'Sistemas fijos de agua pulverizada' },
  { n: 'NFPA 652', d: 'Fundamentos de polvo combustible' },
  { n: 'NFPA 69', d: 'Sistemas de prevención de explosiones' },
  { n: 'ATEX / IECEx', d: 'Equipo para atmósferas explosivas (gas y polvo)' },
  { n: 'NOM-005-STPS', d: 'Manejo de sustancias químicas peligrosas' },
  { n: 'NOM-010-STPS', d: 'Agentes contaminantes del ambiente laboral' },
  { n: 'API 2021', d: 'Atención de incendios en tanques de almacenamiento' },
];

const errores = [
  'Usar espuma AFFF estándar sobre solventes polares: se degrada y no extingue',
  'Especificar materiales no aptos para el químico del proceso (corrosión)',
  'Ignorar la clasificación de área al ubicar equipo eléctrico',
  'Aplicar agua sobre químicos reactivos al agua',
  'No contemplar el polvo combustible en procesos de polímeros',
  'Diseñar sin hoja de datos de seguridad (SDS) del producto manejado',
];

const recomendaciones = [
  'Seleccione el agente según la polaridad y reactividad del químico',
  'Especifique 316L o recubrimientos según el agente corrosivo presente',
  'Defina la clasificación de área antes de elegir el tipo de monitor',
  'Use monitores remotos ATEX en reactores y zonas de alto riesgo',
  'Integre la gestión de polvo combustible (NFPA 652) cuando aplique',
  'Parta siempre de las SDS y del escenario de incendio de diseño',
];

const faqs = [
  { q: '¿Por qué los solventes polares necesitan espuma AR-AFFF y no AFFF normal?', a: 'Los solventes polares o miscibles en agua —como etanol, metanol, acetona o MEK— absorben el agua de la manta de espuma estándar y la destruyen, dejando el combustible expuesto. La espuma resistente al alcohol (AR-AFFF) forma una membrana polimérica que resiste esa acción y mantiene el sellado. En plantas que manejan alcoholes o solventes polares, especificar AR-AFFF no es opcional: es la diferencia entre contener el incendio o no.' },
  { q: '¿Qué es la clasificación de áreas peligrosas y cómo afecta al equipo?', a: 'Es la división de la planta en zonas según la probabilidad de tener una atmósfera explosiva por gases (Zonas 0, 1 y 2) o por polvos combustibles (Zonas 20, 21 y 22). Cada zona impone requisitos al equipo eléctrico: en Zona 1, por ejemplo, los monitores remotos deben contar con certificación ATEX/IECEx (Ex d / Ex e). Definir la clasificación antes de seleccionar el equipo evita instalar dispositivos que se conviertan en fuente de ignición.' },
  { q: '¿Qué material de monitor conviene en una planta química?', a: 'Depende del agente corrosivo presente. El acero inoxidable 316L es el estándar para la mayoría de los ambientes petroquímicos por su resistencia a cloruros y químicos agresivos; en casos severos se añaden recubrimientos especiales. El bronce marino se reserva para hidrocarburos no polares en ambiente menos agresivo. La selección se hace a partir de las sustancias manejadas y de las condiciones del sitio.' },
  { q: '¿Cómo se protege un reactor o una columna de destilación?', a: 'Son recipientes a presión y estructuras altas que, bajo fuego, pueden fallar por radiación térmica. La estrategia es el enfriamiento intensivo y sostenido de la superficie desde una posición segura, idealmente con monitores remotos ATEX como el MR-3000, operados desde sala de control. Se complementa con sistemas fijos de agua pulverizada (NFPA 15) según el análisis de riesgo.' },
  { q: '¿Qué pasa con los químicos reactivos al agua?', a: 'Algunos materiales —metales alcalinos y ciertos compuestos organometálicos— reaccionan violentamente con el agua y empeoran el evento. En esos casos no se usa agua como agente: la protección se diseña con agentes especiales, aislamiento y control de la fuente, a partir de las hojas de datos de seguridad. Es un ejemplo de por qué el diseño debe partir de la química real del proceso.' },
  { q: '¿Atienden el riesgo de polvo combustible en plantas de polímeros?', a: 'Sí. Los procesos que manejan plásticos, resinas y polímeros en polvo pueden generar atmósferas de polvo combustible con riesgo de deflagración, regulado por NFPA 652 y NFPA 654. Lo abordamos desde la clasificación de área (Zonas 20/21/22), la selección de equipo Ex tD y la integración con medidas de prevención de explosiones (NFPA 69), con asesoría de ingeniería específica.' },
  { q: '¿Sus equipos cumplen con la normativa mexicana e internacional?', a: 'Sí. Suministramos monitores y accesorios FM Approved y/o UL Listed con certificación ATEX/IECEx donde aplique, conforme a NFPA 30, NFPA 11, NFPA 15 y NFPA 652, y a las normas oficiales mexicanas NOM-005-STPS y NOM-010-STPS para manejo de sustancias químicas peligrosas. Entregamos la documentación para auditorías de Protección Civil y aseguradoras.' },
  { q: '¿AQUEON diseña el sistema completo para una planta petroquímica?', a: 'Sí. Partimos de las sustancias manejadas y del escenario de incendio de diseño, clasificamos las áreas, seleccionamos el agente y el material por unidad de proceso, calculamos caudales y densidades de aplicación, y entregamos planos y memoria de cálculo. Después instalamos con técnicos certificados, probamos, ponemos en marcha y damos mantenimiento NFPA 25, con cobertura nacional.' },
];
---
<Base
  title="Protección Contra Incendios para Petroquímica | ATEX"
  description="Protección contra incendios para petroquímica en México: monitores en acero 316L, ATEX/IECEx y espuma para ambientes agresivos. Cumplimiento NFPA. Cotiza."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/industrias">Industrias</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Petroquímica y Química</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Industrias · Petroquímica</span>
          <h1>Protección Contra Incendios para Petroquímica y Química</h1>
        </div>
        <div class="section-header__body">
          <p>El sector donde el riesgo es <strong>múltiple</strong>: inflamable, corrosivo, tóxico y reactivo, todo a la vez.</p>
          <p>Equipos <strong>ATEX/IECEx</strong>, materiales <strong>316L</strong> y el agente correcto para cada química, diseñados por ingeniería.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El reto del sector</span>
          <h2>Cuando el Riesgo no es Solo el Fuego</h2>
          <p>
            En una planta <strong>petroquímica o química</strong>, el incendio rara vez es el único peligro. El mismo
            producto que arde puede ser <strong>corrosivo</strong> para el equipo de protección, <strong>tóxico</strong>
            para la brigada, <strong>reactivo</strong> con el agua o capaz de generar una atmósfera explosiva por gas o por
            polvo. Diseñar la protección sin entender la química del proceso es diseñar a ciegas.
          </p>
          <p>
            La diferencia entre contener un evento y agravarlo está en los detalles técnicos: elegir
            <strong>espuma resistente al alcohol</strong> para un solvente polar, especificar <strong>316L</strong> donde hay
            cloruros, clasificar correctamente el área antes de instalar un monitor eléctrico, o reconocer cuándo el agua
            es exactamente lo que no se debe aplicar. Ese criterio es el que AQUEON aporta a cada proyecto.
          </p>
          <p>
            En esta página verá cómo abordamos la <strong>clasificación de áreas peligrosas</strong>, cómo seleccionamos el
            agente y el material según la química del producto, y qué solución corresponde a cada unidad de proceso.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Clasificación de áreas peligrosas -->
  <section class="pq-zonas">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Áreas clasificadas</span>
          <h2>Clasificación de Áreas Peligrosas (ATEX / IECEx)</h2>
        </div>
        <div class="section-header__body">
          <p>El equipo eléctrico debe corresponder a la <strong>zona</strong> en que se instala, por gas o por polvo.</p>
          <p>Clasificar el área es el paso previo a especificar cualquier monitor.</p>
        </div>
      </div>

      <div class="pq-zonas-grid">
        <div class="pq-zonas-col">
          <h3 class="pq-zonas-title"><i class="fas fa-smog" aria-hidden="true"></i> Gases y vapores</h3>
          <div class="pq-zona-cards">
            {zonasGas.map((z) => (
              <article class="pq-zona-card">
                <span class="pq-zona-badge">{z.zona}</span>
                <p class="pq-zona-pres">{z.presencia}</p>
                <p class="pq-zona-eq"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> {z.equipo}</p>
              </article>
            ))}
          </div>
        </div>
        <div class="pq-zonas-col">
          <h3 class="pq-zonas-title"><i class="fas fa-wind" aria-hidden="true"></i> Polvos combustibles</h3>
          <div class="pq-zona-cards">
            {zonasPolvo.map((z) => (
              <article class="pq-zona-card pq-zona-card--dust">
                <span class="pq-zona-badge">{z.zona}</span>
                <p class="pq-zona-pres">{z.presencia}</p>
                <p class="pq-zona-eq"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> {z.equipo}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
      <p class="pq-note"><i class="fas fa-circle-info" aria-hidden="true"></i> La clasificación definitiva la establece el estudio de áreas peligrosas de la instalación conforme a IEC 60079 / NFPA 70.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Matriz agente + material -->
  <section class="pq-matriz">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Criterio de selección</span>
          <h2>El Agente y el Material Correctos para Cada Química</h2>
        </div>
        <div class="section-header__body">
          <p>Un mismo monitor, mal combinado con el agente o el material, <strong>falla ante el químico equivocado</strong>.</p>
          <p>Esta matriz resume cómo decidimos según la naturaleza del producto.</p>
        </div>
      </div>
      <div class="pq-matriz-wrap">
        <table class="pq-matriz-table">
          <thead>
            <tr>
              <th scope="col">Clase de producto</th>
              <th scope="col">Ejemplos</th>
              <th scope="col">Agente recomendado</th>
              <th scope="col">Material</th>
              <th scope="col">Consideración crítica</th>
            </tr>
          </thead>
          <tbody>
            {matriz.map((m) => (
              <tr>
                <th scope="row">{m.clase}</th>
                <td>{m.ejemplos}</td>
                <td class="pq-matriz-ag">{m.agente}</td>
                <td>{m.material}</td>
                <td class="pq-matriz-risk">{m.riesgo}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pq-note"><i class="fas fa-circle-info" aria-hidden="true"></i> La selección final se realiza a partir de las hojas de datos de seguridad (SDS) y la memoria de cálculo del proyecto.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Protección por unidad de proceso -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Soluciones AQUEON</span>
          <h2>Protección por Unidad de Proceso</h2>
        </div>
        <div class="section-header__body">
          <p>De los reactores a las áreas de carga, cada unidad exige una <strong>configuración distinta</strong>.</p>
          <p>Cada recomendación enlaza con la <strong>ficha técnica</strong> del equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {unidades.map((u) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={u.icon}></i></span>
            <h3>{u.titulo}</h3>
            <p>{u.texto}</p>
            <a href={u.url} class="pg-sol-link">{u.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- EXTRA: Densidades de aplicación -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Criterio de diseño</span>
          <h2>Densidades de Aplicación de Espuma</h2>
          <p>
            El dimensionamiento de la protección de un riesgo de hidrocarburo parte de la <strong>densidad de aplicación</strong>
            que exige la norma y, sobre todo, de la <strong>química del producto</strong>: un solvente polar demanda espuma
            resistente al alcohol y, normalmente, una densidad mayor. Estos son valores de referencia; el diseño final lo
            determina la memoria de cálculo a partir de las hojas de datos de seguridad (SDS).
          </p>
          <a href="/diseno-ingenieria" class="btn btn-outline"><i class="fas fa-compass-drafting" aria-hidden="true"></i> Ver servicio de ingeniería</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Aplicación</th><th scope="col">Norma</th><th scope="col">Densidad de referencia</th></tr>
            </thead>
            <tbody>
              {densidades.map(([a, n, d]) => (
                <tr><th scope="row">{a}</th><td>{n}</td><td>{d}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes en el sector</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones de ingeniería</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Ingeniería de Protección para la Industria Química</h2>
          <p>
            En <strong>AQUEON</strong> entendemos que en petroquímica el diseño parte de la química del producto. Somos
            distribuidores autorizados de Elkhart Brass, Akron Brass y Task Force Tips, y especificamos
            <strong>materiales 316L, equipos ATEX/IECEx y el agente espumante correcto</strong> —incluida espuma resistente
            al alcohol— para cada planta. Entregamos ingeniería conforme a NFPA y a las normas oficiales mexicanas,
            instalación certificada y mantenimiento NFPA 25.
          </p>
          <p>
            Atendemos <strong>plantas petroquímicas, químicas, de polímeros y de proceso</strong> con documentación completa
            para auditorías de Protección Civil y aseguradoras, con cobertura en los 32 estados de la República desde la
            Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/nosotros" class="btn btn-outline-light"><i class="fas fa-building-shield" aria-hidden="true"></i> Conozca AQUEON</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Servicios de ingeniería</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Marco normativo aplicable</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Protección para Petroquímica" contexto="protección contra incendios para plantas petroquímicas y químicas" faqs={faqs} />

