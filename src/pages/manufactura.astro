---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: 'FM Global', label: 'Diseño orientado a aseguradoras' },
  { numero: 'NFPA 13·15', label: 'Almacenamiento y agua pulverizada' },
  { numero: 'Clase I–IV', label: 'Clasificación de mercancías' },
  { numero: 'Gran altura', label: 'Naves y racks de alto reto' },
];

const beneficios = [
  'Equipos FM Approved para cumplir requisitos de aseguradoras',
  'Cobertura de grandes superficies con monitores oscilantes',
  'Protección de líquidos inflamables en cabinas de pintura y solventes',
  'Soluciones para almacenamiento en altura y alto reto (high-piled)',
  'Protección de patios exteriores y almacenamiento a la intemperie',
  'Documentación técnica para expedientes de aseguradora y Protección Civil',
];

// DIFERENCIADOR 1 — Tipos de instalación (pg-chain)
const tipos = [
  {
    id: 'manufactura',
    eslabon: 'Producción',
    titulo: 'Nave de Manufactura',
    icon: 'fas fa-industry',
    descripcion: 'Líneas de producción en grandes superficies sin compartimentar, con maquinaria, materia prima y producto en proceso expuestos.',
    activos: ['Líneas de producción', 'Maquinaria', 'Materia prima', 'Producto en proceso'],
    riesgos: ['Gran área sin dividir', 'Carga de fuego variable'],
  },
  {
    id: 'distribucion',
    eslabon: 'Logística',
    titulo: 'Almacén y Centro de Distribución',
    icon: 'fas fa-warehouse',
    descripcion: 'Almacenamiento en altura sobre racks con alta densidad de mercancía; el reto de protección crece con la altura y el tipo de producto.',
    activos: ['Racks de gran altura', 'Pasillos estrechos', 'Mercancía paletizada', 'Muelles de carga'],
    riesgos: ['Almacenamiento de alto reto', 'Plásticos (Grupo A)'],
  },
  {
    id: 'automotriz',
    eslabon: 'Automotriz',
    titulo: 'Planta Automotriz',
    icon: 'fas fa-car',
    descripcion: 'Procesos con cabinas de pintura, solventes y líquidos inflamables junto a líneas de ensamble de altísimo valor y continuidad crítica.',
    activos: ['Cabinas de pintura', 'Almacén de solventes', 'Líneas de ensamble', 'Estampado'],
    riesgos: ['Líquidos inflamables', 'Vapores de solvente'],
  },
  {
    id: 'logistica',
    eslabon: 'Parques',
    titulo: 'Parque Industrial y Logístico',
    icon: 'fas fa-boxes-stacked',
    descripcion: 'Múltiples naves, patios de maniobra y almacenamiento exterior donde la protección debe cubrir grandes distancias y exposiciones entre edificios.',
    activos: ['Naves múltiples', 'Patios de maniobra', 'Almacenamiento exterior', 'Tanques de servicio'],
    riesgos: ['Exposición entre edificios', 'Almacenamiento a la intemperie'],
  },
];

// DIFERENCIADOR 2 — Escenarios / áreas de manufactura (pg-scen)
const escenarios = [
  {
    icon: 'fas fa-warehouse',
    nombre: 'Nave de gran altura',
    descripcion: 'Superficie amplia y techos altos donde una sola línea de manguera resulta insuficiente.',
    estrategia: 'Monitores oscilantes de cobertura amplia que complementan la red de rociadores y enfrían a distancia.',
    solucion: 'Monitores Automáticos oscilantes',
  },
  {
    icon: 'fas fa-layer-group',
    nombre: 'Almacenamiento de alto reto',
    descripcion: 'Racks con mercancía de Clase III–IV o plásticos (Grupo A) apilada en altura.',
    estrategia: 'Diseño conforme a FM Global / NFPA 13 según la clase de mercancía y la altura de apilamiento.',
    solucion: 'Ingeniería + monitores de apoyo',
  },
  {
    icon: 'fas fa-spray-can-sparkles',
    nombre: 'Cabinas de pintura y solventes',
    descripcion: 'Líquidos inflamables y vapores en procesos de acabado y almacenes de solvente.',
    estrategia: 'Espuma sobre derrames y enfriamiento, conforme a NFPA 30 y NFPA 11.',
    solucion: 'Monitor + cámara de espuma',
  },
  {
    icon: 'fas fa-pallet',
    nombre: 'Patios y almacenamiento exterior',
    descripcion: 'Producto, tarimas y materia prima almacenados a la intemperie, fuera del alcance de rociadores.',
    estrategia: 'Monitores fijos de alto caudal para cobertura de área y enfriamiento de exposiciones.',
    solucion: 'Monitor Magnum MG-4000',
  },
  {
    icon: 'fas fa-truck-ramp-box',
    nombre: 'Muelles de carga',
    descripcion: 'Puntos de transferencia con tráfico de montacargas y acumulación temporal de mercancía.',
    estrategia: 'Cobertura dirigida y enfriamiento; protección de la transición interior–exterior.',
    solucion: 'Monitores fijos / portátiles',
  },
  {
    icon: 'fas fa-conveyor-belt-boxes',
    nombre: 'Bandas transportadoras',
    descripcion: 'Líneas de transporte continuas que pueden propagar el fuego entre áreas.',
    estrategia: 'Detección y descarga automática en puntos de transferencia.',
    solucion: 'Monitores Automáticos dirigidos',
  },
];

// DIFERENCIADOR 3 — Soluciones por área (pg-sol, interlink)
const soluciones = [
  {
    icon: 'fas fa-arrows-left-right-to-line',
    titulo: 'Cobertura de grandes superficies',
    texto: 'Monitores oscilantes con detección para cubrir naves amplias y complementar la red de rociadores.',
    producto: 'Monitores Automáticos',
    url: '/monitores-automaticos',
  },
  {
    icon: 'fas fa-pallet',
    titulo: 'Patios y almacenamiento exterior',
    texto: 'Enfriamiento de área y exposiciones en almacenamiento a la intemperie y entre edificios.',
    producto: 'Monitor Magnum MG-4000',
    url: '/monitores-fijos#mg-4000',
  },
  {
    icon: 'fas fa-spray-can-sparkles',
    titulo: 'Líquidos inflamables y pintura',
    texto: 'Espuma y enfriamiento para cabinas de pintura, almacenes de solvente y áreas de acabado.',
    producto: 'Boquillas y Cámaras de Espuma',
    url: '/boquillas',
  },
  {
    icon: 'fas fa-truck-droplet',
    titulo: 'Respuesta de brigada',
    texto: 'Equipos portátiles de despliegue rápido para puntos sin cobertura fija y mantenimiento.',
    producto: 'Monitores Portátiles',
    url: '/monitores-portatiles',
  },
  {
    icon: 'fas fa-water',
    titulo: 'Enfriamiento de muelles y exposiciones',
    texto: 'Monitores fijos para proteger muelles, transiciones interior–exterior y naves vecinas.',
    producto: 'Monitores Fijos Industriales',
    url: '/monitores-fijos',
  },
  {
    icon: 'fas fa-compass-drafting',
    titulo: 'Diseño FM Global / NFPA 13',
    texto: 'Ingeniería del sistema y clasificación de mercancías para cumplir requisitos de aseguradora.',
    producto: 'Servicios de ingeniería',
    url: '/diseno-ingenieria',
  },
];

// EXTRA — Clasificación de mercancías (pg-dens)
const commodities = [
  ['Clase I', 'Productos no combustibles sobre tarima de madera', 'Reto bajo'],
  ['Clase II', 'Clase I en cajas de cartón o madera', 'Reto bajo–medio'],
  ['Clase III', 'Madera, papel, textiles naturales', 'Reto medio'],
  ['Clase IV', 'Productos con componente plástico (Grupo B/C)', 'Reto medio–alto'],
  ['Plásticos Grupo A', 'Plásticos expandidos y no expandidos', 'Reto alto'],
];

const normativas = [
  { n: 'FM Global', d: 'Hojas de datos (Data Sheets) para aseguradoras' },
  { n: 'NFPA 13', d: 'Rociadores y almacenamiento (storage)' },
  { n: 'NFPA 15', d: 'Sistemas fijos de agua pulverizada' },
  { n: 'NFPA 30', d: 'Líquidos inflamables (pintura, solventes)' },
  { n: 'NFPA 11', d: 'Espuma para líquidos inflamables' },
  { n: 'NFPA 230', d: 'Protección de almacenamiento' },
  { n: 'NOM-002-STPS', d: 'Condiciones de seguridad — prevención de incendios' },
];

const errores = [
  'Diseñar sin clasificar la mercancía ni la altura de apilamiento',
  'Confiar solo en rociadores en naves de gran superficie y patios',
  'Ignorar el almacenamiento exterior, fuera del alcance de rociadores',
  'Tratar líquidos inflamables de pintura como riesgo ordinario',
  'No considerar las exposiciones entre naves de un parque industrial',
  'Especificar equipo sin aprobación FM exigida por la aseguradora',
];

const recomendaciones = [
  'Clasifique la mercancía (Clase I–IV / plásticos) antes de diseñar',
  'Complemente los rociadores con monitores en áreas de gran reto',
  'Proteja patios y almacenamiento exterior con monitores fijos',
  'Aplique espuma en cabinas de pintura y almacenes de solvente',
  'Use equipo FM Approved para satisfacer a la aseguradora',
  'Integre el mantenimiento NFPA 25 y la documentación de cumplimiento',
];

const faqs = [
  { q: '¿Qué papel juega FM Global en la protección de una planta de manufactura?', a: 'En el sector industrial y de almacenamiento, la aseguradora suele ser quien fija el estándar de protección. FM Global publica hojas de datos (Data Sheets) con criterios de diseño por tipo de mercancía, altura de almacenamiento y proceso, y exige equipo con aprobación FM. Diseñar conforme a estos criterios no solo mejora la seguridad: es condición para la cobertura y para primas competitivas. AQUEON especifica equipo FM Approved y diseña alineado a estos requisitos.' },
  { q: '¿Por qué se usan monitores si la planta ya tiene rociadores?', a: 'Los rociadores son la base de la protección de naves, pero tienen límites: grandes superficies de techo alto, almacenamiento exterior, patios, muelles y áreas de alto reto pueden requerir un refuerzo. Los monitores —especialmente los oscilantes y automáticos— aportan cobertura de área, alcance y enfriamiento de exposiciones donde el rociador no llega o no basta. Se diseñan como complemento, no como sustituto.' },
  { q: '¿Qué es la clasificación de mercancías y por qué importa?', a: 'Es la categorización del producto almacenado según su combustibilidad, de Clase I (no combustible) a Clase IV y a los plásticos del Grupo A, que son el mayor reto. La clase, junto con la altura de apilamiento, determina la densidad de diseño y la estrategia de protección conforme a NFPA 13 y a las hojas de FM Global. Un mismo almacén protegido para Clase II resultará insuficiente si en realidad guarda plásticos.' },
  { q: '¿Cómo se protege un almacenamiento en altura (high-piled storage)?', a: 'El almacenamiento en racks de gran altura concentra una carga de fuego enorme y de propagación rápida. La protección parte de la clase de mercancía y la altura para definir la densidad de rociadores (en techo y, si aplica, en niveles intermedios) conforme a NFPA 13/FM Global, y se complementa con monitores para áreas exteriores, muelles y enfriamiento de exposiciones. El diseño exige ingeniería específica.' },
  { q: '¿Atienden plantas automotrices y sus áreas de pintura?', a: 'Sí. Las cabinas de pintura, los almacenes de solvente y las áreas de acabado manejan líquidos inflamables regidos por NFPA 30, y se protegen con sistemas de espuma y enfriamiento (NFPA 11) además de la protección general de la nave. Integramos monitores, cámaras de espuma y boquillas como parte del sistema, con documentación para la aseguradora.' },
  { q: '¿Qué hacer con el almacenamiento a la intemperie?', a: 'El producto, las tarimas y la materia prima almacenados en patios quedan fuera del alcance de los rociadores de techo. Los protegemos con monitores fijos de alto caudal que cubren el área y enfrían exposiciones hacia naves vecinas, dimensionados según el volumen almacenado y la distancia a los edificios.' },
  { q: '¿AQUEON diseña e instala el sistema y entrega la documentación?', a: 'Sí. Clasificamos la mercancía y los riesgos, diseñamos conforme a NFPA y a las hojas de FM Global, calculamos caudales y densidades, y entregamos planos y memoria de cálculo. Instalamos con técnicos certificados, probamos, ponemos en marcha, capacitamos y damos mantenimiento NFPA 25, con la documentación que requiere la aseguradora y Protección Civil, con cobertura nacional.' },
];
---
<Base
  title="Protección Contra Incendios para Manufactura | AQUEON"
  description="Protección contra incendios para manufactura, almacenes y centros de distribución: cobertura de gran superficie y diseño FM Global / NFPA 13. AQUEON México."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/industrias">Industrias</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Manufactura e Industrial</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Industrias · Manufactura</span>
          <h1>Protección Contra Incendios para Manufactura e Industria</h1>
        </div>
        <div class="section-header__body">
          <p>El sector donde manda la <strong>aseguradora</strong>: grandes superficies, almacenamiento en altura y continuidad de negocio.</p>
          <p>Diseño orientado a <strong>FM Global y NFPA 13</strong>, con equipo <strong>FM Approved</strong> y cobertura de área por monitores.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El reto del sector</span>
          <h2>Donde la Aseguradora Fija el Estándar</h2>
          <p>
            En <strong>manufactura, almacenamiento y logística</strong> el riesgo no viene de un proceso químico extremo,
            sino de la <strong>escala</strong>: naves de miles de metros cuadrados sin compartimentar, racks de gran altura
            con enorme carga de fuego, patios de almacenamiento a la intemperie y procesos con líquidos inflamables. Y un
            incendio aquí no solo destruye inventario: detiene la producción y rompe la cadena de suministro.
          </p>
          <p>
            A diferencia de otros sectores, aquí quien suele <strong>fijar el estándar de protección es la aseguradora</strong>,
            a través de las hojas de datos de <strong>FM Global</strong> y de la NFPA 13. La protección depende de clasificar
            correctamente la mercancía y la altura de almacenamiento, y de usar equipo con aprobación FM. Diseñar bien es
            condición para la cobertura y para una prima competitiva.
          </p>
          <p>
            Los monitores AQUEON <strong>complementan</strong> la red de rociadores donde esta no basta: grandes superficies,
            almacenamiento exterior, muelles y exposiciones entre edificios. En esta página verá la protección por tipo de
            instalación, los escenarios de manufactura, las soluciones por área y la clasificación de mercancías.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Tipos de instalación -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Mapa de riesgo</span>
          <h2>Protección por Tipo de Instalación</h2>
        </div>
        <div class="section-header__body">
          <p>De la nave de producción al centro de distribución, cada instalación plantea un <strong>reto distinto</strong>.</p>
          <p>Identificarlo define la <strong>estrategia de protección</strong> correcta.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {tipos.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-cubes" aria-hidden="true"></i> Activos típicos</span>
            <div class="l3-chips">
              {c.activos.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-fire" aria-hidden="true"></i> Riesgos principales</span>
            <div class="l3-chips">
              {c.riesgos.map((r) => <span class="l3-chip l3-chip--norm">{r}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Escenarios de manufactura -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Estrategia de respuesta</span>
          <h2>Áreas de Manufactura y Cómo se Protegen</h2>
        </div>
        <div class="section-header__body">
          <p>De la nave de gran altura a las bandas, cada área exige una <strong>estrategia propia</strong>.</p>
          <p>Esta matriz resume el enfoque de ingeniería que aplicamos a cada una.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Área</th>
              <th scope="col">Riesgo</th>
              <th scope="col">Estrategia</th>
              <th scope="col">Solución AQUEON</th>
            </tr>
          </thead>
          <tbody>
            {escenarios.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td>{e.estrategia}</td>
                <td class="pg-scen-sol">{e.solucion}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> El diseño definitivo se establece según la clasificación de mercancías, la altura de almacenamiento y los criterios de la aseguradora.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Soluciones por área -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Soluciones AQUEON</span>
          <h2>El Equipo Correcto para Cada Área</h2>
        </div>
        <div class="section-header__body">
          <p>Los monitores complementan los rociadores donde la escala lo exige, en un <strong>sistema integral</strong>.</p>
          <p>Cada recomendación enlaza con la <strong>ficha técnica</strong> del equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {soluciones.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- EXTRA: Clasificación de mercancías -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Criterio de diseño</span>
          <h2>Clasificación de Mercancías y Reto de Protección</h2>
          <p>
            La <strong>clase de mercancía</strong> almacenada —de la Clase I no combustible a los plásticos del Grupo A— junto
            con la altura de apilamiento, determina la densidad de diseño y la estrategia conforme a NFPA 13 y a las hojas de
            FM Global. Clasificar mal el producto es el error más común y el más costoso. Esta es la referencia general; la
            clasificación final la confirma la ingeniería del proyecto.
          </p>
          <a href="/consultoria-normativa" class="btn btn-outline"><i class="fas fa-clipboard-check" aria-hidden="true"></i> Ver consultoría normativa</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Clase</th><th scope="col">Ejemplos</th><th scope="col">Reto de fuego</th></tr>
            </thead>
            <tbody>
              {commodities.map(([c, e, r]) => (
                <tr><th scope="row">{c}</th><td>{e}</td><td>{r}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes en el sector</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones de ingeniería</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Protección Industrial que Satisface a su Aseguradora</h2>
          <p>
            En <strong>AQUEON</strong> diseñamos la protección de plantas y almacenes partiendo de la mercancía, la escala y
            los requisitos de la aseguradora. Somos distribuidores autorizados de Elkhart Brass, Akron Brass y Task Force
            Tips, y especificamos <strong>equipo FM Approved</strong> y monitores de cobertura de área conforme a NFPA 13,
            NFPA 15 y a las hojas de FM Global. Entregamos ingeniería, instalación certificada y mantenimiento NFPA 25.
          </p>
          <p>
            Atendemos <strong>parques industriales, plantas automotrices, centros de distribución y grandes corporativos</strong>,
            con documentación completa para aseguradoras y Protección Civil, y cobertura en los 32 estados de la República
            desde la Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/nosotros" class="btn btn-outline-light"><i class="fas fa-building-shield" aria-hidden="true"></i> Conozca AQUEON</a>
