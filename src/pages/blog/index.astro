---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import BlogSidebar from '../../components/blog/BlogSidebar.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const destacado = posts[0];
const resto = posts.slice(1);
---
<Base
  title="Blog Técnico | Guías de Monitores Contra Incendios | AQUEON México"
  description="Guías técnicas sobre monitores contra incendios industriales: selección de equipos, cumplimiento PEMEX, certificaciones FM/UL, mantenimiento NFPA 25 y tecnología de detección automática. Por los ingenieros de AQUEON México."
>
  <!-- Hero -->
  <section class="blog-hero">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Blog Técnico</span>
          <h1>Conocimiento que Protege su Operación</h1>
        </div>
        <div class="section-header__body">
          <p>Guías escritas por nuestros <strong>ingenieros certificados NFPA</strong>: selección de equipos, normatividad y certificaciones.</p>
          <p>Información práctica sobre <strong>mantenimiento y tecnología</strong> de protección contra incendios industrial.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Layout con sidebar -->
  <section class="blog-layout-section">
    <div class="container">
      <div class="blog-layout">
        <div class="blog-main">
          {destacado && (
            <article class="blog-featured">
              {destacado.data.image && (
                <a href={`/blog/${destacado.id}`} class="blog-featured-media">
                  <img src={destacado.data.image} alt="" loading="eager" />
                  <span class="blog-featured-flag"><i class="fas fa-star" aria-hidden="true"></i> Destacado</span>
                </a>
              )}
              <div class="blog-featured-body">
                <div class="blog-card-meta">
                  <span class="blog-card-category">{destacado.data.category}</span>
                </div>
                <h2><a href={`/blog/${destacado.id}`}>{destacado.data.title}</a></h2>
                <p>{destacado.data.description}</p>
                <a href={`/blog/${destacado.id}`} class="btn btn-primary">Leer artículo</a>
              </div>
            </article>
          )}

          <div class="blog-grid">
            {resto.map((post) => (
              <article class="blog-card">
                {post.data.image && (
                  <a href={`/blog/${post.id}`} class="blog-card-image" aria-hidden="true" tabindex="-1">
                    <img src={post.data.image} alt="" loading="lazy" />
                  </a>
                )}
                <div class="blog-card-content">
                  <div class="blog-card-meta">
                    <span class="blog-card-category">{post.data.category}</span>
                  </div>
                  <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
                  <p>{post.data.description}</p>
                  <a href={`/blog/${post.id}`} class="blog-card-link">
                    Leer artículo <i class="fas fa-chevron-right" aria-hidden="true"></i>
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>

        <BlogSidebar />
      </div>
    </div>
  </section>
</Base>

<style>
  .blog-hero { background: var(--bg-0); padding: var(--section-pad) 0 calc(var(--section-pad) * 0.5); }
  .blog-hero .section-header { margin-bottom: 0; }
  .blog-hero h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: var(--text-4xl);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--text-strong);
    margin: var(--space-md) 0 0;
  }
  .blog-hero .section-header__body p { font-size: var(--text-base); }

  .blog-layout-section { background: var(--bg-1); padding: var(--section-pad) 0; border-top: 1px solid var(--border-subtle); }
  .blog-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 20rem);
    gap: clamp(1.5rem, 3%, 3rem);
    align-items: start;
  }
  .blog-main { min-width: 0; }

  /* Artículo destacado */
  .blog-featured {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-xl);
  }
  .blog-featured-media { position: relative; display: block; min-height: 100%; }
  .blog-featured-media img { width: 100%; height: 100%; min-height: 240px; object-fit: cover; display: block; filter: saturate(1.06) contrast(1.03) brightness(0.94); }
  .blog-featured-flag {
    position: absolute; top: 1rem; left: 1rem;
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: var(--grad-red); color: #fff;
    font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    padding: 0.35rem 0.8rem; border-radius: var(--radius-full);
  }
  .blog-featured-body { padding: var(--space-xl); display: flex; flex-direction: column; gap: var(--space-md); }
  .blog-featured-body h2 { font-family: 'Space Grotesk', sans-serif; font-size: var(--text-xl); line-height: 1.25; margin: 0; }
  .blog-featured-body h2 a { color: var(--text-strong); text-decoration: none; }
  .blog-featured-body h2 a:hover { color: var(--red-hover); }
  .blog-featured-body p { color: var(--text-body); font-size: var(--text-sm); margin: 0; flex: 1; }
  .blog-featured-body .btn { align-self: flex-start; }

  /* Grid de artículos */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 17rem), 1fr));
    gap: clamp(1.25rem, 2%, 1.75rem);
  }
  .blog-card {
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .blog-card:hover { border-color: var(--border-red); box-shadow: var(--glow-red); }
  .blog-card-image { display: block; aspect-ratio: 16 / 9; overflow: hidden; border-bottom: 1px solid var(--border-subtle); }
  .blog-card-image img { width: 100%; height: 100%; object-fit: cover; filter: saturate(1.06) contrast(1.03) brightness(0.96); }
  .blog-card-content { padding: var(--space-lg); display: flex; flex-direction: column; gap: var(--space-sm); flex: 1; }
  .blog-card-meta { display: flex; align-items: center; justify-content: space-between; gap: var(--space-sm); flex-wrap: wrap; }
  .blog-card-category {
    display: inline-block;
    background: var(--red-soft); color: var(--red-hover); border: 1px solid var(--border-red);
    border-radius: var(--radius-full); padding: 0.2rem 0.7rem;
    font-size: var(--text-xs); font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
  }
  .blog-card-meta time { color: var(--text-muted); font-size: var(--text-xs); }
  .blog-card h2 { font-family: 'Space Grotesk', sans-serif; font-size: var(--text-md); line-height: 1.3; margin: 0; }
  .blog-card h2 a { color: var(--text-strong); text-decoration: none; }
  .blog-card h2 a:hover { color: var(--red-hover); }
  .blog-card p { color: var(--text-body); font-size: var(--text-sm); margin: 0; flex: 1; }
  .blog-card-link {
    color: var(--red-hover); text-decoration: none; font-weight: 600; font-size: var(--text-sm);
    display: inline-flex; align-items: center; gap: var(--space-sm); margin-top: auto;
  }
  .blog-card-link i { font-size: 0.7em; }

  @media (max-width: 980px) {
    .blog-layout { grid-template-columns: 1fr; }
    .blog-sidebar { position: static !important; }
  }
  @media (max-width: 640px) {
    .blog-featured { grid-template-columns: 1fr; }
  }
</style>
