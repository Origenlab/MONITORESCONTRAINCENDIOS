---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatearFecha(fecha: Date): string {
  return fecha.toLocaleDateString('es-MX', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
}
---
<Base
  title="Blog Técnico | Monitores Contra Incendios | AQUEON México"
  description="Guías técnicas sobre monitores contra incendios industriales: selección de equipos, cumplimiento PEMEX, certificaciones FM/UL, mantenimiento NFPA 25 y tecnología de detección automática. Por los ingenieros de AQUEON México."
>
  <section class="blog-hero">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Blog Técnico</span>
        <h1>Conocimiento que Protege su Operación</h1>
        <p>
          Guías técnicas escritas por nuestros ingenieros certificados NFPA: selección de equipos,
          normatividad, certificaciones, mantenimiento y tecnología de protección contra incendios industrial.
        </p>
      </div>
    </div>
  </section>

  <section class="blog-list-section">
    <div class="container">
      <div class="blog-grid">
        {posts.map((post) => (
          <article class="blog-card">
            {post.data.image && (
              <a href={`/blog/${post.id}`} class="blog-card-image" aria-hidden="true" tabindex="-1">
                <img src={post.data.image} alt="" loading="lazy" />
              </a>
            )}
            <div class="blog-card-content">
              <div class="blog-card-meta">
                <span class="blog-card-category">{post.data.category}</span>
                <time datetime={post.data.pubDate.toISOString()}>{formatearFecha(post.data.pubDate)}</time>
              </div>
              <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <a href={`/blog/${post.id}`} class="blog-card-link">
                Leer artículo <i class="fas fa-chevron-right" aria-hidden="true"></i>
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="blog-cta">
        <p>¿Tiene un proyecto de protección contra incendios? Nuestros ingenieros lo asesoran sin costo.</p>
        <a href="/#cotizar" class="btn btn-primary btn-lg">
          <i class="fas fa-file-invoice" aria-hidden="true"></i> Solicitar Cotización Gratuita
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .blog-hero {
    background: var(--bg-0);
    padding: var(--section-pad) 0 calc(var(--section-pad) * 0.5);
  }

  .blog-hero .section-header {
    margin-bottom: 0;
  }

  .blog-hero h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: var(--text-3xl);
    color: var(--text-strong);
    margin: var(--space-md) 0;
  }

  .blog-hero p {
    color: var(--text-body);
    font-size: var(--text-md);
  }

  .blog-list-section {
    background: var(--bg-1);
    padding: var(--section-pad) 0;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 22rem), 1fr));
    gap: 2%;
    row-gap: var(--space-xl);
  }

  .blog-card {
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: var(--transition);
  }

  .blog-card:hover {
    transform: translateY(-1px);
    border-color: var(--border-red);
    box-shadow: var(--glow-red);
  }

  .blog-card-image {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--border-subtle);
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.06) contrast(1.03) brightness(0.96);
  }

  .blog-card-content {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    flex: 1;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .blog-card-category {
    display: inline-block;
    background: var(--red-soft);
    color: var(--red-hover);
    border: 1px solid var(--border-red);
    border-radius: var(--radius-full);
    padding: 0.25rem 0.75rem;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .blog-card-meta time {
    color: var(--text-muted);
    font-size: var(--text-xs);
  }

  .blog-card h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: var(--text-lg);
    line-height: 1.3;
    margin: 0;
  }

  .blog-card h2 a {
    color: var(--text-strong);
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .blog-card h2 a:hover {
    color: var(--red-hover);
  }

  .blog-card p {
    color: var(--text-body);
    font-size: var(--text-sm);
    margin: 0;
    flex: 1;
  }

  .blog-card-link {
    color: var(--red-hover);
    text-decoration: none;
    font-weight: 600;
    font-size: var(--text-sm);
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    transition: var(--transition-fast);
  }

  .blog-card-link:hover {
    gap: var(--space-md);
  }

  .blog-cta {
    margin-top: var(--space-3xl);
    text-align: center;
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
  }

  .blog-cta p {
    color: var(--text-body);
    font-size: var(--text-md);
    margin-bottom: var(--space-lg);
  }
</style>
