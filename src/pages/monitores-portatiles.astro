---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const modelos = [
  {
    id: 'mp-750',
    modelo: 'MP-750',
    nombre: 'Monitor Portátil MP-750',
    badge: 'Más Vendido',
    badgePremium: true,
    icon: 'fas fa-fire-extinguisher',
    imagen: '/images/monitores-contra-incendios-cuerpo-bomberos-emergencias.webp',
    resumen: 'Monitor portátil ligero de aluminio con base plegable: el equilibrio ideal entre caudal, peso y rapidez de despliegue para brigadas industriales.',
    descripcion: 'El MP-750 es el caballo de batalla de la respuesta rápida. Con 18 kg de aluminio de alta resistencia y base plegable, un solo operador lo transporta, lo ancla y lo pone en operación en menos de un minuto. Entrega de 250 a 750 GPM con un sistema antivuelco que lo mantiene estable bajo presión, ideal para brigadas de emergencia y primera respuesta en planta.',
    specs: [
      ['Caudal nominal', '250 – 750 GPM'],
      ['Peso del equipo', '18 kg'],
      ['Material de construcción', 'Aluminio de alta resistencia'],
      ['Despliegue', 'Por un solo operador · base plegable'],
      ['Estabilidad', 'Sistema antivuelco bajo presión'],
      ['Conexión de entrada', 'Storz / NH 2.5"'],
      ['Certificación', 'NFPA Compliant · UL Listed'],
    ],
    aplicaciones: ['Brigadas de emergencia', 'Primera respuesta', 'Refuerzo táctico', 'Mantenimiento programado'],
  },
  {
    id: 'mt-500',
    modelo: 'MT-500',
    nombre: 'Monitor Táctico MT-500',
    badge: 'Ultraligero',
    badgePremium: false,
    icon: 'fas fa-feather-pointed',
    imagen: '/images/monitores-contra-incendios-industria-minera.webp',
    resumen: 'El monitor más ligero del mercado, diseñado para acceso a áreas confinadas y de difícil acceso donde cada kilogramo cuenta.',
    descripcion: 'Cuando la emergencia ocurre en un sótano, una mina o una zona de difícil acceso, el peso lo es todo. El MT-500 pesa apenas 12 kg en aluminio aeronáutico y se transporta como una mochila. Aunque compacto, entrega de 200 a 500 GPM y llega con kit completo de accesorios para operar de inmediato. Es la elección para brigadas que necesitan movilidad extrema sin sacrificar capacidad.',
    specs: [
      ['Caudal nominal', '200 – 500 GPM'],
      ['Peso del equipo', '12 kg (el más ligero)'],
      ['Material de construcción', 'Aluminio aeronáutico'],
      ['Incluye', 'Kit completo de accesorios'],
      ['Transporte', 'Tipo mochila · acceso confinado'],
      ['Conexión de entrada', 'Storz / NH 2.5"'],
      ['Certificación', 'NFPA Compliant'],
    ],
    aplicaciones: ['Áreas confinadas', 'Minería subterránea', 'Acceso difícil', 'Equipos de rescate'],
  },
  {
    id: 'mrt-1200',
    modelo: 'MRT-1200',
    nombre: 'Monitor Trailer MRT-1200',
    badge: 'Profesional',
    badgePremium: false,
    icon: 'fas fa-trailer',
    imagen: '/images/monitores-contra-incendios-aviacion-aeropuertos.webp',
    resumen: 'Monitor montado sobre remolque con posicionamiento hidráulico: máxima movilidad y alto caudal para emergencias industriales mayores.',
    descripcion: 'El MRT-1200 combina la potencia de un monitor fijo con la movilidad de un equipo rodante. Montado sobre remolque con sistema de posicionamiento hidráulico y elevación 360°, se traslada con vehículo a cualquier punto de la instalación y se despliega en minutos. Sus 500 a 1,200 GPM lo hacen ideal para grandes superficies, aeropuertos (ARFF) y escenarios donde se requiere reubicar la protección con rapidez.',
    specs: [
      ['Caudal nominal', '500 – 1,200 GPM'],
      ['Montaje', 'Remolque incluido'],
      ['Posicionamiento', 'Hidráulico · elevación 360°'],
      ['Movilidad', 'Traslado con vehículo'],
      ['Material de construcción', 'Acero con recubrimiento epóxico'],
      ['Compatibilidad', 'Agua y espuma'],
      ['Certificación', 'FM Approved'],
    ],
    aplicaciones: ['Aeropuertos (ARFF)', 'Grandes superficies', 'Eventos de emergencia', 'Cobertura móvil'],
  },
];

const stats = [
  { numero: '12 kg', label: 'El modelo más ligero' },
  { numero: '< 1 min', label: 'Despliegue por un operador' },
  { numero: '200–1,200', label: 'GPM de caudal disponible' },
  { numero: 'NFPA · UL', label: 'Equipos certificados' },
];

const beneficios = [
  'Despliegue inmediato por una sola persona, sin equipo pesado',
  'Movilidad total: lleve la protección al punto del incendio',
  'Refuerzo de la red fija en cualquier zona de la planta',
  'Esenciales para brigadas y programas de respuesta a emergencias',
  'Compatibilidad con agua y, en modelos seleccionados, espuma',
  'Almacenamiento compacto y mantenimiento sencillo',
];

const despliegue = [
  { paso: '01', icon: 'fas fa-truck-ramp-box', titulo: 'Transporte', texto: 'El equipo se traslada a mano, tipo mochila o sobre remolque según el modelo y la distancia.' },
  { paso: '02', icon: 'fas fa-anchor', titulo: 'Anclaje', texto: 'Base plegable, picas de anclaje o estabilizadores hidráulicos fijan el monitor contra el retroceso.' },
  { paso: '03', icon: 'fas fa-plug', titulo: 'Conexión', texto: 'Acople rápido Storz/NH a la línea de manguera o hidrante más cercano.' },
  { paso: '04', icon: 'fas fa-bullseye', titulo: 'Operación', texto: 'El operador orienta el chorro y regula patrón y alcance desde una posición segura.' },
];

const errores = [
  'Elegir un equipo por peso sin verificar el caudal que exige el escenario',
  'Omitir el sistema de anclaje y subestimar el retroceso bajo presión',
  'No capacitar a la brigada en despliegue y operación',
  'Seleccionar conexiones incompatibles con la red existente',
  'Olvidar el mantenimiento y la verificación periódica del equipo',
  'No considerar compatibilidad con espuma cuando hay hidrocarburos',
];

const recomendaciones = [
  'Defina el escenario: distancia, caudal y tipo de riesgo antes de comprar',
  'Equilibre peso y capacidad según quién operará el equipo',
  'Capacite a su brigada con simulacros reales de despliegue',
  'Verifique compatibilidad de conexiones con su red contra incendios',
  'Programe inspección y mantenimiento conforme a NFPA 25',
  'Solicite asesoría para combinar equipos fijos y portátiles',
];

const seleccion = [
  ['Brigada de primera respuesta', 'MP-750', '250–750 GPM, ligero y rápido'],
  ['Acceso confinado / minería', 'MT-500', '12 kg, máxima portabilidad'],
  ['Grandes áreas / aeropuertos', 'MRT-1200', 'Remolque, alto caudal y movilidad'],
  ['Refuerzo de red fija', 'MP-750', 'Despliegue versátil en planta'],
  ['Hidrocarburos (con espuma)', 'MRT-1200', 'Compatible con solución espumante'],
];

const faqs = [
  { q: '¿Qué es un monitor portátil contra incendios?', a: 'Es un cañón de agua o espuma diseñado para trasladarse y desplegarse con rapidez, a diferencia del monitor fijo que está montado de forma permanente. Permite a una brigada llevar gran caudal al punto exacto del incendio, anclarlo y operarlo desde una posición segura, lo que lo hace esencial en programas de respuesta a emergencias.' },
  { q: '¿Cuál es la diferencia entre el MP-750, el MT-500 y el MRT-1200?', a: 'El MP-750 (18 kg, 250–750 GPM) es el equilibrio ideal para brigadas; el MT-500 (12 kg, 200–500 GPM) es el más ligero, para acceso confinado y difícil; y el MRT-1200 va sobre remolque con posicionamiento hidráulico (500–1,200 GPM) para grandes superficies y aeropuertos. La elección depende del caudal requerido y de cómo y dónde se desplegará.' },
  { q: '¿Cuánto pesa un monitor portátil y cuántas personas lo operan?', a: 'Nuestros modelos manuales pesan entre 12 y 18 kg y están diseñados para que un solo operador los transporte y los ponga en operación. El MRT-1200, al ir sobre remolque, se traslada con vehículo pero también lo opera una persona una vez posicionado.' },
  { q: '¿Los monitores portátiles resisten el retroceso del chorro?', a: 'Sí, siempre que se anclen correctamente. Incorporan base plegable con picas, sistemas antivuelco o estabilizadores hidráulicos según el modelo. El anclaje adecuado es crítico: un monitor no asegurado puede desplazarse peligrosamente bajo presión. La capacitación de la brigada es parte esencial de la seguridad.' },
  { q: '¿Se pueden usar con espuma?', a: 'El MRT-1200 admite descarga de solución espumante para incendios de hidrocarburos. Para los modelos manuales, la compatibilidad depende de la configuración; nuestros ingenieros la definen según el tipo de riesgo y el concentrado (AFFF, AR-AFFF) que requiera su instalación.' },
  { q: '¿Qué caudal necesito en un monitor portátil?', a: 'Depende del escenario: una brigada de primera respuesta suele requerir de 250 a 750 GPM, mientras que la protección de grandes áreas puede exigir más de 1,000 GPM. El caudal también está limitado por la presión y el diámetro de la línea que alimenta el equipo. Lo dimensionamos con cálculo hidráulico, sin costo.' },
  { q: '¿Sustituyen los monitores portátiles a los fijos?', a: 'No: se complementan. El monitor fijo da cobertura permanente de áreas críticas, y el portátil aporta flexibilidad para atacar focos donde no hay protección fija o para reforzar la respuesta. Un programa sólido combina ambos. Conozca también nuestros monitores fijos para el sistema completo.' },
  { q: '¿AQUEON capacita a la brigada en el uso del equipo?', a: 'Sí. Nuestro servicio de capacitación especializada entrena a operadores y brigadas en despliegue, anclaje, operación segura y mantenimiento básico, con certificados de competencia y simulacros de emergencia incluidos.' },
  { q: '¿Qué normativa aplica a los equipos portátiles?', a: 'Cumplen estándares NFPA aplicables a equipo de combate y, según el modelo, certificación UL Listed o FM Approved. El programa de inspección y mantenimiento se rige por NFPA 25, y la operación se enmarca en la NOM-002-STPS de seguridad laboral.' },
  { q: '¿En cuánto tiempo entregan una cotización?', a: 'Respondemos cotizaciones técnicas en menos de 24 horas hábiles. Mantenemos stock en México para entrega ágil y, si lo requiere, agendamos una demostración del equipo sin costo.' },
];
---
<Base
  title="Monitores Portátiles Contra Incendios | Despliegue Rápido para Brigadas | AQUEON México"
  description="Monitores portátiles contra incendios para brigadas industriales: MP-750, MT-500 ultraligero y MRT-1200 sobre remolque. De 200 a 1,200 GPM, certificados NFPA y UL. Venta, capacitación e ingeniería en México con AQUEON."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/productos">Productos</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Monitores Portátiles</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Catálogo · Monitores Portátiles</span>
          <h1>Monitores Portátiles Contra Incendios</h1>
        </div>
        <div class="section-header__body">
          <p>Movilidad y <strong>respuesta rápida</strong>: lleve gran caudal al punto exacto del incendio en menos de un minuto.</p>
          <p>Equipos <strong>certificados NFPA y UL</strong>, de 200 a 1,200 GPM, con capacitación y respaldo de AQUEON.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">¿Qué es un monitor portátil?</span>
          <h2>La Protección que Llega Donde se Necesita</h2>
          <p>
            Un <strong>monitor portátil contra incendios</strong> es un cañón de agua o espuma diseñado para trasladarse y
            desplegarse con rapidez. Mientras el monitor fijo cubre de forma permanente un área crítica, el portátil aporta
            algo que ningún sistema fijo puede dar: la capacidad de llevar gran caudal al punto exacto del incendio, sin
            importar dónde ocurra.
          </p>
          <p>
            En la práctica, un buen programa de protección combina ambos. La <a href="/monitores-fijos">red de monitores
            fijos</a> protege tanques y áreas de proceso las 24 horas; los equipos portátiles permiten a la brigada atacar
            focos secundarios, reforzar la respuesta o cubrir zonas sin protección fija. Por eso son esenciales en
            refinerías, parques industriales, minería y cuerpos de bomberos.
          </p>
          <p>
            Elegir el equipo correcto no se reduce al peso. Implica equilibrar caudal, portabilidad y método de anclaje,
            verificar la compatibilidad de conexiones con su red, y capacitar a quien lo operará. En esta página encontrará
            los tres modelos portátiles de AQUEON, sus especificaciones y la guía para seleccionar con criterio.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Cómo se despliega (diferenciador de esta L3) -->
  <section class="l3-proceso">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Despliegue en Campo</span>
          <h2>De la Bodega al Fuego en Cuatro Pasos</h2>
        </div>
        <div class="section-header__body">
          <p>La ventaja del equipo portátil está en la <strong>rapidez</strong>: bien entrenada, una brigada lo opera en menos de un minuto.</p>
          <p>Cada paso requiere <strong>técnica y capacitación</strong>, parte del servicio que entregamos.</p>
        </div>
      </div>
      <div class="l3-proceso-grid">
        {despliegue.map((p) => (
          <div class="l3-step">
            <span class="l3-step-num">{p.paso}</span>
            <span class="l3-step-icon" aria-hidden="true"><i class={p.icon}></i></span>
            <h3>{p.titulo}</h3>
            <p>{p.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modelos -->
  <section class="l3-modelos">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Nuestros Modelos</span>
          <h2>Tres Equipos para Cada Tipo de Despliegue</h2>
        </div>
        <div class="section-header__body">
          <p>Del ultraligero de acceso confinado al monitor sobre remolque de alto caudal, cada modelo resuelve un <strong>escenario distinto</strong>.</p>
          <p>Todos con <strong>certificación, garantía de fábrica</strong> y capacitación de brigada.</p>
        </div>
      </div>

      {modelos.map((m) => (
        <article id={m.id} class="l3-model">
          <div class="l3-model-media">
            <img src={m.imagen} alt={`${m.nombre} — monitor portátil contra incendios AQUEON`} loading="lazy" />
            <span class:list={['l3-model-badge', m.badgePremium && 'is-premium']}><i class={m.icon} aria-hidden="true"></i> {m.badge}</span>
          </div>
          <div class="l3-model-content">
            <span class="l3-model-kicker">{m.modelo}</span>
            <h3>{m.nombre}</h3>
            <p class="l3-model-resumen">{m.resumen}</p>
            <p>{m.descripcion}</p>

            <table class="l3-spec-table">
              <tbody>
                {m.specs.map(([k, v]) => (
                  <tr><th scope="row">{k}</th><td>{v}</td></tr>
                ))}
              </tbody>
            </table>

            <div class="l3-model-apps">
              <span class="l3-apps-label"><i class="fas fa-location-dot" aria-hidden="true"></i> Aplicaciones</span>
              <div class="l3-chips">
                {m.aplicaciones.map((a) => <span class="l3-chip">{a}</span>)}
              </div>
            </div>

            <div class="l3-model-actions">
              <a href="/contacto" class="btn btn-primary"><i class="fas fa-file-invoice" aria-hidden="true"></i> Cotizar el {m.modelo}</a>
              <a href={`https://wa.me/5215512345678?text=Hola%20AQUEON%2C%20me%20interesa%20el%20monitor%20port%C3%A1til%20${m.modelo}`} class="btn btn-outline" target="_blank" rel="noopener"><i class="fab fa-whatsapp" aria-hidden="true"></i> WhatsApp</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Tabla comparativa -->
  <section class="l3-compare">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Comparativa</span>
          <h2>MP-750 vs MT-500 vs MRT-1200</h2>
        </div>
        <div class="section-header__body">
          <p>El equilibrio entre <strong>caudal, peso y movilidad</strong> define cuál es el equipo idóneo.</p>
          <p>¿No sabe cuál especificar? Nuestros ingenieros lo orientan <strong>sin costo</strong>.</p>
        </div>
      </div>
      <div class="l3-compare-wrap">
        <table class="l3-compare-table">
          <thead>
            <tr>
              <th scope="col">Característica</th>
              <th scope="col">MP-750</th>
              <th scope="col">MT-500</th>
              <th scope="col">MRT-1200</th>
            </tr>
          </thead>
          <tbody>
            <tr><th scope="row">Caudal (GPM)</th><td>250 – 750</td><td>200 – 500</td><td>500 – 1,200</td></tr>
            <tr><th scope="row">Peso / montaje</th><td>18 kg</td><td>12 kg</td><td>Remolque</td></tr>
            <tr><th scope="row">Material</th><td>Aluminio</td><td>Aluminio aeronáutico</td><td>Acero epóxico</td></tr>
            <tr><th scope="row">Despliegue</th><td>1 operador</td><td>Tipo mochila</td><td>Hidráulico</td></tr>
            <tr><th scope="row">Movilidad</th><td>Alta</td><td>Máxima</td><td>Con vehículo</td></tr>
            <tr><th scope="row">Espuma</th><td>Opcional</td><td>—</td><td>Sí</td></tr>
            <tr><th scope="row">Certificación</th><td>NFPA · UL</td><td>NFPA</td><td>FM Approved</td></tr>
            <tr><th scope="row">Ideal para</th><td>Brigadas</td><td>Acceso difícil</td><td>Grandes áreas</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Tabla de selección por escenario (diferenciador) -->
  <section class="l3-apps-section">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Guía de Selección</span>
          <h2>¿Qué Modelo Necesita su Operación?</h2>
        </div>
        <div class="section-header__body">
          <p>Una referencia rápida según el <strong>escenario de uso</strong> más frecuente en planta.</p>
          <p>La recomendación final siempre parte de un <strong>análisis de riesgo</strong>.</p>
        </div>
      </div>
      <div class="l3-compare-wrap">
        <table class="l3-compare-table">
          <thead>
            <tr><th scope="col">Escenario de uso</th><th scope="col">Modelo recomendado</th><th scope="col">Por qué</th></tr>
          </thead>
          <tbody>
            {seleccion.map(([esc, mod, por]) => (
              <tr><th scope="row">{esc}</th><td>{mod}</td><td>{por}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes al seleccionar</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones para empresas</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Equipos Portátiles con Capacitación de Brigada</h2>
          <p>
            En <strong>AQUEON</strong> entendemos que un monitor portátil solo protege si la brigada sabe usarlo. Por eso no
            solo distribuimos equipos certificados de Elkhart Brass, Akron Brass y Task Force Tips: entregamos
            <strong>capacitación especializada</strong> con simulacros reales, definimos el anclaje y las conexiones
            compatibles con su red, y damos mantenimiento conforme a NFPA 25, con cobertura en toda la República desde la
            Ciudad de México.
          </p>
          <p>
            Atendemos a <strong>brigadas industriales, cuerpos de bomberos, minería, parques industriales y proyectos
            PEMEX</strong>, con stock en México para entrega ágil y documentación completa. Somos uno de los principales
            especialistas en monitores contra incendios en México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/servicios#capacitacion" class="btn btn-outline-light"><i class="fas fa-chalkboard-user" aria-hidden="true"></i> Capacitación de brigadas</a>
            <a href="/nosotros" class="btn btn-outline-light"><i class="fas fa-building-shield" aria-hidden="true"></i> Conozca AQUEON</a>
          </div>
        </div>
        <div class="l3-normativas">
          <h3>Normativas aplicables</h3>
          <div class="l3-chips">
            <span class="l3-chip l3-chip--norm">NFPA Compliant</span>
            <span class="l3-chip l3-chip--norm">NFPA 25</span>
            <span class="l3-chip l3-chip--norm">NOM-002-STPS</span>
            <span class="l3-chip l3-chip--norm">UL Listed</span>
            <span class="l3-chip l3-chip--norm">FM Approved</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Monitores Portátiles" contexto="monitores portátiles" faqs={faqs} />

  <!-- Otras categorías -->
