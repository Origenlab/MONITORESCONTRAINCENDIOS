---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: 'NFPA 15·11·24', label: 'Normas base de diseño' },
  { numero: 'Hazen-Williams', label: 'Método de cálculo hidráulico' },
  { numero: 'FM · UL', label: 'Equipo certificado especificado' },
  { numero: 'Llave en mano', label: 'Del análisis a la entrega' },
];

const beneficios = [
  'Cálculos hidráulicos profesionales con memoria de cálculo',
  'Planos isométricos y especificaciones técnicas',
  'Análisis de riesgo y de cobertura por área',
  'Documentación lista para aseguradoras y Protección Civil',
  'Selección de equipo certificado FM Approved / UL Listed',
  'Diseño a la medida, sin sobredimensionar ni quedarse corto',
];

// DIFERENCIADOR 1 — Fases de la ingeniería (pg-chain)
const fases = [
  {
    id: 'analisis',
    eslabon: 'Fase 01',
    titulo: 'Análisis de Riesgo',
    icon: 'fas fa-magnifying-glass-chart',
    descripcion: 'Levantamos la instalación, definimos el escenario de incendio de diseño y la normativa aplicable a su actividad.',
    incluye: ['Levantamiento en sitio', 'Escenario de diseño', 'Marco normativo', 'Densidad de aplicación'],
    entrega: 'Informe de riesgo',
  },
  {
    id: 'calculo',
    eslabon: 'Fase 02',
    titulo: 'Cálculo Hidráulico',
    icon: 'fas fa-calculator',
    descripcion: 'Calculamos caudal, presión y pérdidas por fricción para dimensionar tubería, equipo y demanda de bomba.',
    incluye: ['Caudal y presión', 'Pérdidas Hazen-Williams', 'Balanceo de nodos', 'Demanda de bomba'],
    entrega: 'Memoria de cálculo',
  },
  {
    id: 'especificacion',
    eslabon: 'Fase 03',
    titulo: 'Especificación y Planos',
    icon: 'fas fa-compass-drafting',
    descripcion: 'Seleccionamos el equipo certificado y plasmamos el sistema en planos isométricos y especificaciones técnicas.',
    incluye: ['Selección de equipo', 'Planos isométricos', 'Especificaciones', 'Lista de materiales'],
    entrega: 'Paquete de ingeniería',
  },
  {
    id: 'documentacion',
    eslabon: 'Fase 04',
    titulo: 'Documentación y Entrega',
    icon: 'fas fa-folder-open',
    descripcion: 'Integramos el expediente técnico para aseguradoras, Protección Civil y auditorías, listo para construcción.',
    incluye: ['Expediente técnico', 'Doc. para aseguradora', 'Cumplimiento normativo', 'Soporte a obra'],
    entrega: 'Expediente completo',
  },
];

// DIFERENCIADOR 2 — Anatomía del cálculo hidráulico (pg-scen)
const calculo = [
  {
    icon: 'fas fa-gauge-high',
    nombre: 'Caudal de diseño (GPM)',
    descripcion: 'El flujo total que el sistema debe entregar sobre el área de operación.',
    define: 'Densidad de aplicación × área de diseño, según el riesgo.',
    norma: 'NFPA 15 / NFPA 11',
  },
  {
    icon: 'fas fa-droplet',
    nombre: 'Densidad de aplicación',
    descripcion: 'Galones por minuto por pie cuadrado que exige la norma para el riesgo.',
    define: 'El tipo de riesgo y el producto a proteger.',
    norma: 'NFPA 15 / NFPA 11',
  },
  {
    icon: 'fas fa-wave-square',
    nombre: 'Pérdidas por fricción',
    descripcion: 'Caída de presión a lo largo de la tubería y los accesorios.',
    define: 'Diámetro, longitud y factor C (Hazen-Williams).',
    norma: 'NFPA 13 / 15',
  },
  {
    icon: 'fas fa-arrow-up-9-1',
    nombre: 'Presión residual requerida',
    descripcion: 'La presión mínima necesaria en el punto hidráulicamente más desfavorable.',
    define: 'El equipo terminal y las pérdidas acumuladas.',
    norma: 'NFPA 15 / 24',
  },
  {
    icon: 'fas fa-pump-medical',
    nombre: 'Demanda de bomba',
    descripcion: 'El punto de operación (caudal y presión) que debe cubrir la bomba contra incendio.',
    define: 'La curva del sistema y la reserva de agua.',
    norma: 'NFPA 20',
  },
  {
    icon: 'fas fa-database',
    nombre: 'Reserva de agua',
    descripcion: 'El volumen de agua para sostener la demanda durante el tiempo normativo.',
    define: 'Caudal de diseño × duración requerida.',
    norma: 'NFPA 22 / 24',
  },
];

// DIFERENCIADOR 3 — Entregables (pg-sol)
const entregables = [
  {
    icon: 'fas fa-file-lines',
    titulo: 'Memoria de cálculo',
    texto: 'Documento de ingeniería con el cálculo hidráulico completo, hipótesis y resultados verificables.',
    producto: 'Solicitar ejemplo',
    url: '/contacto',
  },
  {
    icon: 'fas fa-ruler-combined',
    titulo: 'Planos isométricos',
    texto: 'Representación del sistema con diámetros, longitudes, equipo y nodos para construcción.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-list-check',
    titulo: 'Especificaciones técnicas',
    texto: 'Especificación de cada componente con su norma, material y certificación exigida.',
    producto: 'Ver catálogo de equipo',
    url: '/productos',
  },
  {
    icon: 'fas fa-clipboard-list',
    titulo: 'Lista de materiales',
    texto: 'Cuantificación detallada de equipo, tubería y accesorios para cotización y obra.',
    producto: 'Ver catálogo',
    url: '/productos',
  },
  {
    icon: 'fas fa-shield-halved',
    titulo: 'Análisis de riesgo y cobertura',
    texto: 'Escenario de incendio de diseño y verificación de cobertura por área protegida.',
    producto: 'Ver industrias',
    url: '/industrias',
  },
  {
    icon: 'fas fa-file-shield',
    titulo: 'Documentación para aseguradoras',
    texto: 'Expediente con certificaciones y cumplimiento normativo para auditoría y póliza.',
    producto: 'Consultoría normativa',
    url: '/servicios#consultoria-normativa',
  },
];

// pg-dens — Normativas aplicadas
const normativasTabla = [
  ['NFPA 15', 'Sistemas fijos de agua pulverizada', 'Enfriamiento y protección de equipos'],
  ['NFPA 11', 'Sistemas de espuma', 'Riesgos de hidrocarburo y solventes'],
  ['NFPA 24', 'Redes privadas de servicio contra incendios', 'Tubería de alimentación y tomas'],
  ['NFPA 13', 'Rociadores y criterios de fricción', 'Naves, almacenes y edificación'],
  ['NFPA 20', 'Bombas contra incendio', 'Dimensionamiento de la bomba'],
  ['NFPA 25', 'Inspección, prueba y mantenimiento', 'Previsto desde el diseño'],
];

const normativas = [
  { n: 'NFPA 15', d: 'Agua pulverizada' },
  { n: 'NFPA 11', d: 'Espuma' },
  { n: 'NFPA 24', d: 'Redes privadas contra incendio' },
  { n: 'NFPA 13', d: 'Rociadores y almacenamiento' },
  { n: 'NFPA 20', d: 'Bombas contra incendio' },
  { n: 'NFPA 22', d: 'Tanques de almacenamiento de agua' },
  { n: 'NFPA 25', d: 'Inspección, prueba y mantenimiento' },
  { n: 'NOM-002-STPS', d: 'Condiciones de seguridad' },
];

const errores = [
  'Comprar equipo antes de tener el cálculo hidráulico',
  'Dimensionar por catálogo y no por escenario de incendio',
  'Ignorar las pérdidas por fricción en redes largas',
  'No verificar la presión en el punto más desfavorable',
  'Omitir la demanda de bomba y la reserva de agua',
  'Diseñar sin pensar en el mantenimiento NFPA 25 futuro',
];

const recomendaciones = [
  'Empiece por el análisis de riesgo y el escenario de diseño',
  'Exija memoria de cálculo verificable, no solo una cotización',
  'Especifique equipo con certificación FM Approved / UL Listed',
  'Valide presión y caudal en el punto hidráulicamente crítico',
  'Integre bomba, reserva de agua y red como un solo sistema',
  'Prevea el mantenimiento y la documentación desde el diseño',
];

const faqs = [
  { q: '¿Qué es un cálculo hidráulico y por qué es indispensable?', a: 'Es el análisis de ingeniería que determina si la red de protección entregará el caudal y la presión necesarios en el punto más desfavorable. Parte de la densidad de aplicación que exige la norma para el riesgo, calcula las pérdidas por fricción a lo largo de la tubería (método Hazen-Williams) y verifica la presión residual y la demanda de bomba. Sin él, un sistema puede verse correcto en planos y fallar en una emergencia por falta de presión o caudal. Es la base de todo diseño serio.' },
  { q: '¿Qué normativa siguen para el diseño?', a: 'Diseñamos conforme a NFPA 15 (agua pulverizada), NFPA 11 (espuma) y NFPA 24 (redes privadas) como base, complementadas según el proyecto con NFPA 13 (rociadores y criterios de fricción), NFPA 20 (bombas), NFPA 22 (reserva de agua) y NFPA 25 (mantenimiento), además de la NOM-002-STPS y los requisitos de aseguradoras. La norma aplicable se define en el análisis de riesgo inicial.' },
  { q: '¿Qué entregables incluye el servicio de diseño?', a: 'Entregamos un paquete de ingeniería completo: informe de análisis de riesgo, memoria de cálculo hidráulico, planos isométricos, especificaciones técnicas por componente, lista de materiales cuantificada y la documentación de cumplimiento para aseguradoras y Protección Civil. Todo verificable y listo para construcción y auditoría.' },
  { q: '¿Diseñan para cualquier industria?', a: 'Sí. Adaptamos el diseño al riesgo de cada sector —petróleo y gas, petroquímica, energía, manufactura, minería, aviación y gobierno— porque cada uno impone densidades de aplicación, agentes y normativas distintas. El mismo rigor de cálculo se aplica, pero el escenario de incendio de diseño cambia con la actividad.' },
  { q: '¿Puedo contratar solo el diseño o debe incluir la instalación?', a: 'Puede contratar solo la ingeniería de diseño si su empresa ejecutará la obra o licitará la construcción. También ofrecemos el ciclo completo —diseño, instalación, puesta en marcha y mantenimiento— como solución llave en mano. En ambos casos, el paquete de ingeniería es suyo y queda documentado.' },
  { q: '¿El diseño me sirve para mi aseguradora?', a: 'Sí. La memoria de cálculo, los planos y la especificación de equipo certificado son precisamente lo que las aseguradoras y FM Global requieren para evaluar el riesgo y otorgar o mantener la cobertura. Integramos el expediente para que su área de seguros y la autoridad cuenten con la documentación que exigen.' },
  { q: '¿En cuánto tiempo entregan un diseño?', a: 'Depende del alcance, pero entregamos cotización técnica del servicio en menos de 24 horas y un cronograma claro de ingeniería según la complejidad. Para proyectos que lo requieran agendamos una visita técnica sin costo para el levantamiento y el escenario de incendio.' },
];
---
<Base
  title="Diseño e Ingeniería de Sistemas Contra Incendio | Cálculo Hidráulico NFPA | AQUEON México"
  description="Diseño e ingeniería de sistemas contra incendio conforme a NFPA 15, NFPA 11 y NFPA 24: cálculo hidráulico, planos isométricos, especificaciones y documentación para aseguradoras. Ingenieros certificados. Memoria de cálculo verificable con AQUEON México."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/servicios">Servicios</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Diseño e Ingeniería</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Servicios · Diseño e Ingeniería</span>
          <h1>Diseño e Ingeniería de Sistemas Contra Incendio</h1>
        </div>
        <div class="section-header__body">
          <p>Donde empieza todo sistema serio: el <strong>cálculo hidráulico</strong> y la especificación técnica.</p>
          <p>Ingenieros certificados, diseño conforme a <strong>NFPA 15, 11 y 24</strong> y memoria de cálculo verificable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El servicio</span>
          <h2>Un Sistema Vale lo que Vale su Ingeniería</h2>
          <p>
            Un monitor certificado, una buena bomba y la mejor tubería no sirven de nada si el sistema no fue
            <strong>calculado correctamente</strong>. La diferencia entre una instalación que protege y una que falla en la
            emergencia casi nunca está en el equipo: está en si alguien hizo el <strong>cálculo hidráulico</strong> que
            garantiza el caudal y la presión donde y cuando se necesitan.
          </p>
          <p>
            En AQUEON el diseño no es un trámite previo a la venta: es un servicio de ingeniería con entregables propios.
            Partimos del <strong>análisis de riesgo</strong>, calculamos conforme a <strong>NFPA 15, 11 y 24</strong>,
            seleccionamos equipo certificado FM Approved / UL Listed y entregamos una <strong>memoria de cálculo
            verificable</strong>, planos y especificaciones. Diseñamos a la medida: sin sobredimensionar ni quedarnos cortos.
          </p>
          <p>
            En esta página verá las fases de la ingeniería, la anatomía de un cálculo hidráulico, los entregables del
            servicio y las normas que aplicamos en cada proyecto.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Fases -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Metodología</span>
          <h2>Las Cuatro Fases de la Ingeniería</h2>
        </div>
        <div class="section-header__body">
          <p>Del <strong>análisis de riesgo</strong> a la <strong>documentación</strong>, cada fase tiene su entregable.</p>
          <p>Un proceso ordenado que convierte un riesgo en un sistema verificable.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {fases.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-list-ul" aria-hidden="true"></i> Incluye</span>
            <div class="l3-chips">
              {c.incluye.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-box-open" aria-hidden="true"></i> Entregable</span>
            <div class="l3-chips">
              <span class="l3-chip l3-chip--norm">{c.entrega}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Anatomía del cálculo -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Ingeniería a fondo</span>
          <h2>Anatomía de un Cálculo Hidráulico</h2>
        </div>
        <div class="section-header__body">
          <p>Esto es lo que hay detrás de una <strong>memoria de cálculo</strong>: no una cotización, sino ingeniería.</p>
          <p>Cada parámetro se calcula y se verifica contra la norma aplicable.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Parámetro</th>
              <th scope="col">Qué es</th>
              <th scope="col">Qué lo define</th>
              <th scope="col">Norma</th>
            </tr>
          </thead>
          <tbody>
            {calculo.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td>{e.define}</td>
                <td class="pg-scen-sol">{e.norma}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> Cada proyecto se calcula para su punto hidráulicamente más desfavorable; los valores se confirman en la memoria de cálculo.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Entregables -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Entregables</span>
          <h2>Lo que Recibe al Final del Diseño</h2>
        </div>
        <div class="section-header__body">
          <p>Un <strong>paquete de ingeniería</strong> completo, verificable y listo para construcción y auditoría.</p>
          <p>Documentación que sirve a su obra, a su aseguradora y a la autoridad.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {entregables.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- pg-dens: Normativas aplicadas -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Marco de diseño</span>
          <h2>Normas que Aplicamos en Cada Proyecto</h2>
          <p>
            No usamos una sola norma: el diseño combina el cuerpo normativo <strong>NFPA</strong> según el riesgo, el agente
            y la infraestructura del proyecto. Esta es la base con la que trabajamos; la combinación exacta se define en el
            análisis de riesgo inicial.
          </p>
          <a href="/servicios#consultoria-normativa" class="btn btn-outline"><i class="fas fa-file-contract" aria-hidden="true"></i> Ver consultoría normativa</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Norma</th><th scope="col">Qué rige</th><th scope="col">Cuándo aplica</th></tr>
            </thead>
            <tbody>
              {normativasTabla.map(([n, q, c]) => (
                <tr><th scope="row">{n}</th><td>{q}</td><td>{c}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Ingeniería que Respalda Cada Equipo que Vendemos</h2>
          <p>
            En <strong>AQUEON</strong> la ingeniería de diseño es la columna de todo lo que hacemos. Nuestros
            <strong>ingenieros certificados</strong> calculan, especifican y documentan conforme a NFPA, seleccionando equipo
            FM Approved y UL Listed de Elkhart Brass, Akron Brass y Task Force Tips. Entregamos memoria de cálculo verificable
            y acompañamos el proyecto de la mesa de diseño a la puesta en marcha.
          </p>
          <p>
            Diseñamos para <strong>PEMEX, CFE, refinerías, plantas, parques industriales, aeropuertos y gobierno</strong>,
            con documentación completa para aseguradoras y Protección Civil, y cobertura en los 32 estados de la República
            desde la Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/nosotros" class="btn btn-outline-light"><i class="fas fa-building-shield" aria-hidden="true"></i> Conozca AQUEON</a>
            <a href="/productos" class="btn btn-outline-light"><i class="fas fa-layer-group" aria-hidden="true"></i> Ver catálogo de equipo</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Normas de referencia</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Diseño e Ingeniería" contexto="el servicio de diseño e ingeniería y cálculo hidráulico" faqs={faqs} />

  <!-- Otros servicios -->
  <section class="l3-otras">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Ciclo Completo</span>
          <h2>Otros Servicios AQUEON</h2>
        </div>
        <div class="section-header__body">
          <p>Del diseño al mantenimiento, cubrimos <strong>todo el ciclo de vida</strong> de su sistema.</p>
          <p>Un solo proveedor con ingeniería, obra y soporte de por vida.</p>
        </div>
      </div>
      <div class="l3-otras-grid">
