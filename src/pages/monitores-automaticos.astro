---
import Base from '../layouts/Base.astro';

const modelos = [
  {
    id: 'ai-3000',
    modelo: 'AI-3000',
    nombre: 'Monitor Inteligente AI-3000',
    badge: 'Tecnología IA',
    badgePremium: true,
    icon: 'fas fa-brain',
    imagen: '/images/soporte-tecnico-monitores-contra-incendios-industrial.webp',
    resumen: 'Monitor con detección automática de incendios mediante inteligencia artificial, posicionamiento óptimo y conectividad IoT para monitoreo remoto en tiempo real.',
    descripcion: 'El AI-3000 representa la última generación: cámaras de visión por computadora con algoritmos de IA que distinguen un incendio real de un falso positivo, calculan el punto óptimo de ataque y orientan el monitor de forma autónoma en menos de tres segundos. Su conectividad IoT permite supervisar el estado del equipo y recibir alertas desde cualquier sala de control, integrándose con los sistemas DCS/SCADA de la planta.',
    specs: [
      ['Caudal nominal', '1,000 – 3,000 GPM'],
      ['Tecnología de detección', 'Inteligencia Artificial (visión por computadora)'],
      ['Conectividad', 'IoT · monitoreo remoto'],
      ['Tiempo de respuesta', '< 3 segundos'],
      ['Integración', 'Compatible con DCS / SCADA'],
      ['Posicionamiento', 'Autónomo · punto óptimo de ataque'],
      ['Certificación', 'FM Approved · SIL2'],
    ],
    aplicaciones: ['Patios de tanques', 'Áreas desatendidas', 'Infraestructura crítica', 'Monitoreo 24/7'],
  },
  {
    id: 'mo-2000',
    modelo: 'MO-2000',
    nombre: 'Monitor Oscilante MO-2000',
    badge: 'Cobertura Amplia',
    badgePremium: false,
    icon: 'fas fa-arrows-left-right',
    imagen: '/images/monitores-contra-incendios-industria-manufactura.webp',
    resumen: 'Oscilación programable con múltiples patrones de cobertura, ideal para protección automática de grandes áreas como patios de tanques y zonas de almacenamiento.',
    descripcion: 'El MO-2000 protege grandes superficies con un movimiento de oscilación programable. En lugar de un punto fijo, barre un área completa siguiendo uno de cuatro patrones configurables, garantizando enfriamiento uniforme sin intervención humana. Es la solución costo-eficiente para patios de tanques, racks de almacenamiento y zonas donde se requiere cobertura continua sobre una extensión amplia.',
    specs: [
      ['Caudal nominal', '750 – 2,000 GPM'],
      ['Modo de operación', '4 patrones de oscilación'],
      ['Control', 'Programable'],
      ['Cobertura', 'Barrido de área amplia'],
      ['Accionamiento', 'Hidráulico / eléctrico'],
      ['Material de construcción', 'Acero inoxidable'],
      ['Certificación', 'FM Approved'],
    ],
    aplicaciones: ['Patios de tanques', 'Racks de almacenamiento', 'Zonas amplias', 'Enfriamiento continuo'],
  },
  {
    id: 'mir-2500',
    modelo: 'MIR-2500',
    nombre: 'Monitor Infrarrojo MIR-2500',
    badge: 'Detección IR',
    badgePremium: false,
    icon: 'fas fa-satellite-dish',
    imagen: '/images/monitores-contra-incendios-planta-petroquimica.webp',
    resumen: 'Sistema de detección por infrarrojo dual con seguimiento automático de fuego, respuesta instantánea y precisión milimétrica para instalaciones de alto riesgo.',
    descripcion: 'El MIR-2500 utiliza detectores de infrarrojo dual (IR/IR) que identifican la firma térmica de una flama y siguen su desplazamiento en tiempo real. Con respuesta en menos de un segundo y certificación FM + SIL2, es el equipo indicado para los escenarios más críticos: refinerías, plantas químicas y áreas donde una ignición debe detectarse y atacarse de inmediato, antes de que escale.',
    specs: [
      ['Caudal nominal', '1,000 – 2,500 GPM'],
      ['Tecnología de detección', 'Infrarrojo dual (IR/IR)'],
      ['Tiempo de respuesta', '< 1 segundo'],
      ['Seguimiento', 'Automático de la flama'],
      ['Nivel de integridad', 'SIL2 (IEC 61508/61511)'],
      ['Material de construcción', 'Acero inoxidable / áreas clasificadas'],
      ['Certificación', 'FM Approved · SIL2'],
    ],
    aplicaciones: ['Refinerías', 'Plantas químicas', 'Alto riesgo', 'Detección crítica'],
  },
];

const stats = [
  { numero: '< 1 s', label: 'Tiempo de respuesta IR' },
  { numero: '24/7', label: 'Protección sin operador' },
  { numero: 'FM · SIL2', label: 'Certificación de seguridad' },
  { numero: 'IoT', label: 'Monitoreo remoto' },
];

const tecnologias = [
  { icon: 'fas fa-satellite-dish', titulo: 'Infrarrojo (IR/IR dual)', texto: 'Detecta la firma térmica de la flama y la sigue en tiempo real. Máxima fiabilidad con bajísima tasa de falsos positivos.' },
  { icon: 'fas fa-video', titulo: 'Visión por computadora (IA)', texto: 'Cámaras con algoritmos de IA que reconocen humo y fuego, distinguen falsas alarmas y calculan el punto óptimo de ataque.' },
  { icon: 'fas fa-temperature-high', titulo: 'Detección térmica', texto: 'Sensores que disparan ante umbrales de temperatura, complemento ideal en zonas con obstrucción visual.' },
  { icon: 'fas fa-network-wired', titulo: 'Integración DCS / SCADA', texto: 'El monitor se enlaza al sistema de control de la planta, formando parte de una función instrumentada de seguridad.' },
];

const beneficios = [
  'Protección continua las 24 horas, sin intervención humana',
  'Detección y respuesta en segundos, antes de que el fuego escale',
  'Eliminación del riesgo para el personal en zonas peligrosas',
  'Reducción de falsos positivos con detección multi-tecnología',
  'Monitoreo remoto y alertas en tiempo real vía IoT',
  'Integración con la arquitectura de seguridad existente (DCS/SCADA)',
];

const errores = [
  'Confiar en una sola tecnología de detección en escenarios críticos',
  'No considerar la tasa de falsos positivos del sistema seleccionado',
  'Omitir el nivel de integridad de seguridad (SIL) requerido',
  'Ignorar la integración con el sistema de control de la planta',
  'Subestimar el mantenimiento y la calibración de los sensores',
  'No definir la lógica de disparo y los enclavamientos con el equipo de proceso',
];

const recomendaciones = [
  'Defina el nivel SIL requerido según el análisis de riesgo (LOPA)',
  'Combine tecnologías de detección para máxima fiabilidad',
  'Verifique certificación FM Approved y cumplimiento IEC 61508/61511',
  'Planifique la integración con DCS/SCADA desde el diseño',
  'Incluya calibración y prueba de lazos en el plan de mantenimiento',
  'Solicite un estudio de cobertura y posicionamiento de detectores',
];

const comparativa = [
  ['Tecnología de detección', 'IA / visión', '— (oscilación)', 'IR/IR dual'],
  ['Tiempo de respuesta', '< 3 s', 'Continuo', '< 1 s'],
  ['Caudal (GPM)', '1,000 – 3,000', '750 – 2,000', '1,000 – 2,500'],
  ['Conectividad IoT', 'Sí', 'Opcional', 'Sí'],
  ['Nivel de seguridad', 'SIL2', 'FM', 'SIL2'],
  ['Ideal para', 'Áreas desatendidas', 'Grandes superficies', 'Detección crítica'],
];

const faqs = [
  { q: '¿Qué es un monitor automático contra incendios?', a: 'Es un monitor capaz de detectar un incendio y responder sin intervención humana. Integra sensores (infrarrojo, visión por IA o térmicos) que identifican la flama, orientan el cañón hacia el punto óptimo y abren la descarga de agua o espuma en segundos. Es la solución para áreas desatendidas o de tan alto riesgo que no es seguro que un operador se acerque.' },
  { q: '¿Cuál es la diferencia entre el AI-3000, el MO-2000 y el MIR-2500?', a: 'El AI-3000 usa inteligencia artificial y visión por computadora con conectividad IoT; el MO-2000 es un monitor oscilante programable para cubrir grandes áreas de forma continua; y el MIR-2500 emplea detección por infrarrojo dual con respuesta en menos de un segundo para los escenarios más críticos. La elección depende del tipo de área, el riesgo y la velocidad de respuesta requerida.' },
  { q: '¿Qué tan confiable es la detección por IA frente a los falsos positivos?', a: 'Los sistemas modernos de visión por IA están entrenados para distinguir un incendio real de reflejos, vapor o movimiento, reduciendo drásticamente los falsos positivos. Para máxima fiabilidad recomendamos combinar tecnologías —por ejemplo, IA con confirmación por infrarrojo— de modo que la descarga solo se active ante una detección validada.' },
  { q: '¿Qué significa la certificación SIL2?', a: 'SIL (Safety Integrity Level) es el Nivel de Integridad de Seguridad definido por las normas IEC 61508 e IEC 61511. SIL2 indica una probabilidad de falla bajo demanda verificada, propia de funciones instrumentadas de seguridad. En la práctica, garantiza que el sistema de detección y supresión actuará cuando se le necesite, requisito frecuente en refinerías y plantas químicas.' },
  { q: '¿Se integran con el sistema de control de la planta (DCS/SCADA)?', a: 'Sí. El AI-3000 y el MIR-2500 se enlazan con la arquitectura DCS/SCADA, lo que permite enclavamientos con el proceso, registro de eventos, alertas remotas y supervisión del estado del equipo. La integración se diseña junto con el equipo de instrumentación de la planta.' },
  { q: '¿Los monitores automáticos sustituyen a la brigada?', a: 'No la sustituyen: la potencian. El sistema automático gana los segundos críticos iniciales atacando el fuego de inmediato, mientras la brigada se moviliza con sus equipos fijos y portátiles. Un programa robusto combina detección automática, monitores fijos y equipos portátiles.' },
  { q: '¿Funcionan con espuma para hidrocarburos?', a: 'Sí. Los monitores automáticos pueden descargar solución espumante para riesgos de hidrocarburos, integrándose con sistemas de proporcionamiento bajo NFPA 11. La configuración del agente y la dosificación forman parte del diseño integral del sistema.' },
  { q: '¿Qué mantenimiento requieren los sistemas de detección?', a: 'Los detectores requieren limpieza, calibración periódica y prueba de los lazos de seguridad para mantener su nivel SIL. Nuestro servicio de mantenimiento preventivo conforme a NFPA 25 incluye la verificación de sensores, actuadores y la lógica de disparo, con reportes documentados para auditoría.' },
  { q: '¿En qué industrias se usan los monitores automáticos?', a: 'Principalmente en refinerías, petroquímica, terminales de almacenamiento, generación de energía y cualquier instalación con áreas desatendidas o de muy alto riesgo. También en bandas transportadoras, patios de tanques y subestaciones, donde la respuesta debe ser inmediata y continua.' },
  { q: '¿En cuánto tiempo entregan una cotización?', a: 'Respondemos cotizaciones técnicas en menos de 24 horas hábiles. Para sistemas automáticos solemos proponer una visita técnica para definir el estudio de cobertura de detección y la integración con el sistema de control, sin costo.' },
];
---
<Base
  title="Monitores Automáticos Contra Incendios | Detección IA, IR y SIL2 | AQUEON México"
  description="Monitores automáticos contra incendios con detección por inteligencia artificial e infrarrojo: AI-3000, MO-2000 oscilante y MIR-2500. Respuesta en menos de 1 segundo, certificación FM y SIL2, integración DCS/SCADA. Venta e ingeniería en México con AQUEON."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/productos">Productos</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Monitores Automáticos</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Catálogo · Monitores Automáticos</span>
          <h1>Monitores Automáticos e Inteligentes</h1>
        </div>
        <div class="section-header__body">
          <p>Protección que <strong>detecta y responde sola</strong>: ataca el fuego en segundos, sin exponer a nadie.</p>
          <p>Detección por <strong>IA e infrarrojo</strong>, certificación FM y SIL2, e integración con su sistema de control.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">¿Qué es un monitor automático?</span>
          <h2>La Protección que No Duerme</h2>
          <p>
            Un <strong>monitor automático contra incendios</strong> es un cañón de agua o espuma que detecta un incendio y
            responde por sí mismo, sin que una persona tenga que verlo, decidir y actuar. Integra sensores —infrarrojo,
            visión por inteligencia artificial o térmicos— que identifican la flama, orientan el equipo hacia el punto
            óptimo y abren la descarga en cuestión de segundos.
          </p>
          <p>
            La diferencia es el tiempo. En un incendio industrial, los primeros segundos definen si será un conato
            controlado o una pérdida total. Un sistema automático actúa de inmediato, de día o de madrugada, en un patio de
            tanques desierto o en una zona donde sería peligroso que un operador se acercara. Por eso es la elección para
            <a href="/industrias#petroleo-gas">refinerías</a>, plantas químicas e infraestructura crítica.
          </p>
          <p>
            Diseñar un sistema automático va más allá del monitor: implica seleccionar la tecnología de detección adecuada,
            definir el nivel de integridad de seguridad (SIL) y planificar la integración con el sistema de control de la
            planta. En esta página encontrará los tres modelos automáticos de AQUEON y la guía técnica para especificarlos.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Tecnologías de detección (diferenciador de esta L3) -->
  <section class="l3-proceso">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Tecnologías de Detección</span>
          <h2>Cómo "Ve" el Fuego un Monitor Automático</h2>
        </div>
        <div class="section-header__body">
          <p>La fiabilidad del sistema depende de <strong>qué y cómo detecta</strong>. Cada tecnología tiene su fortaleza.</p>
          <p>En escenarios críticos combinamos varias para <strong>validar la detección</strong> y evitar falsas alarmas.</p>
        </div>
      </div>
      <div class="l3-proceso-grid">
        {tecnologias.map((t) => (
          <div class="l3-step">
            <span class="l3-step-icon" aria-hidden="true"><i class={t.icon}></i></span>
            <h3>{t.titulo}</h3>
            <p>{t.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modelos -->
  <section class="l3-modelos">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Nuestros Modelos</span>
          <h2>Tres Sistemas para Cada Estrategia</h2>
        </div>
        <div class="section-header__body">
          <p>De la inteligencia artificial al barrido programable y la detección por infrarrojo, cada modelo cubre una <strong>necesidad distinta</strong>.</p>
          <p>Todos con <strong>certificación FM</strong> y capacidad de integración a su planta.</p>
        </div>
      </div>

      {modelos.map((m, i) => (
        <article id={m.id} class:list={['l3-model', i % 2 === 1 && 'l3-model--rev']}>
          <div class="l3-model-media">
            <img src={m.imagen} alt={`${m.nombre} — monitor automático contra incendios AQUEON`} loading="lazy" />
            <span class:list={['l3-model-badge', m.badgePremium && 'is-premium']}><i class={m.icon} aria-hidden="true"></i> {m.badge}</span>
          </div>
          <div class="l3-model-content">
            <span class="l3-model-kicker">{m.modelo}</span>
            <h3>{m.nombre}</h3>
            <p class="l3-model-resumen">{m.resumen}</p>
            <p>{m.descripcion}</p>

            <table class="l3-spec-table">
              <tbody>
                {m.specs.map(([k, v]) => (
                  <tr><th scope="row">{k}</th><td>{v}</td></tr>
                ))}
              </tbody>
            </table>

            <div class="l3-model-apps">
              <span class="l3-apps-label"><i class="fas fa-location-dot" aria-hidden="true"></i> Aplicaciones</span>
              <div class="l3-chips">
                {m.aplicaciones.map((a) => <span class="l3-chip">{a}</span>)}
              </div>
            </div>

            <div class="l3-model-actions">
              <a href="/contacto" class="btn btn-primary"><i class="fas fa-file-invoice" aria-hidden="true"></i> Cotizar el {m.modelo}</a>
              <a href={`https://wa.me/5215512345678?text=Hola%20AQUEON%2C%20me%20interesa%20el%20monitor%20autom%C3%A1tico%20${m.modelo}`} class="btn btn-outline" target="_blank" rel="noopener"><i class="fab fa-whatsapp" aria-hidden="true"></i> WhatsApp</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Tabla comparativa -->
  <section class="l3-compare">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Comparativa</span>
          <h2>AI-3000 vs MO-2000 vs MIR-2500</h2>
        </div>
        <div class="section-header__body">
          <p>Tecnología de detección, velocidad y cobertura: las variables que <strong>definen la estrategia</strong>.</p>
          <p>Nuestros ingenieros diseñan el sistema completo, <strong>sin costo de asesoría</strong>.</p>
        </div>
      </div>
      <div class="l3-compare-wrap">
        <table class="l3-compare-table">
          <thead>
            <tr>
              <th scope="col">Característica</th>
              <th scope="col">AI-3000</th>
              <th scope="col">MO-2000</th>
              <th scope="col">MIR-2500</th>
            </tr>
          </thead>
          <tbody>
            {comparativa.map(([c, a, b, d]) => (
              <tr><th scope="row">{c}</th><td>{a}</td><td>{b}</td><td>{d}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes al especificar</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones de ingeniería</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Ingeniería de Sistemas Automáticos de Supresión</h2>
          <p>
            Un monitor automático no se vende: se diseña. En <strong>AQUEON</strong> integramos equipos certificados FM y
            SIL2 con la tecnología de detección adecuada, definimos la lógica de disparo y los enclavamientos con su
            <strong>sistema DCS/SCADA</strong>, y entregamos el estudio de cobertura, la documentación de seguridad
            funcional y el mantenimiento NFPA 25 que mantiene vigente el nivel SIL. Todo con cobertura nacional desde la
            Ciudad de México.
          </p>
          <p>
            Atendemos proyectos de <strong>PEMEX, CFE, refinerías, petroquímica y generación de energía</strong>, donde la
            detección y supresión automática son críticas. Somos uno de los principales especialistas en monitores contra
            incendios industriales en México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/servicios#diseno-ingenieria" class="btn btn-outline-light"><i class="fas fa-compass-drafting" aria-hidden="true"></i> Diseño e ingeniería</a>
            <a href="/recursos" class="btn btn-outline-light"><i class="fas fa-book" aria-hidden="true"></i> Normas y certificaciones</a>
          </div>
        </div>
        <div class="l3-normativas">
          <h3>Normativas y estándares</h3>
          <div class="l3-chips">
            <span class="l3-chip l3-chip--norm">FM Approved</span>
            <span class="l3-chip l3-chip--norm">SIL2</span>
            <span class="l3-chip l3-chip--norm">IEC 61508</span>
            <span class="l3-chip l3-chip--norm">IEC 61511</span>
            <span class="l3-chip l3-chip--norm">NFPA 15</span>
            <span class="l3-chip l3-chip--norm">NFPA 72</span>
            <span class="l3-chip l3-chip--norm">NFPA 25</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="l3-faq">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Preguntas Frecuentes</span>
          <h2>Dudas sobre Monitores Automáticos</h2>
        </div>
        <div class="section-header__body">
          <p>Respuestas técnicas para <strong>ingenieros de instrumentación, seguridad de procesos y proyecto</strong>.</p>
          <p>¿No encuentra su pregunta? Un especialista le responde en <strong>menos de 24 horas</strong>.</p>
        </div>
      </div>
      <div class="l3-faq-list">
        {faqs.map((f, i) => (
          <details class="l3-faq-item" open={i === 0}>
            <summary><span>{f.q}</span><i class="fas fa-plus l3-faq-icon" aria-hidden="true"></i></summary>
            <div class="l3-faq-answer"><p set:html={f.a} /></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Otras categorías -->
  <section class="l3-otras">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Catálogo Completo</span>
          <h2>Otras Categorías de Producto</h2>
        </div>
        <div class="section-header__body">
          <p>La detección automática se integra con la <strong>red fija, los equipos portátiles y los accesorios</strong>.</p>
          <p>Una sola fuente para todo su sistema de protección contra incendios.</p>
        </div>
