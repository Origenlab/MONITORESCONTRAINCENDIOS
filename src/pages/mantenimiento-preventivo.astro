---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: 'NFPA 25', label: 'Inspección, prueba y mantenimiento' },
  { numero: 'ITM', label: 'Programa documentado por frecuencia' },
  { numero: 'OEM', label: 'Refacciones originales de fábrica' },
  { numero: '32', label: 'Estados con cobertura de servicio' },
];

const beneficios = [
  'Programa anual de inspección, prueba y mantenimiento (ITM)',
  'Reportes de condición y bitácora por equipo',
  'Detección temprana de deficiencias antes de la emergencia',
  'Refacciones originales y técnicos con experiencia industrial',
  'Expediente listo para auditorías y aseguradoras',
  'Disponibilidad garantizada de su sistema cuando lo necesite',
];

// DIFERENCIADOR 1 — Cómo opera el programa (pg-chain)
const fases = [
  {
    id: 'inventario',
    eslabon: 'Fase 01',
    titulo: 'Inventario y Línea Base',
    icon: 'fas fa-clipboard-list',
    descripcion: 'Levantamos cada equipo del sistema, registramos su condición actual y establecemos la línea base contra la cual se medirá.',
    incluye: ['Inventario de equipo', 'Condición inicial', 'Identificación (TAG)', 'Historial existente'],
    entrega: 'Censo de activos',
  },
  {
    id: 'calendario',
    eslabon: 'Fase 02',
    titulo: 'Calendario ITM',
    icon: 'fas fa-calendar-check',
    descripcion: 'Definimos las frecuencias de inspección, prueba y mantenimiento por componente conforme a NFPA 25, en un calendario anual.',
    incluye: ['Frecuencias NFPA 25', 'Plan anual', 'Asignación de recursos', 'Protocolos por equipo'],
    entrega: 'Programa anual',
  },
  {
    id: 'ejecucion',
    eslabon: 'Fase 03',
    titulo: 'Ejecución Documentada',
    icon: 'fas fa-screwdriver-wrench',
    descripcion: 'Ejecutamos las actividades programadas, registramos resultados y reportamos cualquier deficiencia con su nivel de criticidad.',
    incluye: ['Inspección y prueba', 'Lubricación y ajuste', 'Registro de resultados', 'Reporte de deficiencias'],
    entrega: 'Reporte de servicio',
  },
  {
    id: 'analisis',
    eslabon: 'Fase 04',
    titulo: 'Análisis y Mejora',
    icon: 'fas fa-chart-line',
    descripcion: 'Analizamos la condición del sistema en el tiempo, anticipamos refacciones y recomendamos acciones correctivas o de mejora.',
    incluye: ['Análisis de tendencia', 'Plan de refacciones', 'Dictamen de condición', 'Recomendaciones'],
    entrega: 'Dictamen anual',
  },
];

// DIFERENCIADOR 2 — Matriz de frecuencias NFPA 25 (pg-scen)
const frecuencias = [
  {
    icon: 'fas fa-eye',
    nombre: 'Inspección visual del monitor',
    descripcion: 'Estado físico, corrosión, fugas y señalización del monitor y sus conexiones.',
    frecuencia: 'Trimestral',
    norma: 'NFPA 25',
  },
  {
    icon: 'fas fa-arrows-rotate',
    nombre: 'Operación en todo su rango',
    descripcion: 'Giro, elevación y patrón de descarga; en remotos, prueba de control.',
    frecuencia: 'Anual',
    norma: 'NFPA 25',
  },
  {
    icon: 'fas fa-oil-can',
    nombre: 'Lubricación y ajuste',
    descripcion: 'Lubricación de mecanismos y verificación de pares de apriete.',
    frecuencia: 'Anual',
    norma: 'NFPA 25 / OEM',
  },
  {
    icon: 'fas fa-faucet',
    nombre: 'Inspección de válvulas de control',
    descripcion: 'Posición, accesibilidad, sello y candadeo de las válvulas.',
    frecuencia: 'Mensual / Trimestral',
    norma: 'NFPA 25',
  },
  {
    icon: 'fas fa-pump-medical',
    nombre: 'Prueba de bomba contra incendio',
    descripcion: 'Arranque sin flujo y prueba de flujo contra la curva de la bomba.',
    frecuencia: 'Semanal / Anual',
    norma: 'NFPA 25 / 20',
  },
  {
    icon: 'fas fa-gauge-high',
    nombre: 'Prueba de flujo del sistema',
    descripcion: 'Verificación de caudal y presión disponibles contra el diseño.',
    frecuencia: 'Anual',
    norma: 'NFPA 25',
  },
  {
    icon: 'fas fa-clock-rotate-left',
    nombre: 'Prueba hidrostática de mangueras',
    descripcion: 'Presurización de mangueras de servicio para verificar integridad.',
    frecuencia: 'Cada 5 años',
    norma: 'NFPA 1962',
  },
];

// DIFERENCIADOR 3 — Qué recibe (pg-sol)
const recibe = [
  {
    icon: 'fas fa-calendar-days',
    titulo: 'Programa anual ITM',
    texto: 'Calendario de inspección, prueba y mantenimiento por equipo y frecuencia conforme a NFPA 25.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-clipboard-check',
    titulo: 'Reporte de inspección',
    texto: 'Registro de cada visita con resultados, mediciones y evidencia fotográfica.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-book',
    titulo: 'Bitácora por equipo',
    texto: 'Historial de mantenimiento de cada monitor y componente, trazable en el tiempo.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-triangle-exclamation',
    titulo: 'Alertas de deficiencias',
    texto: 'Notificación de hallazgos con su criticidad y la acción correctiva recomendada.',
    producto: 'Ver mantenimiento correctivo',
    url: '/mantenimiento-correctivo',
  },
  {
    icon: 'fas fa-box-open',
    titulo: 'Plan de refacciones',
    texto: 'Previsión de refacciones originales para evitar paros por falta de partes.',
    producto: 'Ver catálogo de equipo',
    url: '/productos',
  },
  {
    icon: 'fas fa-file-shield',
    titulo: 'Expediente para auditoría',
    texto: 'Documentación de cumplimiento NFPA 25 lista para aseguradoras y Protección Civil.',
    producto: 'Ver consultoría normativa',
    url: '/consultoria-normativa',
  },
];

// pg-dens — Sin programa vs con programa
const comparativa = [
  ['Disponibilidad del sistema', 'Incierta: se descubre la falla en la emergencia', 'Verificada y documentada todo el año'],
  ['Cumplimiento normativo', 'En riesgo ante auditoría o aseguradora', 'Expediente NFPA 25 al día'],
  ['Costo de fallas', 'Reparaciones de emergencia y paros', 'Deficiencias detectadas a tiempo'],
  ['Vida útil del equipo', 'Reducida por desgaste no atendido', 'Extendida por mantenimiento programado'],
];

const normativas = [
  { n: 'NFPA 25', d: 'Inspección, prueba y mantenimiento (ITM)' },
  { n: 'NFPA 20', d: 'Prueba de bombas contra incendio' },
  { n: 'NFPA 15', d: 'Sistemas fijos de agua pulverizada' },
  { n: 'NFPA 11', d: 'Sistemas de espuma' },
  { n: 'NFPA 1962', d: 'Cuidado y prueba de mangueras' },
  { n: 'NOM-002-STPS', d: 'Condiciones de seguridad — prevención de incendios' },
];

const errores = [
  'Suponer que un sistema instalado funciona sin verificarlo',
  'Mantener sin un calendario por frecuencia conforme a NFPA 25',
  'No documentar inspecciones, pruebas ni deficiencias',
  'Usar refacciones genéricas en equipo certificado',
  'Descubrir la falla de la bomba durante la emergencia',
  'Llegar a la auditoría sin expediente de mantenimiento',
];

const recomendaciones = [
  'Establezca un programa ITM por frecuencia conforme a NFPA 25',
  'Documente cada inspección, prueba y deficiencia',
  'Pruebe la bomba contra incendio con la periodicidad debida',
  'Use refacciones originales en equipo certificado',
  'Anticipe refacciones con un plan basado en condición',
  'Mantenga el expediente al día para auditoría y aseguradora',
];

const faqs = [
  { q: '¿Qué es la NFPA 25 y por qué rige el mantenimiento?', a: 'La NFPA 25 es la norma de Inspección, Prueba y Mantenimiento (ITM) de sistemas de protección contra incendios basados en agua. Define qué se revisa, cómo se prueba y con qué frecuencia cada componente —del monitor a la bomba y las válvulas— para garantizar que el sistema funcione el día de la emergencia. Un programa de mantenimiento serio no es "revisar de vez en cuando": es ejecutar y documentar las actividades de la NFPA 25 en su calendario correspondiente.' },
  { q: '¿Con qué frecuencia se debe dar mantenimiento a un monitor?', a: 'Depende de la actividad. La NFPA 25 establece, por ejemplo, inspección visual trimestral, operación del monitor en todo su rango de forma anual, y lubricación y ajuste anuales; las válvulas de control se inspeccionan mensual o trimestralmente, y la bomba contra incendio se prueba semanalmente (arranque) y anualmente (flujo). En nuestro servicio integramos todas estas frecuencias en un solo calendario por equipo.' },
  { q: '¿Qué pasa si no doy mantenimiento preventivo?', a: 'El riesgo principal es descubrir la falla en el peor momento: durante una emergencia. Sin un programa, la disponibilidad del sistema es incierta, el equipo se desgasta sin atención, el costo se traslada a reparaciones de emergencia y paros, y el incumplimiento queda expuesto ante una auditoría o la aseguradora. El mantenimiento preventivo convierte un riesgo invisible en una condición verificada y documentada.' },
  { q: '¿Qué documentación entregan en cada visita?', a: 'Entregamos un reporte de inspección con los resultados y mediciones de cada actividad, evidencia fotográfica, la bitácora actualizada del equipo y un reporte de deficiencias con su criticidad y la acción recomendada. De forma anual, integramos un dictamen de condición del sistema. Todo conforma el expediente que su operación, aseguradora y Protección Civil requieren.' },
  { q: '¿Usan refacciones originales?', a: 'Sí. Como distribuidores autorizados de Elkhart Brass, Akron Brass y Task Force Tips, usamos refacciones originales de fábrica (OEM). En equipo certificado FM Approved / UL Listed, una refacción genérica puede invalidar la certificación y comprometer el desempeño; por eso no las usamos. Además, prevemos las refacciones con un plan basado en la condición para evitar paros por falta de partes.' },
  { q: '¿El programa me sirve para mi aseguradora y para auditorías?', a: 'Sí. El expediente de cumplimiento NFPA 25 —programa, reportes, bitácoras y dictamen— es precisamente lo que las aseguradoras y la autoridad solicitan para verificar que el sistema se mantiene operativo. Un buen historial de mantenimiento no solo reduce el riesgo: respalda su póliza y facilita las auditorías.' },
  { q: '¿Atienden cualquier marca o solo equipo AQUEON?', a: 'Atendemos su sistema completo. Aunque somos especialistas en las marcas que distribuimos, nuestro programa NFPA 25 cubre monitores, válvulas, bombas y red de otras marcas, integrando todo en un solo calendario y un solo responsable, con cobertura en los 32 estados de la República.' },
];
---
<Base
  title="Mantenimiento Contra Incendios | Preventivo NFPA 25"
  description="Mantenimiento preventivo contra incendios NFPA 25: programa de inspección, prueba y mantenimiento (ITM), reportes y refacciones originales. AQUEON México."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/servicios">Servicios</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Mantenimiento Preventivo</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Servicios · Mantenimiento Preventivo</span>
          <h1>Mantenimiento Preventivo de Sistemas Contra Incendio</h1>
        </div>
        <div class="section-header__body">
          <p>Un sistema solo sirve si funciona <strong>el día de la emergencia</strong>. Eso se garantiza, no se supone.</p>
          <p>Programa de inspección, prueba y mantenimiento conforme a <strong>NFPA 25</strong>, documentado y trazable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El servicio</span>
          <h2>La Disponibilidad no se Supone: se Verifica</h2>
          <p>
            Un sistema contra incendio pasa el 99.9% de su vida sin usarse. El problema es que nadie sabe si funcionará en
            ese 0.1% que importa —la emergencia— a menos que se <strong>inspeccione y se pruebe con método</strong>. Una
            válvula cerrada por error, una bomba que no arranca o un monitor agarrotado por falta de lubricación convierten
            una inversión en protección en una falsa sensación de seguridad.
          </p>
          <p>
            El mantenimiento preventivo de AQUEON sigue la <strong>NFPA 25</strong>, la norma de inspección, prueba y
            mantenimiento (ITM). No "revisamos de vez en cuando": ejecutamos un <strong>programa por frecuencia</strong>,
            documentamos cada actividad, detectamos deficiencias antes de que sean fallas y entregamos el expediente que su
            aseguradora y la autoridad exigen. Con refacciones originales y un solo responsable.
          </p>
          <p>
            En esta página verá cómo opera el programa, la matriz de frecuencias de la NFPA 25, lo que recibe en cada visita
            y la diferencia entre operar con programa y sin él.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Cómo opera el programa -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Metodología</span>
          <h2>Cómo Opera un Programa NFPA 25</h2>
        </div>
        <div class="section-header__body">
          <p>Del <strong>inventario</strong> al <strong>dictamen anual</strong>, un ciclo que mejora con el tiempo.</p>
          <p>Cada fase con su entregable, para que el mantenimiento sea trazable.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {fases.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-list-ul" aria-hidden="true"></i> Incluye</span>
            <div class="l3-chips">
              {c.incluye.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-box-open" aria-hidden="true"></i> Entregable</span>
            <div class="l3-chips">
              <span class="l3-chip l3-chip--norm">{c.entrega}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Matriz de frecuencias -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">El corazón del servicio</span>
          <h2>Matriz de Frecuencias NFPA 25</h2>
        </div>
        <div class="section-header__body">
          <p>No todo se revisa igual ni con la misma <strong>periodicidad</strong>: esto es lo que exige la norma.</p>
          <p>Cada actividad en su frecuencia, integrada en un solo calendario.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Actividad</th>
              <th scope="col">En qué consiste</th>
              <th scope="col">Frecuencia</th>
              <th scope="col">Norma</th>
            </tr>
          </thead>
          <tbody>
            {frecuencias.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td class="pg-scen-sol">{e.frecuencia}</td>
                <td>{e.norma}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> Las frecuencias son las que establece la NFPA 25; el programa final se ajusta al tipo de sistema y a las condiciones del sitio.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Qué recibe -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Entregables</span>
          <h2>Qué Recibe con el Programa</h2>
        </div>
        <div class="section-header__body">
          <p>Documentación que demuestra que su sistema está <strong>operativo y al día</strong>.</p>
          <p>Cada entregable enlaza con el servicio o equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {recibe.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- pg-dens: Sin vs con programa -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">El valor real</span>
          <h2>Con Programa vs Sin Programa</h2>
          <p>
            La diferencia entre tener un programa NFPA 25 y no tenerlo no se ve en el día a día: se ve el día de la
            emergencia y el día de la auditoría. El mantenimiento preventivo convierte un <strong>riesgo invisible</strong>
            en una condición verificada, documentada y respaldada.
          </p>
          <a href="/servicios#planes" class="btn btn-outline"><i class="fas fa-layer-group" aria-hidden="true"></i> Ver planes de servicio</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Aspecto</th><th scope="col">Sin programa</th><th scope="col">Con programa NFPA 25</th></tr>
            </thead>
            <tbody>
              {comparativa.map(([a, s, c]) => (
                <tr><th scope="row">{a}</th><td>{s}</td><td class="pg-dens-ok">{c}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Su Sistema, Operativo el Día que Importa</h2>
          <p>
            En <strong>AQUEON</strong> el mantenimiento no es un servicio de relleno: es lo que garantiza que toda la
            inversión en diseño, equipo e instalación realmente proteja. Ejecutamos programas <strong>NFPA 25</strong> con
            técnicos de experiencia industrial y <strong>refacciones originales</strong>, documentamos cada actividad y
            anticipamos deficiencias antes de que se vuelvan fallas. Un solo responsable de todo el ciclo de vida.
          </p>
          <p>
            Mantenemos sistemas en <strong>refinerías, plantas, parques industriales, aeropuertos, minería y gobierno</strong>,
            con expediente de cumplimiento completo y cobertura en los 32 estados de la República desde la Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/mantenimiento-correctivo" class="btn btn-outline-light"><i class="fas fa-wrench" aria-hidden="true"></i> Mantenimiento correctivo</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Todos los servicios</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Normas de referencia</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Mantenimiento Preventivo" contexto="el servicio de mantenimiento preventivo NFPA 25" faqs={faqs} />

  <!-- Otros servicios -->
  <section class="l3-otras">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Ciclo Completo</span>
          <h2>Otros Servicios AQUEON</h2>
        </div>
        <div class="section-header__body">
          <p>Del diseño al mantenimiento, cubrimos <strong>todo el ciclo de vida</strong> de su sistema.</p>
          <p>Un solo proveedor con ingeniería, obra y soporte de por vida.</p>
        </div>
      </div>
      <div class="l3-otras-grid">
        <a href="/instalacion" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i></span><span class="l3-otra-name">Instalación Profesional</span><span class="l3-otra-sub">Montaje certificado · pruebas</span></a>
        <a href="/mantenimiento-correctivo" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-wrench" aria-hidden="true"></i></span><span class="l3-otra-name">Mantenimiento Correctivo</span><span class="l3-otra-sub">Respuesta 24/7</span></a>
