---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: 'DC-3', label: 'Constancia oficial STPS' },
  { numero: 'NOM-002', label: 'Brigadas y prevención de incendios' },
  { numero: 'Teoría + Práctica', label: 'Formación con simulacros reales' },
  { numero: 'En sitio', label: 'Capacitación en su instalación' },
];

const beneficios = [
  'Capacitación teórico-práctica con simulacros reales',
  'Certificados de competencia y constancia DC-3 (STPS)',
  'Programa a la medida del equipo y el riesgo de su planta',
  'Manual de operación y material didáctico incluidos',
  'Cumplimiento de la NOM-002-STPS en materia de brigadas',
  'Instructores con experiencia industrial de campo',
];

// DIFERENCIADOR 1 — Fases del programa (pg-chain)
const fases = [
  {
    id: 'diagnostico',
    eslabon: 'Fase 01',
    titulo: 'Diagnóstico de Necesidades',
    icon: 'fas fa-magnifying-glass-chart',
    descripcion: 'Evaluamos el riesgo de su instalación, el equipo instalado y el perfil del personal para definir los objetivos de formación.',
    incluye: ['Análisis de riesgo', 'Equipo a operar', 'Perfil del personal', 'Objetivos de formación'],
    entrega: 'Plan de necesidades',
  },
  {
    id: 'plan',
    eslabon: 'Fase 02',
    titulo: 'Plan de Formación',
    icon: 'fas fa-list-check',
    descripcion: 'Diseñamos el temario, la modalidad y la duración a la medida del nivel de competencia que su personal requiere.',
    incluye: ['Temario a la medida', 'Modalidad y duración', 'Material didáctico', 'Calendario'],
    entrega: 'Programa de curso',
  },
  {
    id: 'ejecucion',
    eslabon: 'Fase 03',
    titulo: 'Ejecución Teórico-Práctica',
    icon: 'fas fa-fire-extinguisher',
    descripcion: 'Impartimos la teoría y la llevamos a la práctica con ejercicios y simulacros sobre el equipo real de su planta.',
    incluye: ['Sesiones teóricas', 'Práctica con equipo', 'Simulacros', 'Protocolos de emergencia'],
    entrega: 'Curso impartido',
  },
  {
    id: 'certificacion',
    eslabon: 'Fase 04',
    titulo: 'Evaluación y Certificación',
    icon: 'fas fa-certificate',
    descripcion: 'Evaluamos la competencia adquirida y emitimos los certificados y la constancia DC-3 ante la STPS.',
    incluye: ['Evaluación de competencia', 'Certificados', 'Constancia DC-3', 'Registro de asistencia'],
    entrega: 'Expediente de formación',
  },
];

// DIFERENCIADOR 2 — Temario del programa (pg-scen)
const temario = [
  {
    icon: 'fas fa-fire',
    nombre: 'Fundamentos del fuego',
    descripcion: 'Tetraedro del fuego, clases de fuego y métodos de extinción aplicados a la industria.',
    modulo: 'Teórico',
    norma: 'Protocolos NFPA',
  },
  {
    icon: 'fas fa-fire-extinguisher',
    nombre: 'Equipo y operación de monitores',
    descripcion: 'Uso correcto, seguro y eficiente de monitores, boquillas y sistemas de espuma.',
    modulo: 'Teórico-práctico',
    norma: 'Manual del equipo',
  },
  {
    icon: 'fas fa-route',
    nombre: 'Protocolos de emergencia',
    descripcion: 'Activación, roles de brigada, comunicación y evacuación ante un evento.',
    modulo: 'Teórico-práctico',
    norma: 'NOM-002-STPS',
  },
  {
    icon: 'fas fa-screwdriver-wrench',
    nombre: 'Mantenimiento básico',
    descripcion: 'Inspección visual y cuidado del equipo que el operador puede realizar.',
    modulo: 'Práctico',
    norma: 'NFPA 25 (básico)',
  },
  {
    icon: 'fas fa-people-group',
    nombre: 'Simulacros de emergencia',
    descripcion: 'Ejercicio realista del escenario de incendio con el equipo de la planta.',
    modulo: 'Práctico',
    norma: 'NOM-002-STPS',
  },
  {
    icon: 'fas fa-file-contract',
    nombre: 'Marco normativo',
    descripcion: 'Obligaciones de la NOM-002-STPS y responsabilidades de la brigada.',
    modulo: 'Teórico',
    norma: 'NOM-002-STPS',
  },
];

// DIFERENCIADOR 3 — Qué incluye (pg-sol)
const incluye = [
  {
    icon: 'fas fa-certificate',
    titulo: 'Certificados de competencia',
    texto: 'Documento que acredita la competencia adquirida por cada participante.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-stamp',
    titulo: 'Constancia DC-3 (STPS)',
    texto: 'Constancia oficial de competencias o habilidades laborales ante la STPS.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-book-open',
    titulo: 'Manual de operación',
    texto: 'Material de consulta del equipo y los protocolos para el día a día de la brigada.',
    producto: 'Ver catálogo de equipo',
    url: '/productos',
  },
  {
    icon: 'fas fa-chalkboard',
    titulo: 'Material didáctico',
    texto: 'Recursos de apoyo para la formación, entregados a cada participante.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-people-roof',
    titulo: 'Simulacros',
    texto: 'Ejercicios prácticos sobre el equipo real para fijar el conocimiento.',
    producto: 'Ver monitores portátiles',
    url: '/monitores-portatiles',
  },
  {
    icon: 'fas fa-clipboard-check',
    titulo: 'Evaluación documentada',
    texto: 'Registro de la evaluación de competencia para el expediente de la planta.',
    producto: 'Ver consultoría normativa',
    url: '/consultoria-normativa',
  },
];

// pg-dens — Niveles de competencia
const niveles = [
  ['Operador', 'Personal que usa el equipo en su tarea diaria', 'Uso correcto y seguro del monitor'],
  ['Brigadista', 'Integrantes de la brigada de emergencia', 'Respuesta coordinada ante un incendio'],
  ['Líder de brigada', 'Responsables de coordinar la respuesta', 'Mando, comunicación y toma de decisiones'],
];

const normativas = [
  { n: 'NOM-002-STPS', d: 'Prevención de incendios y brigadas' },
  { n: 'DC-3', d: 'Constancia de competencias (STPS)' },
  { n: 'NFPA 600', d: 'Brigadas industriales contra incendio' },
  { n: 'Protocolos NFPA', d: 'Métodos de extinción y respuesta' },
];

const errores = [
  'Comprar equipo sin capacitar a quien lo va a operar',
  'Dar teoría sin práctica ni simulacros con el equipo real',
  'Capacitar sin emitir constancia DC-3 ni evidencia',
  'Olvidar la NOM-002-STPS en materia de brigadas',
  'No diferenciar el nivel: operador, brigadista o líder',
  'Capacitar una sola vez y no reforzar con el tiempo',
];

const recomendaciones = [
  'Capacite a todo el personal que opera o responde con el equipo',
  'Combine teoría con práctica y simulacros sobre el equipo real',
  'Emita certificados y constancia DC-3 para el expediente',
  'Cumpla la NOM-002-STPS en materia de brigadas',
  'Defina el nivel de competencia por perfil de personal',
  'Refuerce la formación periódicamente y tras cambios de equipo',
];

const faqs = [
  { q: '¿Qué es la constancia DC-3 y por qué importa?', a: 'La DC-3 es la Constancia de Competencias o de Habilidades Laborales que reconoce la Secretaría del Trabajo y Previsión Social (STPS). Acredita oficialmente que un trabajador recibió y aprobó una capacitación específica. En materia de protección contra incendios, contar con personal capacitado y con su DC-3 no solo cumple la NOM-002-STPS: es la evidencia que la autoridad y la aseguradora esperan ver. AQUEON emite la constancia DC-3 como parte de la capacitación.' },
  { q: '¿La capacitación es teórica o práctica?', a: 'Ambas, y esa es la clave. La teoría —fundamentos del fuego, clases de fuego, protocolos— se lleva a la práctica con ejercicios y simulacros sobre el equipo real de su planta. Operar un monitor o desplegar un equipo portátil bajo presión no se aprende en una presentación: se aprende practicando. Por eso nuestra formación es teórico-práctica y culmina en simulacros realistas.' },
  { q: '¿Capacitan según el nivel del personal?', a: 'Sí. Diferenciamos el nivel de competencia: el operador que usa el equipo en su tarea diaria, el brigadista que responde ante una emergencia y el líder de brigada que coordina la respuesta. Cada nivel tiene objetivos, contenido y profundidad distintos. El programa se diseña a partir del perfil del personal y del riesgo de la instalación.' },
  { q: '¿La capacitación cumple con la NOM-002-STPS?', a: 'Sí. La NOM-002-STPS obliga a los centros de trabajo a contar con brigadas capacitadas en prevención y combate de incendios. Nuestro programa cubre los requisitos de la norma —protocolos, roles de brigada, simulacros— y entrega la evidencia documental (certificados, DC-3, registros de asistencia) que la autoridad solicita en una inspección.' },
  { q: '¿Dónde se imparte la capacitación?', a: 'Preferentemente en sitio, en su instalación y con su equipo, para que la práctica sea sobre el escenario real. También podemos impartir la parte teórica en aula. La capacitación en sitio tiene la ventaja de que el personal se forma con el equipo que realmente va a operar, en el entorno donde tendría que responder.' },
  { q: '¿Con qué frecuencia se debe capacitar a la brigada?', a: 'La capacitación no es un evento único. Recomendamos reforzarla periódicamente y, especialmente, cada vez que cambia el equipo, el personal o el riesgo de la instalación. Una brigada capacitada hace años y nunca reentrenada pierde competencia. Podemos integrar la capacitación recurrente a su programa anual junto con el mantenimiento.' },
  { q: '¿Quién imparte los cursos?', a: 'Instructores con experiencia industrial de campo, que conocen el equipo y los escenarios reales de la industria, no solo la teoría. Esa experiencia es la que permite que la capacitación sea relevante y aplicable a la operación específica de cada cliente, con cobertura en los 32 estados de la República.' },
];
---
<Base
  title="Capacitación Contra Incendios y Brigadas DC-3 | AQUEON"
  description="Capacitación contra incendios para brigadas y operadores: teórico-práctica con simulacros, certificados y DC-3 conforme a la NOM-002-STPS. AQUEON México."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/servicios">Servicios</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Capacitación Especializada</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Servicios · Capacitación</span>
          <h1>Capacitación Especializada Contra Incendios</h1>
        </div>
        <div class="section-header__body">
          <p>El mejor equipo es inútil si la brigada no sabe usarlo <strong>bajo presión</strong>.</p>
          <p>Formación teórico-práctica con <strong>simulacros</strong>, certificados y constancia <strong>DC-3</strong> conforme a la NOM-002-STPS.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El servicio</span>
          <h2>El Equipo no Apaga el Fuego: lo Apaga la Gente</h2>
          <p>
            Se puede invertir en el mejor monitor, el mejor diseño y la mejor instalación, pero en el momento de la
            emergencia quien actúa es una <strong>persona</strong>. Si esa persona no sabe operar el equipo con seguridad y
            criterio, bajo el estrés de un incendio real, toda la inversión en protección queda en entredicho. La
            capacitación no es un complemento: es lo que activa todo lo demás.
          </p>
          <p>
            La capacitación de AQUEON es <strong>teórico-práctica</strong>: enseñamos los fundamentos y los llevamos a la
            práctica con <strong>simulacros sobre el equipo real</strong> de su planta. Formamos por nivel de competencia
            —operador, brigadista, líder de brigada—, evaluamos lo aprendido y emitimos <strong>certificados y la constancia
            DC-3</strong> conforme a la NOM-002-STPS. Con instructores que conocen el campo, no solo la teoría.
          </p>
          <p>
            En esta página verá las fases del programa, el temario, lo que incluye la capacitación y los niveles de
            competencia que formamos.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Fases del programa -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Metodología</span>
          <h2>Las Fases del Programa</h2>
        </div>
        <div class="section-header__body">
          <p>Del <strong>diagnóstico de necesidades</strong> a la <strong>certificación</strong>, formación con método.</p>
          <p>Cada fase con su entregable, para que la capacitación sea trazable.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {fases.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-list-ul" aria-hidden="true"></i> Incluye</span>
            <div class="l3-chips">
              {c.incluye.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-box-open" aria-hidden="true"></i> Entregable</span>
            <div class="l3-chips">
              <span class="l3-chip l3-chip--norm">{c.entrega}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Temario -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Contenido</span>
          <h2>Temario del Programa</h2>
        </div>
        <div class="section-header__body">
          <p>De los <strong>fundamentos del fuego</strong> a los <strong>simulacros</strong>: un temario completo.</p>
          <p>Cada módulo con su contenido, modalidad y respaldo normativo.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Módulo</th>
              <th scope="col">Qué cubre</th>
              <th scope="col">Modalidad</th>
              <th scope="col">Respaldo</th>
            </tr>
          </thead>
          <tbody>
            {temario.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td class="pg-scen-sol">{e.modulo}</td>
                <td>{e.norma}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> El temario se ajusta al equipo instalado, al riesgo de la planta y al nivel de competencia del personal.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Qué incluye -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Entregables</span>
          <h2>Qué Incluye la Capacitación</h2>
        </div>
        <div class="section-header__body">
          <p>Formación con <strong>evidencia documental</strong> para la operación y para la autoridad.</p>
          <p>Cada elemento enlaza con el servicio o equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {incluye.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- pg-dens: Niveles de competencia -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Perfiles</span>
          <h2>Niveles de Competencia</h2>
          <p>
            No todos en la planta necesitan la misma formación. Distinguimos <strong>tres niveles de competencia</strong>
            con objetivos y profundidad propios, para que cada persona reciba exactamente la capacitación que su rol exige.
            El programa final se diseña según el perfil de su personal.
          </p>
          <a href="/contacto" class="btn btn-outline"><i class="fas fa-chalkboard-user" aria-hidden="true"></i> Solicitar este servicio</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Nivel</th><th scope="col">Dirigido a</th><th scope="col">Resultado</th></tr>
            </thead>
            <tbody>
              {niveles.map(([n, d, r]) => (
                <tr><th scope="row">{n}</th><td>{d}</td><td class="pg-dens-ok">{r}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Formación que se Aplica el Día de la Emergencia</h2>
          <p>
            En <strong>AQUEON</strong> capacitamos con la misma seriedad con la que diseñamos e instalamos. Nuestros
            <strong>instructores con experiencia de campo</strong> forman a operadores, brigadistas y líderes con teoría,
            práctica y <strong>simulacros sobre el equipo real</strong>, y entregan certificados y la constancia DC-3
            conforme a la NOM-002-STPS. Porque conocemos su equipo: nosotros lo vendimos, lo instalamos y lo mantenemos.
          </p>
          <p>
            Capacitamos brigadas de <strong>refinerías, plantas, parques industriales, aeropuertos, minería y gobierno</strong>,
            con expediente de formación completo y cobertura en los 32 estados de la República desde la Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Todos los servicios</a>
            <a href="/monitores-portatiles" class="btn btn-outline-light"><i class="fas fa-fire-extinguisher" aria-hidden="true"></i> Equipo de brigada</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Normas de referencia</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Capacitación" contexto="el servicio de capacitación de brigadas y operadores" faqs={faqs} />

  <!-- Otros servicios -->
  <section class="l3-otras">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Ciclo Completo</span>
          <h2>Otros Servicios AQUEON</h2>
        </div>
        <div class="section-header__body">
          <p>Del diseño al mantenimiento, cubrimos <strong>todo el ciclo de vida</strong> de su sistema.</p>
          <p>Un solo proveedor con ingeniería, obra y soporte de por vida.</p>
        </div>
      </div>
      <div class="l3-otras-grid">
        <a href="/instalacion" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i></span><span class="l3-otra-name">Instalación Profesional</span><span class="l3-otra-sub">Montaje certificado · pruebas</span></a>
        <a href="/mantenimiento-preventivo" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-clipboard-check" aria-hidden="true"></i></span><span class="l3-otra-name">Mantenimiento Preventivo</span><span class="l3-otra-sub">NFPA 25 · disponibilidad</span></a>
        <a href="/consultoria-normativa" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-file-contract" aria-hidden="true"></i></span><span class="l3-otra-name">Consultoría Normativa</span><span class="l3-otra-sub">Auditorías · aseguradoras</span></a>
        <a href="/servicios" class="l3-otra l3-otra--all"><span class="l3-otra-icon"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i></span><span class="l3-otra-name">Ver todos los servicios</span><span class="l3-otra-sub">Ciclo de vida completo</span></a>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="l3-cta">
    <div class="container">
