---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: 'NFPA 24', label: 'Instalación de redes contra incendio' },
  { numero: '200 PSI', label: 'Prueba hidrostática de aceptación' },
  { numero: 'Certificados', label: 'Técnicos con experiencia industrial' },
  { numero: 'As-built', label: 'Planos y expediente de entrega' },
];

const beneficios = [
  'Técnicos certificados con experiencia en proyectos industriales',
  'Pruebas hidrostáticas y de flujo incluidas en el alcance',
  'Integración con su red hidráulica y sistemas existentes',
  'Documentación completa de entrega y planos as-built',
  'Anclaje y alineación conforme a las cargas de reacción',
  'Garantía de instalación por escrito',
];

// DIFERENCIADOR 1 — Fases de la instalación (pg-chain)
const fases = [
  {
    id: 'recepcion',
    eslabon: 'Fase 01',
    titulo: 'Recepción y Replanteo',
    icon: 'fas fa-clipboard-list',
    descripcion: 'Verificamos el equipo contra la especificación, revisamos el sitio y replanteamos la instalación sobre los planos de ingeniería.',
    incluye: ['Verificación de equipo', 'Revisión de sitio', 'Replanteo en obra', 'Plan de seguridad'],
    entrega: 'Acta de inicio',
  },
  {
    id: 'montaje',
    eslabon: 'Fase 02',
    titulo: 'Montaje e Integración',
    icon: 'fas fa-screwdriver-wrench',
    descripcion: 'Montamos monitores, tubería y accesorios, e integramos el sistema con su red hidráulica y de control existente.',
    incluye: ['Montaje de equipo', 'Anclaje y soporte', 'Integración hidráulica', 'Conexión a control'],
    entrega: 'Sistema montado',
  },
  {
    id: 'pruebas',
    eslabon: 'Fase 03',
    titulo: 'Pruebas Hidrostáticas',
    icon: 'fas fa-gauge-high',
    descripcion: 'Sometemos la red a prueba hidrostática y de flujo para verificar la estanqueidad, la presión y el desempeño antes de operar.',
    incluye: ['Prueba hidrostática', 'Lavado (flushing)', 'Verificación de presión', 'Prueba de flujo'],
    entrega: 'Reporte de pruebas',
  },
  {
    id: 'puesta',
    eslabon: 'Fase 04',
    titulo: 'Puesta en Marcha y Entrega',
    icon: 'fas fa-circle-check',
    descripcion: 'Arrancamos el sistema, capacitamos al personal de operación y entregamos el expediente técnico completo con planos as-built.',
    incluye: ['Arranque del sistema', 'Capacitación de arranque', 'Planos as-built', 'Acta de entrega'],
    entrega: 'Expediente de entrega',
  },
];

// DIFERENCIADOR 2 — Protocolo de pruebas de aceptación (pg-scen)
const pruebas = [
  {
    icon: 'fas fa-gauge-high',
    nombre: 'Prueba hidrostática',
    descripcion: 'Presurización de la red por encima de la presión de operación durante un tiempo definido.',
    verifica: 'Estanqueidad y resistencia de juntas, bridas y tubería.',
    norma: 'NFPA 24 (200 PSI / 2 h)',
  },
  {
    icon: 'fas fa-water',
    nombre: 'Lavado (flushing)',
    descripcion: 'Circulación de agua a alta velocidad para arrastrar residuos de obra de la tubería.',
    verifica: 'Limpieza interna antes de la puesta en marcha.',
    norma: 'NFPA 24',
  },
  {
    icon: 'fas fa-anchor',
    nombre: 'Anclaje y alineación',
    descripcion: 'Verificación del soporte y la fijación frente a las cargas de reacción del chorro.',
    verifica: 'Estabilidad del monitor en operación a plena presión.',
    norma: 'Especificación del fabricante',
  },
  {
    icon: 'fas fa-arrows-rotate',
    nombre: 'Prueba funcional',
    descripcion: 'Operación del monitor en todo su rango de giro, elevación y patrón de descarga.',
    verifica: 'Funcionamiento mecánico y, en remotos, el control.',
    norma: 'NFPA 25 (base operativa)',
  },
  {
    icon: 'fas fa-arrow-up-9-1',
    nombre: 'Verificación de presión y caudal',
    descripcion: 'Medición de presión y caudal en el punto de descarga contra el diseño.',
    verifica: 'Que el sistema entregue lo que dice la memoria de cálculo.',
    norma: 'NFPA 15 / 24',
  },
];

// DIFERENCIADOR 3 — Qué incluye la instalación (pg-sol)
const incluye = [
  {
    icon: 'fas fa-file-signature',
    titulo: 'Acta de entrega',
    texto: 'Documento formal de recepción del sistema con el alcance ejecutado y las condiciones de operación.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-clipboard-check',
    titulo: 'Reporte de pruebas',
    texto: 'Registro de la prueba hidrostática, lavado y pruebas funcionales con sus resultados.',
    producto: 'Solicitar este servicio',
    url: '/contacto',
  },
  {
    icon: 'fas fa-ruler-combined',
    titulo: 'Planos as-built',
    texto: 'Planos actualizados con la instalación tal como quedó construida, para operación y mantenimiento.',
    producto: 'Ver diseño e ingeniería',
    url: '/diseno-ingenieria',
  },
  {
    icon: 'fas fa-shield-halved',
    titulo: 'Garantía de instalación',
    texto: 'Garantía por escrito del montaje, además de la garantía de fábrica del equipo.',
    producto: 'Ver catálogo de equipo',
    url: '/productos',
  },
  {
    icon: 'fas fa-chalkboard-user',
    titulo: 'Capacitación de arranque',
    texto: 'Inducción al personal de operación sobre el uso seguro y correcto del sistema instalado.',
    producto: 'Ver capacitación',
    url: '/capacitacion',
  },
  {
    icon: 'fas fa-clipboard-list',
    titulo: 'Base para mantenimiento',
    texto: 'Condición inicial documentada que sirve de referencia para el programa NFPA 25.',
    producto: 'Ver mantenimiento',
    url: '/mantenimiento-preventivo',
  },
];

// pg-dens — Tipos de montaje e integración
const montajes = [
  ['Brida', 'Monitor fijo conectado a tubería bridada', 'Par de apriete y empaque correctos'],
  ['Pedestal', 'Monitor elevado sobre columna o estructura', 'Anclaje a base de concreto / estructura'],
  ['Skid / paquete', 'Sistema premontado en patín', 'Integración de bomba, válvulas y monitor'],
  ['Vehicular (deck gun)', 'Monitor sobre unidad de bomberos', 'Refuerzo y conexión a la bomba del vehículo'],
  ['Integración a red existente', 'Conexión a red contra incendio en operación', 'Trabajo en caliente y libranzas'],
];

const normativas = [
  { n: 'NFPA 24', d: 'Instalación de redes privadas contra incendio' },
  { n: 'NFPA 15', d: 'Sistemas fijos de agua pulverizada' },
  { n: 'NFPA 13', d: 'Rociadores y criterios de instalación' },
  { n: 'NFPA 25', d: 'Base de la inspección y prueba posterior' },
  { n: 'Prueba hidrostática', d: 'Aceptación de estanqueidad y presión' },
  { n: 'NOM-002-STPS', d: 'Condiciones de seguridad en obra' },
];

const errores = [
  'Instalar sin un diseño ni una memoria de cálculo previos',
  'Omitir la prueba hidrostática y el lavado de la red',
  'Anclar el monitor sin considerar la carga de reacción del chorro',
  'No documentar planos as-built ni el reporte de pruebas',
  'Dejar la puesta en marcha sin capacitación de operación',
  'Integrar a una red existente sin libranza ni trabajo seguro',
];

const recomendaciones = [
  'Parta del diseño y los planos de ingeniería aprobados',
  'Exija prueba hidrostática y lavado documentados',
  'Verifique anclaje y alineación contra la carga de reacción',
  'Reciba planos as-built y el expediente de pruebas',
  'Incluya la capacitación de arranque en el alcance',
  'Establezca desde la entrega el programa NFPA 25',
];

const faqs = [
  { q: '¿Qué incluye el servicio de instalación profesional?', a: 'Incluye la recepción y verificación del equipo, el replanteo en sitio, el montaje e integración con su red hidráulica y de control, las pruebas hidrostáticas y de flujo, el lavado de la red, la puesta en marcha, la capacitación de arranque y la entrega del expediente técnico con planos as-built, reporte de pruebas y garantía por escrito. Es un servicio llave en mano, no solo "atornillar el equipo".' },
  { q: '¿Por qué es indispensable la prueba hidrostática?', a: 'La prueba hidrostática presuriza la red por encima de la presión de operación —típicamente a 200 PSI durante 2 horas conforme a NFPA 24— para verificar que no haya fugas en juntas, bridas y tubería antes de poner el sistema en servicio. Detectar una fuga en la prueba es trivial; descubrirla durante una emergencia, catastrófico. Por eso ninguna instalación seria se entrega sin ella, documentada.' },
  { q: '¿Sus técnicos están certificados?', a: 'Sí. Nuestro personal de instalación tiene experiencia comprobada en proyectos industriales y trabaja conforme a NFPA 24 y a las especificaciones del fabricante, con los protocolos de seguridad de la NOM-002-STPS. En instalaciones que lo requieren, coordinamos libranzas y trabajo seguro con el área de seguridad del cliente.' },
  { q: '¿Pueden integrar el equipo a mi red contra incendio existente?', a: 'Sí. Una parte importante de nuestro trabajo es la integración: conectar el nuevo monitor o sistema a la red hidráulica y de control en operación, con la libranza y el trabajo en caliente necesarios, minimizando el tiempo fuera de servicio. La integración parte del diseño para garantizar que la red existente soporte la nueva demanda.' },
  { q: '¿Qué documentación entregan al terminar?', a: 'Entregamos el acta de entrega, el reporte de pruebas hidrostáticas y funcionales, los planos as-built (la instalación tal como quedó construida), la garantía de instalación por escrito y la condición inicial que sirve de base para el mantenimiento NFPA 25. Es la documentación que su operación, su aseguradora y Protección Civil requieren.' },
  { q: '¿La instalación incluye garantía?', a: 'Sí. Ofrecemos garantía por escrito del montaje, adicional a la garantía de fábrica del equipo que, como distribuidores autorizados, respaldamos. Además, al ser un solo proveedor de diseño, equipo, instalación y mantenimiento, la responsabilidad es única: no hay zonas grises entre proveedores.' },
  { q: '¿Trabajan en toda la República?', a: 'Sí. Realizamos instalaciones en los 32 estados de la República desde la Ciudad de México, coordinando logística, personal y pruebas en sitio. Para cada proyecto definimos un cronograma de obra claro y un responsable técnico.' },
];
---
<Base
  title="Instalación de Sistemas Contra Incendios | Pruebas NFPA"
  description="Instalación profesional de monitores contra incendio: montaje certificado, pruebas hidrostáticas NFPA 24 y planos as-built, con garantía por escrito. AQUEON."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/servicios">Servicios</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Instalación Profesional</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Servicios · Instalación</span>
          <h1>Instalación Profesional de Sistemas Contra Incendio</h1>
        </div>
        <div class="section-header__body">
          <p>El mejor diseño falla si el <strong>montaje y las pruebas</strong> no se hacen bien.</p>
          <p>Técnicos con experiencia industrial, <strong>pruebas hidrostáticas NFPA 24</strong> y entrega documentada con planos as-built.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El servicio</span>
          <h2>Una Instalación es Tan Buena como sus Pruebas</h2>
          <p>
            Un sistema contra incendio bien diseñado y con el mejor equipo puede fallar por una sola junta mal apretada o
            una red que nunca se probó. La instalación no es la parte "fácil" del proyecto: es donde el diseño se vuelve
            realidad o se pierde. La diferencia está en el <strong>rigor del montaje</strong> y, sobre todo, en las
            <strong>pruebas de aceptación</strong> que verifican que todo funciona antes de que llegue la emergencia.
          </p>
          <p>
            En AQUEON instalamos con <strong>técnicos de experiencia industrial</strong>, integramos el sistema con su red
            hidráulica y de control, ejecutamos <strong>prueba hidrostática, lavado y pruebas funcionales</strong> conforme a
            NFPA 24, y entregamos el sistema con planos as-built, reporte de pruebas y garantía por escrito. Un solo
            proveedor del diseño a la puesta en marcha: responsabilidad única, sin zonas grises.
          </p>
          <p>
            En esta página verá las fases de la instalación, el protocolo de pruebas de aceptación, lo que incluye el
            servicio y los tipos de montaje e integración que realizamos.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Fases -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Metodología</span>
          <h2>Las Cuatro Fases de la Instalación</h2>
        </div>
        <div class="section-header__body">
          <p>De la <strong>recepción del equipo</strong> a la <strong>puesta en marcha</strong>, cada fase con su entregable.</p>
          <p>Un proceso controlado que termina en un sistema probado y documentado.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {fases.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-list-ul" aria-hidden="true"></i> Incluye</span>
            <div class="l3-chips">
              {c.incluye.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-box-open" aria-hidden="true"></i> Entregable</span>
            <div class="l3-chips">
              <span class="l3-chip l3-chip--norm">{c.entrega}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Protocolo de pruebas -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Control de calidad</span>
          <h2>Protocolo de Pruebas de Aceptación</h2>
        </div>
        <div class="section-header__body">
          <p>Ningún sistema se entrega sin <strong>probarse</strong>: esto es lo que verificamos antes de operar.</p>
          <p>Cada prueba con su criterio y su norma, documentada en el reporte de entrega.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Prueba</th>
              <th scope="col">En qué consiste</th>
              <th scope="col">Qué verifica</th>
              <th scope="col">Norma / criterio</th>
            </tr>
          </thead>
          <tbody>
            {pruebas.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td>{e.verifica}</td>
                <td class="pg-scen-sol">{e.norma}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> Los valores y tiempos de prueba se ajustan al diseño del proyecto y a la presión de operación de la red.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Qué incluye -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Alcance</span>
          <h2>Qué Incluye la Instalación</h2>
        </div>
        <div class="section-header__body">
          <p>Más que montaje: <strong>pruebas, documentación y garantía</strong> en un solo alcance.</p>
          <p>Cada entregable enlaza con el servicio o equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {incluye.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- pg-dens: Tipos de montaje -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Integración</span>
          <h2>Tipos de Montaje e Integración</h2>
          <p>
            Cada proyecto exige un <strong>tipo de montaje</strong> distinto, con sus propias consideraciones técnicas: del
            monitor bridado a la integración de un patín completo o un sistema vehicular. Definimos el montaje a partir del
            diseño y de la infraestructura existente, cuidando el anclaje frente a la carga de reacción del chorro.
          </p>
          <a href="/productos" class="btn btn-outline"><i class="fas fa-layer-group" aria-hidden="true"></i> Ver catálogo de equipo</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Tipo de montaje</th><th scope="col">Aplicación</th><th scope="col">Consideración clave</th></tr>
            </thead>
            <tbody>
              {montajes.map(([t, a, c]) => (
                <tr><th scope="row">{t}</th><td>{a}</td><td>{c}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Del Diseño a la Puesta en Marcha, un Solo Responsable</h2>
          <p>
            En <strong>AQUEON</strong> la instalación es la continuación natural de nuestra ingeniería. Instalamos con
            <strong>técnicos de experiencia industrial</strong>, integramos con su red existente y probamos cada sistema
            conforme a NFPA 24 antes de entregarlo. Al ser un solo proveedor de diseño, equipo certificado, instalación y
            mantenimiento, la <strong>responsabilidad es única</strong>: no hay zonas grises entre proveedores.
          </p>
          <p>
            Instalamos para <strong>refinerías, plantas, parques industriales, aeropuertos, minería y gobierno</strong>, con
            documentación de entrega completa y cobertura en los 32 estados de la República desde la Ciudad de México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/diseno-ingenieria" class="btn btn-outline-light"><i class="fas fa-compass-drafting" aria-hidden="true"></i> Ver diseño e ingeniería</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Todos los servicios</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Normas de referencia</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqContactSplit titulo="Dudas sobre Instalación Profesional" contexto="el servicio de instalación de sistemas contra incendio" faqs={faqs} />

  <!-- Otros servicios -->
  <section class="l3-otras">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Ciclo Completo</span>
          <h2>Otros Servicios AQUEON</h2>
        </div>
        <div class="section-header__body">
          <p>Del diseño al mantenimiento, cubrimos <strong>todo el ciclo de vida</strong> de su sistema.</p>
          <p>Un solo proveedor con ingeniería, obra y soporte de por vida.</p>
        </div>
      </div>
      <div class="l3-otras-grid">
        <a href="/diseno-ingenieria" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-compass-drafting" aria-hidden="true"></i></span><span class="l3-otra-name">Diseño e Ingeniería</span><span class="l3-otra-sub">Cálculo hidráulico · planos</span></a>
        <a href="/mantenimiento-preventivo" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-clipboard-check" aria-hidden="true"></i></span><span class="l3-otra-name">Mantenimiento Preventivo</span><span class="l3-otra-sub">NFPA 25 · disponibilidad</span></a>
        <a href="/capacitacion" class="l3-otra"><span class="l3-otra-icon"><i class="fas fa-chalkboard-user" aria-hidden="true"></i></span><span class="l3-otra-name">Capacitación</span><span class="l3-otra-sub">Brigadas y operadores</span></a>
