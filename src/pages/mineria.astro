---
import Base from '../layouts/Base.astro';
import FaqContactSplit from '../components/sections/FaqContactSplit.astro';

const stats = [
  { numero: 'NOM-023', label: 'STPS — seguridad en minas' },
  { numero: 'NFPA 122', label: 'Protección en minería metálica' },
  { numero: '24/7', label: 'Operación continua en ambiente extremo' },
  { numero: 'Cielo · Subt.', label: 'Superficie y subterráneo' },
];

const beneficios = [
  'Equipos robustos para polvo, abrasión y vibración severa',
  'Protección de estaciones de combustible y reabastecimiento',
  'Cobertura de bandas transportadoras y puntos de transferencia',
  'Soluciones para talleres de equipo pesado y subestaciones',
  'Diseño conforme a NOM-023-STPS y NFPA 122 / 121',
  'Operación confiable 24/7 en minas a cielo abierto y subterráneas',
];

// DIFERENCIADOR 1 — Entornos mineros (pg-chain)
const entornos = [
  {
    id: 'cielo-abierto',
    eslabon: 'Superficie',
    titulo: 'Mina a Cielo Abierto',
    icon: 'fas fa-mountain-sun',
    descripcion: 'Grandes distancias, equipo móvil de alto valor y estaciones de combustible expuestas, con agua y respuesta a menudo lejanas.',
    activos: ['Camiones y palas', 'Estaciones de combustible', 'Subestaciones', 'Patios de servicio'],
    riesgos: ['Incendio de equipo móvil', 'Derrame de combustible'],
  },
  {
    id: 'subterranea',
    eslabon: 'Subterráneo',
    titulo: 'Mina Subterránea',
    icon: 'fas fa-helmet-safety',
    descripcion: 'Espacios confinados con ventilación limitada, equipo diésel y bandas; el humo y el calor son tan peligrosos como el fuego.',
    activos: ['Equipo diésel', 'Bandas transportadoras', 'Estaciones de carga', 'Refugios'],
    riesgos: ['Humo en confinamiento', 'Propagación por bandas'],
  },
  {
    id: 'beneficio',
    eslabon: 'Proceso',
    titulo: 'Planta de Beneficio',
    icon: 'fas fa-gears',
    descripcion: 'Chancado, molienda y procesamiento del mineral, con motores, bandas y, en algunos minerales, riesgo de polvo combustible.',
    activos: ['Chancadoras', 'Molinos', 'Bandas', 'Tableros eléctricos'],
    riesgos: ['Polvo combustible', 'Aceite y bandas'],
  },
  {
    id: 'talleres',
    eslabon: 'Servicio',
    titulo: 'Talleres y Patios',
    icon: 'fas fa-screwdriver-wrench',
    descripcion: 'Mantenimiento de equipo pesado, almacenes de combustible y lubricantes, y patios de maniobra de operación continua.',
    activos: ['Talleres de equipo pesado', 'Almacén de lubricantes', 'Llanteras', 'Patios'],
    riesgos: ['Líquidos inflamables', 'Llantas y residuos'],
  },
];

// DIFERENCIADOR 2 — Activos críticos (pg-scen)
const activos = [
  {
    icon: 'fas fa-gas-pump',
    nombre: 'Estación de combustible',
    descripcion: 'Reabastecimiento de diésel para flota pesada, con gran inventario y trasiego continuo.',
    estrategia: 'Espuma sobre derrames y enfriamiento de exposiciones, con cobertura de área (NFPA 11 / 30).',
    solucion: 'Monitor Magnum MG-4000 + espuma',
  },
  {
    icon: 'fas fa-conveyor-belt-boxes',
    nombre: 'Bandas transportadoras',
    descripcion: 'Líneas largas que pueden propagar el fuego y, bajo tierra, generar humo en confinamiento.',
    estrategia: 'Detección y descarga automática en puntos de transferencia y motrices.',
    solucion: 'Monitores Automáticos dirigidos',
  },
  {
    icon: 'fas fa-truck-monster',
    nombre: 'Equipo móvil pesado',
    descripcion: 'Camiones, palas y cargadores con motores, hidráulicos y combustible a presión.',
    estrategia: 'Enfriamiento de exposiciones y respaldo a los sistemas de supresión a bordo.',
    solucion: 'Monitores portátiles de brigada',
  },
  {
    icon: 'fas fa-tower-cell',
    nombre: 'Subestación eléctrica',
    descripcion: 'Transformadores y tableros que alimentan la operación, con riesgo de incendio de aceite.',
    estrategia: 'Agua pulverizada y enfriamiento operado a distancia en patios energizados.',
    solucion: 'Monitor Remoto ATEX MR-3000',
  },
  {
    icon: 'fas fa-warehouse',
    nombre: 'Taller de equipo pesado',
    descripcion: 'Mantenimiento con lubricantes, soldadura y residuos combustibles bajo techo.',
    estrategia: 'Protección de área con monitores fijos y respaldo portátil para la brigada.',
    solucion: 'Monitores fijos / portátiles',
  },
  {
    icon: 'fas fa-smog',
    nombre: 'Chancado y procesamiento',
    descripcion: 'Polvo combustible en ciertos minerales y carga de fuego por aceite y bandas.',
    estrategia: 'Supresión dirigida y gestión de polvo combustible en puntos críticos.',
    solucion: 'Monitores Automáticos + ingeniería',
  },
];

// DIFERENCIADOR 3 — Soluciones por área (pg-sol, interlink)
const soluciones = [
  {
    icon: 'fas fa-gas-pump',
    titulo: 'Estaciones de combustible',
    texto: 'Enfriamiento de exposiciones y espuma sobre derrames en estaciones de reabastecimiento de la flota.',
    producto: 'Monitor Magnum MG-4000',
    url: '/monitores-fijos#mg-4000',
  },
  {
    icon: 'fas fa-conveyor-belt-boxes',
    titulo: 'Bandas y puntos de transferencia',
    texto: 'Detección y descarga automática dirigida en líneas de transporte de mineral.',
    producto: 'Monitores Automáticos',
    url: '/monitores-automaticos',
  },
  {
    icon: 'fas fa-tower-cell',
    titulo: 'Subestaciones',
    texto: 'Enfriamiento de transformadores y patios energizados sin exponer personal, operado a distancia.',
    producto: 'Monitor Remoto ATEX MR-3000',
    url: '/monitores-fijos#mr-3000',
  },
  {
    icon: 'fas fa-truck-droplet',
    titulo: 'Respuesta de brigada',
    texto: 'Equipos portátiles robustos para puntos remotos, equipo móvil y maniobras de emergencia.',
    producto: 'Monitores Portátiles',
    url: '/monitores-portatiles',
  },
  {
    icon: 'fas fa-screwdriver-wrench',
    titulo: 'Talleres y almacenes',
    texto: 'Protección de área en talleres de equipo pesado y almacenes de combustible y lubricantes.',
    producto: 'Monitores Fijos Industriales',
    url: '/monitores-fijos',
  },
  {
    icon: 'fas fa-compass-drafting',
    titulo: 'Diseño NOM-023 / NFPA 122',
    texto: 'Ingeniería del sistema y documentación para cumplimiento minero y auditorías.',
    producto: 'Servicios de ingeniería',
    url: '/diseno-ingenieria',
  },
];

// EXTRA — Cielo abierto vs subterránea (pg-dens, comparativa)
const comparativa = [
  ['Entorno', 'Grandes distancias al aire libre', 'Espacios confinados con ventilación'],
  ['Riesgo dominante', 'Equipo móvil y combustible', 'Humo y propagación por bandas'],
  ['Disponibilidad de agua', 'Frecuentemente limitada / recirculada', 'Limitada y por bombeo'],
  ['Enfoque AQUEON', 'Cobertura de área y estaciones de combustible', 'Detección y supresión en puntos críticos'],
];

const normativas = [
  { n: 'NOM-023-STPS', d: 'Seguridad en minas subterráneas' },
  { n: 'NFPA 122', d: 'Prevención y control en minería metálica/no metálica' },
  { n: 'NFPA 121', d: 'Equipo móvil de minería autopropulsado' },
  { n: 'NFPA 120', d: 'Protección en minas de carbón' },
  { n: 'NFPA 15', d: 'Sistemas fijos de agua pulverizada' },
  { n: 'NFPA 11', d: 'Espuma para combustibles líquidos' },
  { n: 'NOM-002-STPS', d: 'Condiciones de seguridad — prevención de incendios' },
];

const errores = [
  'Diseñar igual una mina a cielo abierto que una subterránea',
  'Subestimar el humo en confinamiento como riesgo principal bajo tierra',
  'Ignorar las estaciones de combustible y el reabastecimiento de la flota',
  'No proteger las bandas transportadoras, ruta de propagación clave',
  'Especificar equipo no apto para polvo, abrasión y vibración',
  'Olvidar la disponibilidad limitada de agua en el diseño',
];

const recomendaciones = [
  'Diferencie la estrategia entre superficie y subterráneo',
  'Priorice estaciones de combustible, bandas y subestaciones',
  'Use equipo robusto para ambiente abrasivo y operación 24/7',
  'Integre detección temprana donde el humo es crítico',
  'Considere la disponibilidad de agua y la recirculación',
  'Diseñe conforme a NOM-023-STPS y NFPA 122 / 121',
];

const faqs = [
  { q: '¿La protección contra incendios es distinta en mina a cielo abierto y subterránea?', a: 'Sí, radicalmente. En cielo abierto el reto es la escala —grandes distancias, equipo móvil de alto valor y estaciones de combustible, con agua a menudo limitada—, por lo que predominan la cobertura de área y la protección de puntos fijos críticos. En subterráneo, el espacio confinado y la ventilación limitada hacen que el humo y el calor sean tan peligrosos como el fuego, y se prioriza la detección temprana y la supresión dirigida en bandas, estaciones de carga y equipo diésel, conforme a NOM-023-STPS.' },
  { q: '¿Qué normativa aplica a la minería en México?', a: 'La referencia principal de seguridad es la NOM-023-STPS para minas subterráneas, complementada por las prácticas NFPA 122 (prevención y control de incendios en minería metálica y no metálica), NFPA 121 (equipo móvil autopropulsado) y, en carbón, NFPA 120, además de NFPA 15 y NFPA 11 para los sistemas fijos. AQUEON diseña conforme a este marco y entrega la documentación de cumplimiento.' },
  { q: '¿Cómo se protege una estación de reabastecimiento de combustible?', a: 'Las estaciones de diésel de la flota concentran un gran inventario y trasiego continuo. Se protegen con monitores de alto caudal que aplican espuma sobre derrames y enfrían las exposiciones, dimensionados según el volumen y la disposición de la estación, conforme a NFPA 11 y NFPA 30. Es uno de los puntos fijos más críticos de una mina a cielo abierto.' },
  { q: '¿Por qué son críticas las bandas transportadoras?', a: 'Las bandas recorren largas distancias y, además de propagar el fuego entre áreas, bajo tierra pueden llenar de humo galerías enteras. Se protegen con detección temprana y descarga automática dirigida en los puntos de transferencia y en las estaciones motrices, integrando monitores automáticos con la estrategia general de la mina.' },
  { q: '¿Atienden el riesgo de polvo combustible en el procesamiento?', a: 'Sí. Algunos minerales y el carbón pueden generar polvo combustible con riesgo de deflagración en chancado, molienda y manejo. Lo abordamos con supresión dirigida en los puntos críticos y con asesoría de ingeniería para la gestión del polvo, integrada a la protección general de la planta de beneficio.' },
  { q: '¿Los equipos resisten el ambiente extremo de una mina?', a: 'Especificamos equipo robusto para condiciones de polvo, abrasión, vibración y operación continua 24/7, con materiales y recubrimientos adecuados al entorno. La selección parte de las condiciones reales del sitio para garantizar confiabilidad donde el mantenimiento y la respuesta pueden estar lejos.' },
  { q: '¿AQUEON diseña, instala y da mantenimiento en sitios remotos?', a: 'Sí. Partimos del análisis de riesgo por área (superficie, subterráneo, beneficio, talleres), diseñamos conforme a NOM-023-STPS y NFPA, calculamos caudales y entregamos planos y memoria de cálculo. Instalamos con técnicos certificados, probamos, capacitamos a la brigada y damos mantenimiento NFPA 25, con cobertura en los 32 estados de la República.' },
];
---
<Base
  title="Protección Contra Incendios para Minería | NOM-023-STPS"
  description="Protección contra incendios para minería en México: monitores para minas y plantas de beneficio con cumplimiento NOM-023-STPS y NFPA 122. Solicita cotización."
>
  <!-- Hero -->
  <section class="l3-hero">
    <div class="container">
      <nav class="l3-breadcrumb" aria-label="Migas de pan">
        <a href="/">Inicio</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <a href="/industrias">Industrias</a>
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
        <span>Minería</span>
      </nav>
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Industrias · Minería</span>
          <h1>Protección Contra Incendios para Minería</h1>
        </div>
        <div class="section-header__body">
          <p>El sector del <strong>ambiente extremo</strong>: equipo móvil de alto valor, bandas kilométricas y operación continua.</p>
          <p>Equipos robustos conforme a <strong>NOM-023-STPS y NFPA 122/121</strong>, para mina a cielo abierto y subterránea.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Banda de cifras -->
  <section class="l3-band">
    <div class="container">
      <div class="l3-band-grid">
        {stats.map((s) => (
          <div class="l3-band-item">
            <span class="l3-band-num">{s.numero}</span>
            <span class="l3-band-txt">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Introducción -->
  <section class="l3-intro">
    <div class="container">
      <div class="l3-intro-grid">
        <div class="l3-intro-text">
          <span class="section-tag">El reto del sector</span>
          <h2>Proteger Donde la Ayuda Está Lejos</h2>
          <p>
            La <strong>minería</strong> combina dos retos que ningún otro sector reúne: ambientes
            <strong>extremos</strong> —polvo, abrasión, vibración y operación 24/7— y la <strong>lejanía</strong> de la
            respuesta de emergencia y, muchas veces, del agua. Un incendio en un camión de acarreo, en una estación de
            combustible o en una banda transportadora puede crecer mucho antes de que llegue ayuda.
          </p>
          <p>
            Además, una mina no es un solo escenario: la <strong>superficie</strong> y el <strong>subterráneo</strong> son
            mundos distintos. A cielo abierto manda la escala y el equipo móvil; bajo tierra, el espacio confinado convierte
            al <strong>humo</strong> en el enemigo principal. La protección debe diseñarse por separado para cada uno,
            conforme a la NOM-023-STPS y a las prácticas NFPA 122 y 121.
          </p>
          <p>
            En esta página verá la protección por entorno minero, los activos críticos y su estrategia, las soluciones
            AQUEON por área y la diferencia clave entre operar a cielo abierto y bajo tierra.
          </p>
        </div>
        <ul class="l3-benefits">
          {beneficios.map((b) => (
            <li><i class="fas fa-check" aria-hidden="true"></i> {b}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 1: Entornos mineros -->
  <section class="pg-chain">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Mapa de riesgo</span>
          <h2>Protección por Entorno Minero</h2>
        </div>
        <div class="section-header__body">
          <p>De la superficie al subterráneo y al beneficio, cada entorno plantea un <strong>reto distinto</strong>.</p>
          <p>Identificarlo define la <strong>estrategia de protección</strong> correcta.</p>
        </div>
      </div>
      <div class="pg-chain-grid">
        {entornos.map((c) => (
          <article id={c.id} class="pg-chain-card">
            <div class="pg-chain-top">
              <span class="pg-chain-icon" aria-hidden="true"><i class={c.icon}></i></span>
              <div>
                <span class="pg-chain-kicker">{c.eslabon}</span>
                <h3>{c.titulo}</h3>
              </div>
            </div>
            <p>{c.descripcion}</p>
            <span class="pg-block-label"><i class="fas fa-cubes" aria-hidden="true"></i> Activos típicos</span>
            <div class="l3-chips">
              {c.activos.map((a) => <span class="l3-chip">{a}</span>)}
            </div>
            <span class="pg-block-label"><i class="fas fa-fire" aria-hidden="true"></i> Riesgos principales</span>
            <div class="l3-chips">
              {c.riesgos.map((r) => <span class="l3-chip l3-chip--norm">{r}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- DIFERENCIADOR 2: Activos críticos -->
  <section class="pg-scen">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Estrategia de respuesta</span>
          <h2>Activos Críticos y Cómo se Protegen</h2>
        </div>
        <div class="section-header__body">
          <p>De la estación de combustible a la chancadora, cada activo exige una <strong>estrategia propia</strong>.</p>
          <p>Esta matriz resume el enfoque de ingeniería que aplicamos a cada uno.</p>
        </div>
      </div>
      <div class="pg-scen-wrap">
        <table class="pg-scen-table">
          <thead>
            <tr>
              <th scope="col">Activo</th>
              <th scope="col">Riesgo</th>
              <th scope="col">Estrategia</th>
              <th scope="col">Solución AQUEON</th>
            </tr>
          </thead>
          <tbody>
            {activos.map((e) => (
              <tr>
                <th scope="row"><span class="pg-scen-name"><i class={e.icon} aria-hidden="true"></i> {e.nombre}</span></th>
                <td>{e.descripcion}</td>
                <td>{e.estrategia}</td>
                <td class="pg-scen-sol">{e.solucion}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pg-note"><i class="fas fa-circle-info" aria-hidden="true"></i> La estrategia definitiva se establece en el análisis de riesgo del sitio conforme a NOM-023-STPS y NFPA 122.</p>
    </div>
  </section>

  <!-- DIFERENCIADOR 3: Soluciones por área -->
  <section class="pg-sol">
    <div class="container">
      <div class="section-header split">
        <div class="section-header__head">
          <span class="section-tag">Soluciones AQUEON</span>
          <h2>El Equipo Correcto para Cada Área</h2>
        </div>
        <div class="section-header__body">
          <p>Combinamos monitores fijos, remotos, automáticos y portátiles en un <strong>sistema integral</strong>.</p>
          <p>Cada recomendación enlaza con la <strong>ficha técnica</strong> del equipo correspondiente.</p>
        </div>
      </div>
      <div class="pg-sol-grid">
        {soluciones.map((s) => (
          <article class="pg-sol-card">
            <span class="pg-sol-icon" aria-hidden="true"><i class={s.icon}></i></span>
            <h3>{s.titulo}</h3>
            <p>{s.texto}</p>
            <a href={s.url} class="pg-sol-link">{s.producto} <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- EXTRA: Cielo abierto vs subterránea -->
  <section class="pg-dens">
    <div class="container">
      <div class="pg-dens-grid">
        <div class="pg-dens-text">
          <span class="section-tag">Criterio de diseño</span>
          <h2>Cielo Abierto vs Subterránea</h2>
          <p>
            La diferencia entre proteger una mina a <strong>cielo abierto</strong> y una <strong>subterránea</strong> no es
            de grado, sino de naturaleza: cambia el riesgo dominante, la disponibilidad de agua y la estrategia. Diseñar
            ambas igual es el error más costoso del sector. Esta es la diferencia esencial que guía cada proyecto.
          </p>
          <a href="/consultoria-normativa" class="btn btn-outline"><i class="fas fa-clipboard-check" aria-hidden="true"></i> Ver consultoría normativa</a>
        </div>
        <div class="pg-dens-wrap">
          <table class="pg-dens-table">
            <thead>
              <tr><th scope="col">Aspecto</th><th scope="col">Cielo abierto</th><th scope="col">Subterránea</th></tr>
            </thead>
            <tbody>
              {comparativa.map(([a, c, s]) => (
                <tr><th scope="row">{a}</th><td>{c}</td><td>{s}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Errores y recomendaciones -->
  <section class="l3-guia">
    <div class="container">
      <div class="l3-guia-grid">
        <div class="l3-guia-card l3-guia-errores">
          <h3><i class="fas fa-triangle-exclamation" aria-hidden="true"></i> Errores comunes en el sector</h3>
          <ul>
            {errores.map((e) => <li><i class="fas fa-xmark" aria-hidden="true"></i> {e}</li>)}
          </ul>
        </div>
        <div class="l3-guia-card l3-guia-reco">
          <h3><i class="fas fa-clipboard-check" aria-hidden="true"></i> Recomendaciones de ingeniería</h3>
          <ul>
            {recomendaciones.map((r) => <li><i class="fas fa-check" aria-hidden="true"></i> {r}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- AQUEON + normativas -->
  <section class="l3-aqueon">
    <div class="container">
      <div class="l3-aqueon-inner">
        <div class="l3-aqueon-text">
          <span class="section-tag">Por qué AQUEON</span>
          <h2>Protección Confiable para la Operación Minera</h2>
          <p>
            En <strong>AQUEON</strong> diseñamos la protección de minas partiendo del entorno y de la lejanía de la
            respuesta. Somos distribuidores autorizados de Elkhart Brass, Akron Brass y Task Force Tips, y especificamos
            <strong>equipo robusto</strong> para polvo, abrasión y operación 24/7, conforme a NOM-023-STPS y NFPA 122 / 121.
            Entregamos ingeniería, instalación certificada, capacitación a la brigada y mantenimiento NFPA 25.
          </p>
          <p>
            Atendemos <strong>minas a cielo abierto, subterráneas, plantas de beneficio y patios de servicio</strong>, con
            documentación para auditorías y aseguradoras, y cobertura en los 32 estados de la República desde la Ciudad de
            México.
          </p>
          <div class="l3-aqueon-actions">
            <a href="/nosotros" class="btn btn-outline-light"><i class="fas fa-building-shield" aria-hidden="true"></i> Conozca AQUEON</a>
            <a href="/servicios" class="btn btn-outline-light"><i class="fas fa-screwdriver-wrench" aria-hidden="true"></i> Servicios de ingeniería</a>
          </div>
        </div>
        <div class="l3-normativas pg-norm">
          <h3>Marco normativo aplicable</h3>
          <ul class="pg-norm-list">
            {normativas.map((nm) => (
              <li><span class="pg-norm-tag">{nm.n}</span><span class="pg-norm-desc">{nm.d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

